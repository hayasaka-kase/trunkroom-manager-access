'==============================================================================*
'
'        MODULE_NAME      :fncMakeSql_FVS100_A03KEIY
'        機能             :契約本数を取得するSQL(契約解約件数表）
'        CREATE_DATE      :2009/10/23
'        IN               :
'        OUT              :SQL文
'        MEMO             :(新規)
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncMakeSql_FVS100_A03KEIY() As String
    
    Dim strSQL              As String
    Dim strShukeibi         As String '契約件数の集計日

    strSQL = ""

    '契約の集計日をセット
    If opg_契約の集計日_契件.VALUE = 1 Then
        '「契約開始日」を選択している場合
        strShukeibi = "CARG_STDATE"
    Else
        '「契約日」を選択している場合
        strShukeibi = "CARG_FSDATE"
    End If

    '対象年月の契約本数を取得
    If opg_集計単位_契件.VALUE = 1 Then
        '「年単位表示」を選択している場合
        strSQL = strSQL & " SELECT LEFT(CONVERT(varchar, " & strShukeibi & ",112),4) CARG_YEAR,  " & Chr(13)
    Else
        '「月単位表示」を選択している場合
        strSQL = strSQL & " SELECT LEFT(CONVERT(varchar, " & strShukeibi & ",112),6) CARG_STYM,  " & Chr(13)
        strSQL = strSQL & "        YEAR(" & strShukeibi & ") CARG_YEAR,  " & Chr(13)
        strSQL = strSQL & "        MONTH(" & strShukeibi & ") CARG_MONTH,  " & Chr(13)
    End If

    strSQL = strSQL & "        COUNT(*)         CNT " & Chr(13)
    
    strSQL = strSQL & "   FROM CARG_FILE " & Chr(13)
    
    strSQL = strSQL & "        LEFT OUTER JOIN CNTA_MAST " & Chr(13)
    strSQL = strSQL & "           ON CNTA_CODE = CARG_YCODE " & Chr(13)
    strSQL = strSQL & "          AND CNTA_NO = CARG_NO " & Chr(13)
    
    '用途コード、用途名
    strSQL = strSQL & "        LEFT OUTER JOIN " & Chr(13)
    strSQL = strSQL & "            ( " & Chr(13) & fncMakeYotoSql & "            ) CM1 " & Chr(13)
    strSQL = strSQL & "           ON CM1.CNTA_CODE = CARG_YCODE " & Chr(13)
    strSQL = strSQL & "          AND CM1.CNTA_USAGE = CNTA_MAST.CNTA_USAGE " & Chr(13)
    
    'サイズ
    strSQL = strSQL & "        LEFT OUTER JOIN " & Chr(13)
    strSQL = strSQL & "            ( " & Chr(13) & fncMakeSizeSql & "            ) CM2 " & Chr(13)
    strSQL = strSQL & "           ON CM2.CNTA_CODE = CARG_YCODE " & Chr(13)
    strSQL = strSQL & "          AND CM2.CNTA_NO = CARG_NO " & Chr(13)
    
    
    strSQL = strSQL & "  WHERE CONVERT(varchar, " & strShukeibi & ",112) " & pstrCondDate & Chr(13)

    strSQL = strSQL & "    AND NOT EXISTS( " & Chr(13)
    strSQL = strSQL & "                    SELECT * FROM YOUK_TRAN " & Chr(13)
    strSQL = strSQL & "                     WHERE    YOUKT_UKNO = CARG_UKNO " & Chr(13)
    strSQL = strSQL & "                       AND    ISNULL(YOUKT_MOTO_ACPTNO,'') <> '' ) " & Chr(13)
    
    '用途コードを条件にセット（用途「全て」にチェックしている場合は条件不要）
    If chk_用途全て.VALUE = 0 Then
        strSQL = strSQL & fncMakeCondYoto & Chr(13)
    End If
        
    'サイズを条件にセット（サイズ「全て」にチェックしている場合は条件不要）
    If chk_サイズ全て_契件.VALUE = 0 Then
        strSQL = strSQL & "    AND CM2.CNTA_SIZE IS NOT NULL " & Chr(13)
        strSQL = strSQL & "    AND CM2.CNTA_SIZE BETWEEN '" & txt_サイズF_契件 & "' AND '" & txt_サイズT_契件 & "' " & Chr(13)
    End If
    
    strSQL = strSQL & "  GROUP BY"
    If opg_集計単位_契件.VALUE = 1 Then
        '「年単位表示」を選択している場合
        strSQL = strSQL & " LEFT(CONVERT(varchar, " & strShukeibi & ",112),4);" & Chr(13)
    Else
        '「月単位表示」を選択している場合
        strSQL = strSQL & " LEFT(CONVERT(varchar, " & strShukeibi & ",112),6), " & Chr(13)
        strSQL = strSQL & "           YEAR(" & strShukeibi & "), " & Chr(13)
        strSQL = strSQL & "           MONTH(" & strShukeibi & ");"
    End If
    
    fncMakeSql_FVS100_A03KEIY = strSQL
    
End Function

