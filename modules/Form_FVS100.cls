'==============================================================================*
'
'        MODULE_NAME      :FVS100_A04_UKE
'        機能             :受付本数取得(個人別受付契約件数表）
'        CREATE_DATE      :2009/10/23
'        IN               :strBumonCode = 部門コード
'        OUT              :取得結果
'        MEMO             :（新規）
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
'Private Function FVS100_A04_UKE(dbSqlServer As Database) As Boolean                        'DEL 2009/10/30 kihara
Private Function FVS100_A04_UKE(strBumonCode As String) As Boolean                          'MOD 2009/10/30 kihara

    On Error GoTo Err_FVS100_A04_UKE

    Dim intMCount           As Integer  ' 月数
    Dim intDCount           As Integer  ' 日数
    Dim workDatas()         As Variant  ' 受付本数データ格納配列
    Dim workDatasTemp()     As Variant  ' 初期化用の配列
'    Dim rsKEIY_COUNT        As Recordset                                                   'DEL 2009/10/30 kihara
    Dim rsKEIY_COUNT        As Object                                                       'MOD 2009/10/30 kihara
    Dim strTantTemp         As String   ' 担当者コード
    Dim strYMTemp           As String   ' 日付(yyyy/mm)
    Dim strYMDTemp          As String   ' 日付(yyyy/mm/dd)
    Dim vTanto              As Variant  ' 受付担当者名
    Dim i                   As Integer
    
    '配列初期値設定
    If opg_対象年月日_個人.VALUE = 1 Then
        '「月単位表示」を選択している場合
        '月数を取得
        intMCount = DateDiff("m", txt_対象年月F_個人, txt_対象年月T_個人)
        '受付本数データ格納配列(月数）
        ReDim Preserve workDatas(intMCount)
        ReDim Preserve workDatasTemp(intMCount)
    Else
        '「日単位表示」を選択している場合
        '日数を取得
        intDCount = DateDiff("d", txt_対象年月日F_個人, txt_対象年月日T_個人)
        '受付本数データ格納配列(日数）
        ReDim Preserve workDatas(intDCount)
        ReDim Preserve workDatasTemp(intDCount)
    End If
    
    '配列に0をセット
    If opg_対象年月日_個人.VALUE = 1 Then
        '「月単位表示」を選択している場合
        For i = 0 To intMCount
            workDatas(i) = 0
            workDatasTemp(i) = 0
        Next
    Else
        '「日単位表示」を選択している場合
        For i = 0 To intDCount
            workDatas(i) = 0
            workDatasTemp(i) = 0
        Next
    End If
    
    '対象年月日の受付本数を取得
'    Set rsKEIY_COUNT = dbSqlServer.OpenRecordset(fncMakeSql_FVS100_A04UKE, dbOpenSnapshot, dbSQLPassThrough)   'DEL 2009/10/30 kihara
    Set rsKEIY_COUNT = MSZZ025.ADODB_Recordset(fncMakeSql_FVS100_A04UKE, pobjAdoDbConnection)                   'MOD 2009/10/30 kihara
    
    '該当レコードがない場合は処理しない
    If rsKEIY_COUNT.EOF Then
'        FVS100_A04_UKE = False                                                             'DEL 2009/10/30 kihara
        '受付本数取得処理を抜けて契約本数を取得処理へ
        FVS100_A04_UKE = True                                                               'MOD 2009/10/30 kihara
        Exit Function
    End If
    
   'ワークテーブルを更新
    If opg_対象年月日_個人.VALUE = 1 Then
        '「月単位表示」を選択している場合
        Set pRST_Access = pdbAccess.OpenRecordset(WORK_TABLE_個人_月, dbOpenDynaset, dbAppendOnly)
    Else
        '「日単位表示」を選択している場合
        Set pRST_Access = pdbAccess.OpenRecordset(WORK_TABLE_個人_日, dbOpenDynaset, dbAppendOnly)
    End If
    
    '受付本数データ格納配列に値をセット
    'カウンタ初期化
    i = 0
    '1レコード目の担当者コードをセット
    strTantTemp = rsKEIY_COUNT.Fields("YOUKT_UKTANTO")
    
    Do Until rsKEIY_COUNT.EOF
        '一つ前のレコードと担当者コードを比較
        If strTantTemp = rsKEIY_COUNT.Fields("YOUKT_UKTANTO") Then
        '同じ場合
            '受付件数をセットするindexを取得
             If opg_対象年月日_個人.VALUE = 1 Then
            '「月単位表示」を選択している場合
                strYMTemp = Left(rsKEIY_COUNT.Fields("YOUKT_KUDATEYM"), 4) & "/" _
                            & Right(rsKEIY_COUNT.Fields("YOUKT_KUDATEYM"), 2)
                i = DateDiff("m", txt_対象年月F_個人, strYMTemp)
            Else
            '「日単位表示」を選択している場合
                strYMDTemp = Left(rsKEIY_COUNT.Fields("YOUKT_KUDATEYMD"), 4) & "/" _
                            & Mid(rsKEIY_COUNT.Fields("YOUKT_KUDATEYMD"), 5, 2) & "/" _
                            & Right(rsKEIY_COUNT.Fields("YOUKT_KUDATEYMD"), 2)
                i = DateDiff("d", txt_対象年月日F_個人, strYMDTemp)
            End If
            '受付件数を配列にセット
            workDatas(i) = rsKEIY_COUNT.Fields("AUTO_TEL_UKE") + _
                           rsKEIY_COUNT.Fields("AUTO_INET_UKE") + rsKEIY_COUNT.Fields("MANUAL_TEL_UKE")

            '担当者コードをセット
            strTantTemp = rsKEIY_COUNT.Fields("YOUKT_UKTANTO")
            rsKEIY_COUNT.MoveNext
        Else
        '異なる場合
            '担当者名を取得
'            If GetTantoData(pdbAccess, strTantTemp, vTanto) = False Then GoTo Err_FVS100_A04_UKE      'DEL 2009/10/30 kihara
            If GetTantoData(strBumonCode, strTantTemp, vTanto) = False Then GoTo Err_FVS100_A04_UKE    'MOD 2009/10/30 kihara
            'workdatas()の値をワークテーブルにセット
            Call subAddWork4(workDatas, strTantTemp, vTanto, "受付")
            'workdatas()をクリア
            workDatas() = workDatasTemp()
            'カウンタ初期化、担当者コードをセット
            i = 0
            strTantTemp = rsKEIY_COUNT.Fields("YOUKT_UKTANTO")
        End If
    Loop

    '担当者名を取得
'    If GetTantoData(pdbAccess, strTantTemp, vTanto) = False Then GoTo Err_FVS100_A04_UKE   'DEL 2009/10/30 kihara
    If GetTantoData(strBumonCode, strTantTemp, vTanto) = False Then GoTo Err_FVS100_A04_UKE 'MOD 2009/10/30 kihara
    'workdatas()の値をワークテーブルにセット
    Call subAddWork4(workDatas, strTantTemp, vTanto, "受付")
          
    FVS100_A04_UKE = True
    
    Exit Function
    
Err_FVS100_A04_UKE:
    Call Err.Raise(Err.Number, "FVS100_A04_UKE" & vbRightAllow & Err.Source, Err.Description, Err.HelpFile, Err.HelpContext)
    FVS100_A04_UKE = False
End Function

'==============================================================================*
'
'        MODULE_NAME      :FVS100_A04_KEIY
'        機能             :契約本数取得(個人別受付契約件数表）
'        CREATE_DATE      :2009/10/23
'        IN               :strBumonCode = 部門コード
'        OUT              :取得結果
'        MEMO             :（新規）
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
'Private Function FVS100_A04_KEIY(dbSqlServer As Database) As Boolean                       'DEL 2009/10/30 kihara
Private Function FVS100_A04_KEIY(strBumonCode As String) As Boolean                         'MOD 2009/10/30 kihara

    On Error GoTo Err_FVS100_A04_KEIY

    Dim intMCount           As Integer  ' 月数
    Dim intDCount           As Integer  ' 日数
    Dim workDatas()         As Variant  ' 契約本数データ格納配列
    Dim workDatasTemp()     As Variant  ' 初期化用の配列
'    Dim rsKEIY_COUNT        As Recordset                                                   'DEL 2009/10/30 kihara
    Dim rsKEIY_COUNT        As Object                                                       'MOD 2009/10/30 kihara
    Dim strTantTemp         As String   ' 担当者コード
    Dim strYMTemp           As String   ' 日付(yyyy/mm)
    Dim strYMDTemp          As String   ' 日付(yyyy/mm/dd)
    Dim vTanto              As Variant  ' 契約担当者名
    Dim i                   As Integer
    
    '配列初期値設定
    If opg_対象年月日_個人.VALUE = 1 Then
        '「月単位表示」を選択している場合
        '月数を取得
        intMCount = DateDiff("m", txt_対象年月F_個人, txt_対象年月T_個人)
        '契約本数データ格納配列(月数）
        ReDim Preserve workDatas(intMCount)
        ReDim Preserve workDatasTemp(intMCount)
    Else
        '「日単位表示」を選択している場合
        '日数を取得
        intDCount = DateDiff("d", txt_対象年月日F_個人, txt_対象年月日T_個人)
        '契約本数データ格納配列(日数）
        ReDim Preserve workDatas(intDCount)
        ReDim Preserve workDatasTemp(intDCount)
    End If
    
    '配列に0をセット
    If opg_対象年月日_個人.VALUE = 1 Then
        '「月単位表示」を選択している場合
        For i = 0 To intMCount
            workDatas(i) = 0
            workDatasTemp(i) = 0
        Next
    Else
        '「日単位表示」を選択している場合
        For i = 0 To intDCount
            workDatas(i) = 0
            workDatasTemp(i) = 0
        Next
    End If

    '対象年月日の契約本数を取得
'    Set rsKEIY_COUNT = dbSqlServer.OpenRecordset(fncMakeSql_FVS100_A04KEIY, dbOpenSnapshot, dbSQLPassThrough)  'DEL 2009/10/30 kihara
    Set rsKEIY_COUNT = MSZZ025.ADODB_Recordset(fncMakeSql_FVS100_A04KEIY, pobjAdoDbConnection)                  'MOD 2009/10/30 kihara
            
    '該当レコードがない場合は処理しない
    If rsKEIY_COUNT.EOF Then
'        FVS100_A04_KEIY = False                                                            'DEL 2009/10/30 kihara
        '契約本数取得処理を抜け、受付本数が取得できていればExcel出力
        FVS100_A04_KEIY = True                                                              'MOD 2009/10/30 kihara
        Exit Function
    End If
        
   'ワークテーブルを更新
    If opg_対象年月日_個人.VALUE = 1 Then
        '「月単位表示」を選択している場合
        Set pRST_Access = pdbAccess.OpenRecordset(WORK_TABLE_個人_月, dbOpenDynaset, dbAppendOnly)
    Else
        '「日単位表示」を選択している場合
        Set pRST_Access = pdbAccess.OpenRecordset(WORK_TABLE_個人_日, dbOpenDynaset, dbAppendOnly)
    End If
    
    '契約本数データ格納配列に値をセット
    'カウンタ初期化
    i = 0
    '1レコード目の担当者コードをセット
    strTantTemp = rsKEIY_COUNT.Fields("CARG_UKTANTO")
    
    Do Until rsKEIY_COUNT.EOF
        '担当者コードを比較（1つ前のレコードとカレントレコード）
        If strTantTemp = rsKEIY_COUNT.Fields("CARG_UKTANTO") Then
        '同じ場合
            '契約件数をセットするindexを取得
            If opg_対象年月日_個人.VALUE = 1 Then
            '「月単位表示」を選択している場合
                strYMTemp = Left(rsKEIY_COUNT.Fields("CARG_STYM"), 4) & "/" _
                            & Right(rsKEIY_COUNT.Fields("CARG_STYM"), 2)
                i = DateDiff("m", txt_対象年月F_個人, strYMTemp)
            Else
            '「日単位表示」を選択している場合
                strYMDTemp = Left(rsKEIY_COUNT.Fields("CARG_STYMD"), 4) & "/" _
                            & Mid(rsKEIY_COUNT.Fields("CARG_STYMD"), 5, 2) & "/" _
                            & Right(rsKEIY_COUNT.Fields("CARG_STYMD"), 2)
                i = DateDiff("d", txt_対象年月日F_個人, strYMDTemp)
            End If
            '契約件数を配列にセット
            workDatas(i) = rsKEIY_COUNT.Fields("CNT")
            '担当者コードをセット
            strTantTemp = rsKEIY_COUNT.Fields("CARG_UKTANTO")
            rsKEIY_COUNT.MoveNext
        Else
        '異なる場合
            '担当者名を取得
'            If GetTantoData(pdbAccess, strTantTemp, vTanto) = False Then GoTo Err_FVS100_A04_KEIY      'DEL 2009/10/30 kihara
            If GetTantoData(strBumonCode, strTantTemp, vTanto) = False Then GoTo Err_FVS100_A04_KEIY    'MOD 2009/10/30 kihara
            'workdatas()の値をワークテーブルにセット
            Call subAddWork4(workDatas, strTantTemp, vTanto, "契約")
            'workdatas()をクリア
            workDatas() = workDatasTemp()
            'カウンタ初期化、担当者コードをセット
            i = 0
            strTantTemp = rsKEIY_COUNT.Fields("CARG_UKTANTO")
        End If
    Loop

    '担当者名を取得
'    If GetTantoData(pdbAccess, strTantTemp, vTanto) = False Then GoTo Err_FVS100_A04_KEIY   'DEL 2009/10/30 kihara
    If GetTantoData(strBumonCode, strTantTemp, vTanto) = False Then GoTo Err_FVS100_A04_KEIY 'MOD 2009/10/30 kihara
    'workdatas()の値をワークテーブルにセット
    Call subAddWork4(workDatas, strTantTemp, vTanto, "契約")
          
    FVS100_A04_KEIY = True
         
    Exit Function

Err_FVS100_A04_KEIY:
    Call Err.Raise(Err.Number, "FVS100_A04_KEIY" & vbRightAllow & Err.Source, Err.Description, Err.HelpFile, Err.HelpContext)
    FVS100_A04_KEIY = False
End Function

