    'サイズの名称をセット
    txt_サイズ_契件 = fncComboAfterUpdate(cmb_サイズ_契件, 2)
    
    'サイズ「全て」のチェックを外す
    chk_サイズ全て_契件.VALUE = 0

End Sub

