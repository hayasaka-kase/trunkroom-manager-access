'==============================================================================*
'
'        MODULE_NAME      :fncInputCheck3
'        機能             :入力チェック(個人別受付契約件数表）
'        CREATE_DATE      :2009/10/23
'        IN               :
'        OUT              :取得結果
'        MEMO             :(LF0050引用＋改修）
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncInputCheck3() As Boolean

    On Error GoTo ErrorHandler

    Dim blnError       As Boolean
    Dim intDateCnt     As Integer
    
    fncInputCheck3 = False
    blnError = False
    
    '範囲（大小チェック）
    If cmb_担当者コードF_個人.VALUE > cmb_担当者コードT_個人.VALUE Then
        MsgBox "範囲指定が不正です。", vbInformation, "確認"
        cmb_担当者コードF_個人.SetFocus
        Exit Function
    End If
    
    '「月単位表示」を選択している場合
    If opg_対象年月日_個人.VALUE = 1 Then
        '必須入力
        If Nz(txt_対象年月F_個人.VALUE, "") = "" Then
            MsgBox "日付を入力して下さい。", vbInformation, "確認"
            txt_対象年月F_個人.SetFocus
            Exit Function
        End If
        If Nz(txt_対象年月T_個人.VALUE, "") = "" Then
            MsgBox "日付を入力して下さい。", vbInformation, "確認"
            txt_対象年月T_個人.SetFocus
            Exit Function
        End If
        '範囲（大小チェック）
        If Me.txt_対象年月F_個人.VALUE > txt_対象年月T_個人.VALUE Then
            MsgBox "範囲指定が不正です。", vbInformation, "確認"
            txt_対象年月F_個人.SetFocus
            Exit Function
        End If
        '範囲（年数が10年を超えていたら確認メッセージ表示）
        intDateCnt = Year(txt_対象年月T_個人) - Year(txt_対象年月F_個人)
        If intDateCnt > 10 Then
            MsgBox "日付の範囲がオーバーしています。Excel出力可能な日付の範囲は最大10年です。", vbInformation, "確認"
            txt_対象年月F_個人.SetFocus
            Exit Function
        End If
    Else
    '「日単位表示」を選択している場合
        '必須入力
        If Nz(txt_対象年月日F_個人.VALUE, "") = "" Then
            MsgBox "日付を入力して下さい。", vbInformation, "確認"
            txt_対象年月日F_個人.SetFocus
            Exit Function
        End If
        If Nz(txt_対象年月日T_個人.VALUE, "") = "" Then
            MsgBox "日付を入力して下さい。", vbInformation, "確認"
            txt_対象年月日T_個人.SetFocus
            Exit Function
        End If
        '範囲（大小チェック）
        If Me.txt_対象年月日F_個人.VALUE > txt_対象年月日T_個人.VALUE Then
            MsgBox "範囲指定が不正です。", vbInformation, "確認"
            txt_対象年月日F_個人.SetFocus
            Exit Function
        End If
        '範囲（月数が6ヶ月を超えていたら確認メッセージ表示）
        intDateCnt = DateDiff("m", txt_対象年月日F_個人, txt_対象年月日T_個人)
        If intDateCnt > 6 Then
            MsgBox "日付の範囲がオーバーしています。Excel出力可能な日付の範囲は最大6ヶ月です。", vbInformation, "確認"
            txt_対象年月日F_個人.SetFocus
            Exit Function
        End If
    End If

    fncInputCheck3 = True
    GoTo ExitRtn

ErrorHandler:
    blnError = True

ExitRtn:
    If blnError Then
        Call Err.Raise(Err.Number, "fncDateCheck3" & vbRightAllow & Err.Source, Err.Description, Err.HelpFile, Err.HelpContext)
    End If

End Function

'==============================================================================*
'
'        MODULE_NAME      :LF0001_NEW_CNT
'        機能             :新規契約本数取得
'        CREATE_DATE      :2009/10/23
'        IN               :
'        OUT              :取得結果
'        MEMO             :（LF0001引用＋改修）
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
'Private Function LF0001_NEW_CNT(dbSqlServer As Database) As Boolean                        'DEL 2009/10/30 kihara
Private Function LF0001_NEW_CNT() As Boolean                                                'MOD 2009/10/30 kihara

    On Error GoTo Err_LF0001_NEW_CNT
    
    Dim strSQL              As String
'    Dim rsKEIY_COUNT        As Recordset                                                   'DEL 2009/10/30 kihara
    Dim rsKEIY_COUNT        As Object                                                       'MOD 2009/10/30 kihara

    strSQL = ""
    strSQL = "SELECT " & Chr(13)
    strSQL = strSQL & "CARG_YCODE, " & Chr(13)
    strSQL = strSQL & "COUNT(*)         CNT,  " & Chr(13)
    strSQL = strSQL & "SUM(CARG_RENTKG) GOUKE " & Chr(13)
    strSQL = strSQL & "FROM " & Chr(13)
    strSQL = strSQL & "CARG_FILE " & Chr(13)
    strSQL = strSQL & "WHERE " & Chr(13)
    If Me.txt_対象年月日F_契集 >= Me.txt_対象年月日T_契集 Then
        strSQL = strSQL & "CONVERT(varchar, CARG_STDATE, 111) Between '" & Me.txt_対象年月日T_契集 & "' AND '" & Me.txt_対象年月日F_契集 & "'" & Chr(13)
    Else
        strSQL = strSQL & "CONVERT(varchar, CARG_STDATE, 111) Between '" & Me.txt_対象年月日F_契集 & "' AND '" & Me.txt_対象年月日T_契集 & "'" & Chr(13)
    End If

    If Me.cmb_ヤードコードF_契集 >= Me.cmb_ヤードコードT_契集 Then
        strSQL = strSQL & "AND CARG_YCODE Between " & Me.cmb_ヤードコードT_契集 & " AND " & Me.cmb_ヤードコードF_契集 & " "
    Else
