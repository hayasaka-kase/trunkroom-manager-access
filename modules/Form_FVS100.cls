'                         :
'        OUT              :SQL文
'        MEMO             :(新規)
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncMakeYotoSql() As String

    Dim strSQL              As String
    
    strSQL = ""
    strSQL = strSQL & "             SELECT CNTA_CODE, " & Chr(13)
    strSQL = strSQL & "                    CNTA_USAGE, " & Chr(13)
    strSQL = strSQL & "                    NAME_MAST.NAME_NAME AS YOTO_NAME " & Chr(13)
    strSQL = strSQL & "               FROM CNTA_MAST " & Chr(13)
    strSQL = strSQL & "                    LEFT OUTER JOIN NAME_MAST " & Chr(13)
    strSQL = strSQL & "                      ON NAME_MAST.NAME_ID = '086' AND NAME_MAST.NAME_CODE = CNTA_MAST.CNTA_USAGE " & Chr(13)
    strSQL = strSQL & "              GROUP BY CNTA_CODE,CNTA_USAGE,NAME_MAST.NAME_NAME " & Chr(13)
    
    fncMakeYotoSql = strSQL
    
End Function

