'        CREATE_DATE      :2009/10/23
'        IN               :
'        OUT              :
'        MEMO             :(新規)
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub CLR_RTN()
On Error Resume Next

    Dim ctl As Control
  
    'このフォーム内のすべてのコントロールを検索
    For Each ctl In Me.Controls
        Select Case ctl.ControlType
            Case acTextBox, acComboBox, acCheckBox
              ctl.VALUE = Null
        End Select
    Next ctl
    
End Sub

