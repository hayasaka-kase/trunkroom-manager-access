    If TableExist(WORK_TABLE_契件_年) Then
        Call pdbAccess.TableDefs.Delete(WORK_TABLE_契件_年)
    End If
    If TableExist(WORK_TABLE_契件_月) Then
        Call pdbAccess.TableDefs.Delete(WORK_TABLE_契件_月)
    End If
    If TableExist(WORK_TABLE_個人_月) Then
        Call pdbAccess.TableDefs.Delete(WORK_TABLE_個人_月)
    End If
    If TableExist(WORK_TABLE_個人_日) Then
        Call pdbAccess.TableDefs.Delete(WORK_TABLE_個人_日)
    End If

    If Not pdbAccess Is Nothing Then pdbAccess.Close: Set pdbAccess = Nothing

End Sub

