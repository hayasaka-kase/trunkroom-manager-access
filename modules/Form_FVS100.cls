    strSQL = strSQL & "         NULL, " & Chr(13)
    strSQL = strSQL & "         NULL, " & Chr(13)
    strSQL = strSQL & "         NULL, " & Chr(13)
    strSQL = strSQL & "         NULL, " & Chr(13)
    strSQL = strSQL & "         NULL, " & Chr(13)
    strSQL = strSQL & "         NULL " & Chr(13)
    
    strSQL = strSQL & "  FROM YOUK_TRAN " & Chr(13)
    
    strSQL = strSQL & "       INNER JOIN YARD_MAST " & Chr(13)
    strSQL = strSQL & "          ON YARD_CODE = YOUKT_REQ_YCODE " & Chr(13)
    
