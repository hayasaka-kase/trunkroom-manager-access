'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub subAddWork2(workDatas() As Variant, strName As String)

    Dim i                   As Integer
    
    '各項目の本数をワークテーブルにセットする
    With pRST_Access
        For i = 0 To UBound(workDatas)
            .AddNew
            .Fields("対象項目") = strName
            .Fields("対象年") = Year(pstrDateFrom) + i
            .Fields("合計") = workDatas(i)
            .UPDATE
        Next
    End With
    
