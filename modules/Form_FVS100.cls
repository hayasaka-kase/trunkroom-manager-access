    strSQL = strSQL & "                AND ISNULL(YOUKT_MOVEKBN," & P_MOVEKBN_無し & ") = " & P_MOVEKBN_無し & Chr(13)
    
    strSQL = strSQL & "              GROUP BY YOUKT_YCODE, CNTA_MAST.CNTA_USAGE" & Chr(13)

    fncMakeUkeSql = strSQL
    
End Function

