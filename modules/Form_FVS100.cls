'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub subAddWork4(workDatas() As Variant, strTantTemp As String, _
                        vTanto As Variant, strName As String)

    Dim i                   As Integer
    Dim j                   As Integer

    With pRST_Access
       .AddNew
       .Fields("担当者コード") = strTantTemp
       .Fields("名称") = vTanto
       .Fields("予約状態") = strName
       '対象日付の列に件数をセット
       For i = 0 To UBound(workDatas)
           j = 3 + i
           .Fields(j) = workDatas(i)
           .Fields("合計") = Nz(.Fields("合計"), 0) + workDatas(i)
       Next
       .UPDATE
     End With
    
