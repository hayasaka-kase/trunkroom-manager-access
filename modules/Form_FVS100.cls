    With tdfNew
        Call .Fields.Append(.CreateField("対象項目", DataTypeEnum.dbText, 20))
        Call .Fields.Append(.CreateField("対象年", DataTypeEnum.dbText, 4))
        
        '「月単位表示」にチェックがある場合
        If opg_集計単位_契件.VALUE = 2 Then
            Call .Fields.Append(.CreateField("1月", DataTypeEnum.dbLong))
            Call .Fields.Append(.CreateField("2月", DataTypeEnum.dbLong))
            Call .Fields.Append(.CreateField("3月", DataTypeEnum.dbLong))
            Call .Fields.Append(.CreateField("4月", DataTypeEnum.dbLong))
            Call .Fields.Append(.CreateField("5月", DataTypeEnum.dbLong))
            Call .Fields.Append(.CreateField("6月", DataTypeEnum.dbLong))
            Call .Fields.Append(.CreateField("7月", DataTypeEnum.dbLong))
            Call .Fields.Append(.CreateField("8月", DataTypeEnum.dbLong))
            Call .Fields.Append(.CreateField("9月", DataTypeEnum.dbLong))
            Call .Fields.Append(.CreateField("10月", DataTypeEnum.dbLong))
            Call .Fields.Append(.CreateField("11月", DataTypeEnum.dbLong))
            Call .Fields.Append(.CreateField("12月", DataTypeEnum.dbLong))
        End If
        
        Call .Fields.Append(.CreateField("合計", DataTypeEnum.dbLong))
        
        For intCount = 0 To .Fields.Count - 1
            If .Fields(intCount).Type = dbText Then
                .Fields(intCount).AllowZeroLength = True
