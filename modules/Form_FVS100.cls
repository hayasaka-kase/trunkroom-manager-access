'==============================================================================*
'
'        MODULE_NAME      :fncMakeReqSql
'        機能             :予約数（部屋割付済）検索SQL作成
'        CREATE_DATE      :2009/10/23
'        IN               :strCondYard = ﾔｰﾄﾞｺｰﾄﾞの条件
'                         :strCondDate = 日付の条件
'        OUT              :SQL文
'        MEMO             :(LF0008引用＋改修)
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncMakeReqSql(strCondYard As String, strCondDate As String) As String

    Dim strSQL              As String
    
    strSQL = ""
    strSQL = strSQL & "             SELECT YOUKT_REQ_YCODE, " & Chr(13)
    
    '用途コード
    strSQL = strSQL & "                    CNTA_MAST.CNTA_USAGE AS USAGE, " & Chr(13)
    
    '自動紹介（電話）予約数
    strSQL = strSQL & "                    SUM( CASE WHEN YOUKT_GENKBN = " & P_GENKBN_電話 & Chr(13)
    strSQL = strSQL & "                               AND YOUKT_ORG_YUKBN = " & P_YUKBN_自動紹介 & Chr(13)
    strSQL = strSQL & "                               AND YOUKT_YUKBN != " & P_YUKBN_予約キャンセル & Chr(13)
    strSQL = strSQL & "                              THEN 1 ELSE 0 " & Chr(13)
    strSQL = strSQL & "                         END ) AS AUTO_TEL_REQ, " & Chr(13)
    
    '自動紹介（インターネット）予約数
    strSQL = strSQL & "                    SUM( CASE WHEN YOUKT_GENKBN = " & P_GENKBN_インターネット & Chr(13)
    strSQL = strSQL & "                               AND YOUKT_ORG_YUKBN IN(" & P_YUKBN_受付 & "," & P_YUKBN_予約キャンセル & ")" & Chr(13)
    strSQL = strSQL & "                              THEN 1 ELSE 0 " & Chr(13)
    strSQL = strSQL & "                         END ) AS AUTO_INET_REQ " & Chr(13)
    
    strSQL = strSQL & "               FROM YOUK_TRAN " & Chr(13)
    
    '用途コード、用途名
    strSQL = strSQL & "                    INNER JOIN CNTA_MAST " & Chr(13)
    strSQL = strSQL & "                       ON CNTA_CODE = YOUKT_REQ_YCODE AND CNTA_NO = YOUKT_NO " & Chr(13)
    
    strSQL = strSQL & "              WHERE YOUKT_REQ_YCODE " & strCondYard & Chr(13)
    strSQL = strSQL & "                AND YOUKT_UKDATE " & strCondDate & Chr(13)
    strSQL = strSQL & "                AND YOUKT_GENKBN IN(" & P_GENKBN_電話 & "," & P_GENKBN_インターネット & ") " & Chr(13)
    strSQL = strSQL & "                AND YOUKT_ORG_YUKBN IN( " & P_YUKBN_自動紹介 & "," & P_YUKBN_受付 & "," & P_YUKBN_予約キャンセル & ")" & Chr(13)
    
    strSQL = strSQL & "              GROUP BY YOUKT_REQ_YCODE, CNTA_MAST.CNTA_USAGE " & Chr(13)
    fncMakeReqSql = strSQL
    
End Function

