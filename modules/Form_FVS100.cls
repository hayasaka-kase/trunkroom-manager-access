'==============================================================================*
'
'        MODULE_NAME      :funcSelectChk
'        機能             :用途レコード選択件数
'        CREATE_DATE      :2009/10/23
'        IN               :
'        OUT              :
'        MEMO             :（新規）
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function funcSelectChk() As Boolean

    Dim objRs        As Recordset
    Dim objSubForm   As SubForm
    Dim intCnt       As Integer
    
    On Error GoTo funcSelectChk_Err
    
    '初期化
    intCnt = 0
    funcSelectChk = False
    Erase pYotoDatas                  '初期化
    Set objSubForm = Me.FVS100_S01
    
    Set objRs = objSubForm.Form.RecordsetClone
    objRs.MoveLast
    objRs.MoveFirst
    Do Until objRs.EOF
        'レコードを選択している場合は、用途コードを配列にセット
        If Nz(objRs.Fields("FVS100_CHECK"), False) = True Then
            ReDim Preserve pYotoDatas(intCnt)
            pYotoDatas(intCnt) = Nz(objRs.Fields("FVS100_YOTOCODE"), "")
            intCnt = intCnt + 1
        End If
        objRs.MoveNext
    Loop
    objRs.Close
    Set objRs = Nothing

    Set objSubForm = Nothing
    
    If intCnt = 0 Then
        funcSelectChk = False
        GoTo funcSelectChk_Exit
    End If
    
    funcSelectChk = True

funcSelectChk_Exit:
    If Not objRs Is Nothing Then objRs.Close: Set objRs = Nothing
    If Not objSubForm Is Nothing Then Set objSubForm = Nothing
    Exit Function

funcSelectChk_Err:
    MsgBox "ｴﾗｰ番号" & Err.Number & vbCrLf & Err.Description
    Err.Clear
    GoTo funcSelectChk_Exit

End Function

'==============================================================================*
'
'        MODULE_NAME      :SubSetDate
'        機能             :日付範囲条件作成
'        CREATE_DATE      :2009/10/23
'        IN               :strFrom = 範囲条件値FROM(yyyy/mm)
'                         :strTo = 範囲条件値TO(yyyy/mm)
'        OUT              :
'        MEMO             :(新規)
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub SubSetDate(strfrom As String, strTo As String)
    
    pstrDateFrom = ""
    pstrDateTo = ""
    pstrCondDate = ""
    
    '月の初日をセット
    If Nz(strfrom, "") = "" Then
        pstrDateFrom = "1900/01/01"
    Else
        '個人別受付契約件数表（日単位）の場合                               'INS 2009/10/30 kihara
        If pintSelectPage = 3 And opg_対象年月日_個人.VALUE = 2 Then        'INS 2009/10/30 kihara
            pstrDateFrom = strfrom                                          'INS 2009/10/30 kihara
        Else                                                                'INS 2009/10/30 kihara
            pstrDateFrom = Format(DateSerial(Year(strfrom), Month(strfrom), 1), "yyyy/mm/dd")
        End If                                                              'INS 2009/10/30 kihara
    End If
    '月の末日をセット
    If Nz(strTo, "") = "" Then
        pstrDateTo = "9999/12/31"
    Else
        '個人別受付契約件数表（日単位）の場合                               'INS 2009/10/30 kihara
        If pintSelectPage = 3 And opg_対象年月日_個人.VALUE = 2 Then        'INS 2009/10/30 kihara
            pstrDateTo = strTo                                              'INS 2009/10/30 kihara
        Else                                                                'INS 2009/10/30 kihara
            pstrDateTo = Format(DateSerial(Year(strTo), Month(strTo) + 1, 0), "yyyy/mm/dd")
        End If                                                              'INS 2009/10/30 kihara
    End If
    
    '日付の範囲条件をセット
    pstrCondDate = fncMakeBetween(Format(pstrDateFrom, "yyyymmdd"), Format(pstrDateTo, "yyyymmdd"))
   

End Sub

