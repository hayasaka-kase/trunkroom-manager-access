    Dim workDatas()         As Variant    ' 契約本数データ格納配列
    Dim workCount           As Integer    ' 契約本数データ数
    Dim i                   As Integer
    Dim j                   As Integer
    
    '配列初期値設定
    workCount = 0
    workCount = Year(pstrDateTo) - Year(pstrDateFrom)
    
    If opg_集計単位_契件.VALUE = 1 Then
        '「年単位表示」を選択している場合
        '契約本数データ格納配列(年数）
        ReDim Preserve workDatas(workCount)
        '0をセット
        For i = 0 To workCount
            workDatas(i) = 0
        Next
    Else
        '「月単位表示」を選択している場合
        '契約本数データ格納配列(年数,月数）
        ReDim Preserve workDatas(workCount, 11)
        '0をセット
        For i = 0 To workCount
            For j = 0 To 11
                workDatas(i, j) = 0
            Next
        Next
    End If
    
    '対象年月の契約本数を取得
'    Set rsKEIY_COUNT = dbSqlServer.OpenRecordset(fncMakeSql_FVS100_A03KEIY, dbOpenSnapshot, dbSQLPassThrough)  'DEL 2009/10/30 kihara
    Set rsKEIY_COUNT = MSZZ025.ADODB_Recordset(fncMakeSql_FVS100_A03KEIY, pobjAdoDbConnection)                  'MOD 2009/10/30 kihara
    
    '配列に値をセット
    'カウンタ初期化
    i = 0
    j = 0
    Do Until rsKEIY_COUNT.EOF
        If opg_集計単位_契件.VALUE = 1 Then
            '「年単位表示」を選択している場合
            'index番号を取得
            i = rsKEIY_COUNT.Fields("CARG_YEAR") - Year(pstrDateFrom)
            '契約本数をセット
            workDatas(i) = rsKEIY_COUNT.Fields("CNT")
        Else
            '「月単位表示」を選択している場合
            '1次元目のindex番号を取得
            i = rsKEIY_COUNT.Fields("CARG_YEAR") - Year(pstrDateFrom)
            '2次元目のindex番号を取得
            j = rsKEIY_COUNT.Fields("CARG_MONTH") - 1
            '契約本数をセット
            workDatas(i, j) = rsKEIY_COUNT.Fields("CNT")
        End If
        rsKEIY_COUNT.MoveNext
    Loop
      
   'ワークテーブルに配列のデータをセット
    If opg_集計単位_契件.VALUE = 1 Then
        '「年単位表示」を選択している場合
        Set pRST_Access = pdbAccess.OpenRecordset(WORK_TABLE_契件_年, dbOpenDynaset, dbAppendOnly)
        Call subAddWork2(workDatas(), "契約")
    Else
        '「月単位表示」を選択している場合
        Set pRST_Access = pdbAccess.OpenRecordset(WORK_TABLE_契件_月, dbOpenDynaset, dbAppendOnly)
        Call subAddWork3(workDatas(), "契約")
    End If
    
    pRST_Access.Close
    rsKEIY_COUNT.Close
    If workCount > 0 Then Erase workDatas

    FVS100_A03_KEIY = True
    Exit Function

