'
'        MODULE_NAME      :fncMakeCondYoto
'        機能             :用途条件作成
'        CREATE_DATE      :2009/10/23
'        IN               :
'        OUT              :条件文
'        MEMO             :(新規)
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncMakeCondYoto() As String

    Dim strSQL              As String
    Dim i                   As Integer
    Dim intCnt              As Integer  '用途コード格納配列の最大添字
    
    strSQL = ""
    intCnt = UBound(pYotoDatas)
    
    If intCnt = 0 Then
        '用途コードが１つの場合
        strSQL = "    AND CM1.CNTA_USAGE = " & pYotoDatas(0)
    Else
        '用途コードが複数の場合
        strSQL = strSQL & "    AND CM1.CNTA_USAGE IN ("
        For i = 0 To intCnt - 1
            strSQL = strSQL & pYotoDatas(i) & ","
        Next
        strSQL = strSQL & pYotoDatas(intCnt) & ")"
    End If
    
    fncMakeCondYoto = strSQL

End Function

