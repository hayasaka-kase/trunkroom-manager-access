'==============================================================================*
'
'        MODULE_NAME      :chk_用途全て_Click
'        機能             :chk_用途全て_Clickイベント
'        CREATE_DATE      :2009/10/23
'        IN               :
'        OUT              :
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub chk_用途全て_Click()
    
    If chk_用途全て.VALUE = -1 Then
        '「全て」にチェックを付けた場合
        'サブフォームの用途にチェックを付ける
        Call fncChangeFlgFVS100_W01(True)
        Me.FVS100_S01.Requery
        'サブフォーム編集不可
        FVS100_S01.Enabled = False
    Else
        '「全て」のチェックを外した場合
        'サブフォームの用途のチェックをクリア
        Call fncChangeFlgFVS100_W01(False)
        Me.FVS100_S01.Requery
        'サブフォーム編集可
        FVS100_S01.Enabled = True
    End If
End Sub

'==============================================================================*
'
'        MODULE_NAME      :Form_Load
'        機能             :Form_Loadイベント
'        CREATE_DATE      :2009/10/30
'        IN               :
'        OUT              :
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub Form_Load()

    FVS100_S01.Visible = True
    FVS100_S01.Enabled = False
    
    '用途のチェックボックスを選択
    chk_用途全て.VALUE = -1
    
    '用途格納配列を初期化
    Erase pYotoDatas
    
    '用途を画面に設定する
    Call fncSetYotoData
   
    'サブフォーム表示用ﾜｰｸﾃｰﾌﾞﾙのチェックフラグを立てる
    Call fncChangeFlgFVS100_W01(True)
    Me.FVS100_S01.Requery

End Sub

'==============================================================================*
'
'        MODULE_NAME      :FVS100_S01_Enter
'        機能             :FVS100_S01_Enterイベント
'        CREATE_DATE      :2009/10/23
'        IN               :
'        OUT              :
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub FVS100_S01_Enter()
On Error Resume Next

    If Me.FVS100_S01.Form.CurrentRecord <> 1 Then
        'サブフォームのカレントレコードが先頭ではない場合は先頭に移動
        doCmd.GoToRecord , , acFirst
        Me.FVS100_S01!chk_用途.SetFocus
    End If

End Sub

