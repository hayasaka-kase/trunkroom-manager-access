'==============================================================================*
'
'        MODULE_NAME      :cmd_Excel_Click
'        機能             :cmd_Excel_Click イベント
'        CREATE_DATE      :2009/10/23
'        IN               :
'        OUT              :
'        MEMO             :(LF0008引用＋改修)
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub cmd_excel_Click()

    On Error GoTo ErrorHandler
    
    '用途の選択チェック
    If chk_用途全て.VALUE = 0 Then
        If funcSelectChk = False Then
            '用途を何も選択していない場合はエラー
            MsgBox "用途を選択してください。", vbInformation, Me.NAME
            Exit Sub
        End If
    End If
    
    '選択ページの番号をセットする
    pintSelectPage = tab_ctl_予約契約解約帳票.VALUE
    
    Select Case pintSelectPage
        Case 0   '予約集計表
            If fncMakeReport_FVS100_A01 Then
                On Error Resume Next
                doCmd.OutputTo acOutputTable, WORK_TABLE_予約, "MicrosoftExcel(*.xls)", "", True, ""
                On Error GoTo ErrorHandler
            End If
        Case 1   '契約解約集計表
            If fncInputCheck = False Then
                Exit Sub
            End If
            If fncMakeReport_FVS100_A02 Then
                On Error Resume Next
                doCmd.OutputTo acQuery, QUERY_NAME_契集, "MicrosoftExcel(*.xls)", "", True, ""
                On Error GoTo ErrorHandler
            End If
        Case 2   '契約解約件数表
            '入力チェック
            If fncInputCheck2 = False Then
                Exit Sub
            End If
            'レポート用ワークテーブル作成
            If fncMakeReport_FVS100_A03 Then
                On Error Resume Next
                If opg_集計単位_契件.VALUE = 1 Then
                    '「年単位表示」を選択している場合
                    doCmd.OutputTo acOutputTable, WORK_TABLE_契件_年, "MicrosoftExcel(*.xls)", "", True, ""
                
                Else
                    '「月単位表示」を選択している場合
                    doCmd.OutputTo acOutputTable, WORK_TABLE_契件_月, "MicrosoftExcel(*.xls)", "", True, ""
                End If
                On Error GoTo ErrorHandler
            End If
        Case 3   '個人別受付契約件数表
            '入力チェック
            If fncInputCheck3 = False Then
                Exit Sub
            End If
            'レポート用ワークテーブル作成
            If fncMakeReport_FVS100_A04 Then
                On Error Resume Next
                If opg_対象年月日_個人.VALUE = 1 Then
'                    '「年単位表示」を選択している場合  'DEL 2009/10/30 kihara
                    '「月単位表示」を選択している場合   'MOD 2009/10/30 kihara
                    doCmd.OutputTo acQuery, QUERY_NAME_個人_月, "MicrosoftExcel(*.xls)", "", True, ""
                Else
'                    '「月単位表示」を選択している場合  'DEL 2009/10/30 kihara
                    '「日単位表示」を選択している場合   'MOD 2009/10/30 kihara
                    doCmd.OutputTo acQuery, QUERY_NAME_個人_日, "MicrosoftExcel(*.xls)", "", True, ""
                End If
                On Error GoTo ErrorHandler
            End If
    End Select
    
    Exit Sub

ErrorHandler:
    Call MSZZ024_M00("cmd_Excel_Click", True)
    Err.Clear

End Sub

