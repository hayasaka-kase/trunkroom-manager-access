    strSQL = strSQL & "                    CNTA_MAST.CNTA_USAGE AS USAGE, " & Chr(13)
    
    '自動紹介（電話）契約数
    strSQL = strSQL & "                    SUM( CASE WHEN YOUKT_GENKBN = " & P_GENKBN_電話 & Chr(13)
    strSQL = strSQL & "                               AND YOUKT_ORG_YUKBN = " & P_YUKBN_自動紹介 & Chr(13)
    strSQL = strSQL & "                              THEN 1 ELSE 0 " & Chr(13)
    strSQL = strSQL & "                         END ) AS AUTO_TEL_KEI, " & Chr(13)
    
    '自動紹介（インターネット）契約数
    strSQL = strSQL & "                    SUM( CASE WHEN YOUKT_GENKBN = " & P_GENKBN_インターネット & Chr(13)
    strSQL = strSQL & "                               AND YOUKT_ORG_YUKBN = " & P_YUKBN_受付 & Chr(13)
    strSQL = strSQL & "                              THEN 1 ELSE 0 " & Chr(13)
    strSQL = strSQL & "                         END ) AS AUTO_INET_KEI, " & Chr(13)
    
    '手動紹介（電話）契約数
    strSQL = strSQL & "                    SUM( CASE WHEN YOUKT_GENKBN = " & P_GENKBN_電話 & Chr(13)
    strSQL = strSQL & "                               AND YOUKT_ORG_YUKBN != " & P_YUKBN_自動紹介 & Chr(13)
    strSQL = strSQL & "                              THEN 1 ELSE 0 " & Chr(13)
    strSQL = strSQL & "                         END ) AS MANUAL_TEL_KEI " & Chr(13)
        
    strSQL = strSQL & "               FROM CARG_FILE " & Chr(13)
    strSQL = strSQL & "                    INNER JOIN YOUK_TRAN " & Chr(13)
    strSQL = strSQL & "                       ON YOUKT_UKNO = CARG_UKNO " & Chr(13)
    
    '用途コード、用途名
    strSQL = strSQL & "                    INNER JOIN CNTA_MAST" & Chr(13)
    strSQL = strSQL & "                       ON CNTA_CODE = CARG_YCODE AND CNTA_NO = CARG_NO " & Chr(13)
    
    strSQL = strSQL & "              WHERE CARG_YCODE " & strCondYard & Chr(13)
    strSQL = strSQL & "                AND CARG_STDATE " & strCondDate & Chr(13)
    strSQL = strSQL & "                AND YOUKT_GENKBN IN(" & P_GENKBN_電話 & "," & P_GENKBN_インターネット & ") " & Chr(13)
    strSQL = strSQL & "                AND YOUKT_ORG_YUKBN IN(" & P_YUKBN_自動紹介 & "," _
                                                                & P_YUKBN_自社理由 & "," _
                                                                & P_YUKBN_取置 & "," _
                                                                & P_YUKBN_受付 & ") " & Chr(13)
    strSQL = strSQL & "                AND ISNULL(YOUKT_MOVEKBN," & P_MOVEKBN_無し & ") = " & P_MOVEKBN_無し & Chr(13)
    
    strSQL = strSQL & "              GROUP BY CARG_YCODE, CNTA_MAST.CNTA_USAGE" & Chr(13)
    
    fncMakeKeiSql = strSQL
    
End Function

'==============================================================================*
'
'        MODULE_NAME      :fncMakeKaiyakuSql
'        機能             :解約数検索SQL作成
'        CREATE_DATE      :2009/10/23
'        IN               :strCondYard = ﾔｰﾄﾞｺｰﾄﾞの条件
'                         :strCondDate = 日付の条件
'        OUT              :SQL文
'        MEMO             :(LF0008引用＋改修)
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncMakeKaiyakuSql(strCondYard As String, strCondDate As String) As String

    Dim strSQL              As String
    
    strSQL = ""
    strSQL = strSQL & "             SELECT CARG_YCODE, " & Chr(13)
    
    '用途コード
    strSQL = strSQL & "                    CNTA_MAST.CNTA_USAGE AS USAGE, " & Chr(13)
    
    strSQL = strSQL & "                    COUNT(*) AS KAIYAKU " & Chr(13)

    strSQL = strSQL & "               FROM CARG_FILE " & Chr(13)
    '用途コード、用途名
    strSQL = strSQL & "                    INNER JOIN CNTA_MAST " & Chr(13)
    strSQL = strSQL & "                       ON CNTA_CODE = CARG_YCODE AND CNTA_NO = CARG_NO " & Chr(13)
    
    strSQL = strSQL & "              WHERE CARG_YCODE " & strCondYard & Chr(13)
    strSQL = strSQL & "                AND CARG_KYDATE " & strCondDate & Chr(13)
    strSQL = strSQL & "                AND NOT EXISTS " & Chr(13)
    strSQL = strSQL & "                ( SELECT * FROM YOUK_TRAN " & Chr(13)
    strSQL = strSQL & "                  WHERE YOUKT_MOTO_ACPTNO = CARG_ACPTNO ) " & Chr(13)
    
    strSQL = strSQL & "              GROUP BY CARG_YCODE,CNTA_MAST.CNTA_USAGE" & Chr(13)

    fncMakeKaiyakuSql = strSQL
    
End Function

'==============================================================================*
'
'        MODULE_NAME      :fncMakeBetween
'        機能             :範囲条件作成
'        CREATE_DATE      :2009/10/23
'        IN               :strFrom = 範囲条件値FROM
'                         :strTo = 範囲条件値TO
'        OUT              :条件文
'        MEMO             :(LF0008引用)
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncMakeBetween(strfrom As String, strTo As String) As String

    Dim strTemp     As String
    
    strTemp = ""
    
    If strfrom <> "" And strTo <> "" Then
        '共に空白ではない場合、
        If strfrom = strTo Then
            'FROMとTOが同一の場合、一致条件
            strTemp = " = '" & strfrom & "' "
        Else
            'FROMとTOが異なる場合、BETWEEN条件
            strTemp = " BETWEEN '" & strfrom & "' AND '" & strTo & "' "
        End If
    ElseIf strfrom <> "" Then
        'FROMのみの場合、それ以上であることが条件
        strTemp = " >= '" & strfrom & "' "
    ElseIf strTo <> "" Then
        'TOのみの場合、それ以下であることが条件
        strTemp = " <= '" & strTo & "' "
    End If
    
    fncMakeBetween = strTemp

End Function

'==============================================================================*
'
'        MODULE_NAME      :subAddWork
'        機能             :作業テーブル追加
'        CREATE_DATE      :2009/10/23
'        IN               :rsSource = 元ネタ
'                         :rsDestination = ワークテーブルレコードセット
'        OUT              :
'        MEMO             :(LF0008引用＋改修)
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub subAddWork(rsSource As Object, rsDestination As Recordset)

    Dim strFromTemp     As String
    Dim strToTemp       As String
    
    If Nz(txt_対象年月日F_予約, "") = "" Then
        strFromTemp = "1900/01/01"
    Else
        strFromTemp = txt_対象年月日F_予約
    End If
    
    If Nz(txt_対象年月日T_予約, "") = "" Then
        strToTemp = "9999/12/31"
    Else
        strToTemp = txt_対象年月日T_予約
    End If

    With rsDestination
        .AddNew

        .Fields("対象日FROM") = Format(strFromTemp, "yyyy/mm/dd")
        .Fields("対象日TO") = Format(strToTemp, "yyyy/mm/dd")
        .Fields("ヤードコード") = Format(rsSource.Fields("YARD_CODE"), "000000")
        .Fields("ヤード名") = rsSource.Fields("YARD_NAME")
        
        .Fields("用途") = rsSource.Fields("USAGE_NM")
        
        .Fields("自動紹介(電話)予約数") = Nz(rsSource.Fields("AUTO_TEL_REQ"), 0)
        .Fields("自動紹介(電話)受付数") = Nz(rsSource.Fields("AUTO_TEL_UKE"), 0)
        .Fields("自動紹介(電話)契約数") = Nz(rsSource.Fields("AUTO_TEL_KEI"), 0)
        
        .Fields("自動紹介(ｲﾝﾀｰﾈｯﾄ)予約数") = Nz(rsSource.Fields("AUTO_INET_REQ"), 0)
        .Fields("自動紹介(ｲﾝﾀｰﾈｯﾄ)受付数") = Nz(rsSource.Fields("AUTO_INET_UKE"), 0)
        .Fields("自動紹介(ｲﾝﾀｰﾈｯﾄ)契約数") = Nz(rsSource.Fields("AUTO_INET_KEI"), 0)
                
        .Fields("手動紹介(電話)受付数") = Nz(rsSource.Fields("MANUAL_TEL_UKE"), 0)
        .Fields("手動紹介(電話)契約数") = Nz(rsSource.Fields("MANUAL_TEL_KEI"), 0)
                
        .Fields("総受付数") = .Fields("自動紹介(電話)受付数") _
                            + .Fields("自動紹介(ｲﾝﾀｰﾈｯﾄ)受付数") _
                            + .Fields("手動紹介(電話)受付数")

        .Fields("総契約数") = .Fields("自動紹介(電話)契約数") _
                            + .Fields("自動紹介(ｲﾝﾀｰﾈｯﾄ)契約数") _
                            + .Fields("手動紹介(電話)契約数")

        .Fields("解約数") = Nz(rsSource.Fields("KAIYAKU"), 0)

        .Fields("差引本数") = .Fields("総契約数") - .Fields("解約数")
        
        .UPDATE
    End With
    
End Sub

