        strSQL = strSQL & "           MONTH(" & strShukeibi & ");"
    End If
    
    fncMakeSql_FVS100_A03CAM = strSQL
    
End Function

'==============================================================================*
'
'        MODULE_NAME      :fncMakeSql_FVS100_A04UKE
'        機能             :受付本数を取得するSQL(個人別受付契約件数表）
'        CREATE_DATE      :2009/10/23
'        IN               :
'        OUT              :SQL文
'        MEMO             :(新規)
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncMakeSql_FVS100_A04UKE() As String
    
    Dim strSQL              As String
    
    '対象年月日の受付本数を取得
    strSQL = ""
    strSQL = strSQL & " SELECT YOUKT_UKTANTO,  " & Chr(13)
    
    If opg_対象年月日_個人.VALUE = 1 Then
        '「月単位表示」を選択している場合
        strSQL = strSQL & "        LEFT(CONVERT(varchar, YOUKT_KUDATE,112),6) YOUKT_KUDATEYM,  " & Chr(13)
    Else
        '「日単位表示」を選択している場合
        strSQL = strSQL & "        LEFT(CONVERT(varchar, YOUKT_KUDATE,112),8) YOUKT_KUDATEYMD,  " & Chr(13)
    End If

    strSQL = strSQL & "        SUM( CASE WHEN YOUKT_GENKBN = 0 " & Chr(13)
    strSQL = strSQL & "                   AND YOUKT_ORG_YUKBN = 0 " & Chr(13)
    strSQL = strSQL & "                  THEN 1 ELSE 0 " & Chr(13)
    strSQL = strSQL & "             END ) AS AUTO_TEL_UKE, " & Chr(13)
    
    strSQL = strSQL & "        SUM( CASE WHEN YOUKT_GENKBN = 1 " & Chr(13)
    strSQL = strSQL & "                   AND YOUKT_ORG_YUKBN = 10 " & Chr(13)
    strSQL = strSQL & "                   AND YOUKT_YUKBN != 53 " & Chr(13)
    strSQL = strSQL & "                  THEN 1 ELSE 0 " & Chr(13)
    strSQL = strSQL & "             END ) AS AUTO_INET_UKE, " & Chr(13)
    
    strSQL = strSQL & "        SUM( CASE WHEN YOUKT_GENKBN = 0 " & Chr(13)
    strSQL = strSQL & "                   AND YOUKT_ORG_YUKBN != 0 " & Chr(13)
    strSQL = strSQL & "                  THEN 1 ELSE 0 " & Chr(13)
    strSQL = strSQL & "             END ) AS MANUAL_TEL_UKE " & Chr(13)
   
    strSQL = strSQL & "   FROM YOUK_TRAN " & Chr(13)
    
    strSQL = strSQL & "        LEFT OUTER JOIN CNTA_MAST " & Chr(13)
    strSQL = strSQL & "           ON CNTA_CODE = YOUKT_YCODE " & Chr(13)
    strSQL = strSQL & "          AND CNTA_NO = YOUKT_NO " & Chr(13)
    
    '用途コード、用途名
    strSQL = strSQL & "        LEFT OUTER JOIN " & Chr(13)
    strSQL = strSQL & "            ( " & Chr(13) & fncMakeYotoSql & "            ) CM1 " & Chr(13)
    strSQL = strSQL & "           ON CM1.CNTA_CODE = YOUKT_YCODE " & Chr(13)
    strSQL = strSQL & "          AND CM1.CNTA_USAGE = CNTA_MAST.CNTA_USAGE " & Chr(13)
    
    strSQL = strSQL & "        LEFT OUTER JOIN YARD_MAST " & Chr(13)
    strSQL = strSQL & "           ON YARD_CODE = YOUKT_YCODE " & Chr(13)
    
    strSQL = strSQL & "  WHERE CONVERT(varchar, YOUKT_KUDATE,112) " & pstrCondDate & Chr(13)
    strSQL = strSQL & "    AND YOUKT_UKTANTO " & pstrCondTant & Chr(13)
    strSQL = strSQL & "    AND YOUKT_GENKBN IN(0,1) " & Chr(13)
    strSQL = strSQL & "    AND YOUKT_ORG_YUKBN IN(0,1,2,10) " & Chr(13)
    strSQL = strSQL & "    AND YOUKT_YUKBN IN(10,20,53) " & Chr(13)
    strSQL = strSQL & "    AND ISNULL(YOUKT_MOVEKBN,0) = 0 " & Chr(13)
    
    '▼下記条件は必要か確認　解約したヤードは集計しなくて良いのか？
    strSQL = strSQL & "    AND ISNULL(YARD_END_DAY,'9999/12/31') > GETDATE() " & Chr(13)
    '▲
    
    '用途コードを条件にセット（用途「全て」にチェックしている場合は条件不要）
    If chk_用途全て.VALUE = 0 Then
        strSQL = strSQL & fncMakeCondYoto & Chr(13)
    End If
    
    strSQL = strSQL & "  GROUP BY YOUKT_UKTANTO,"
    If opg_対象年月日_個人.VALUE = 1 Then
        '「月単位表示」を選択している場合
        strSQL = strSQL & " LEFT(CONVERT(varchar, YOUK_TRAN.YOUKT_KUDATE,112),6)  " & Chr(13)
    Else
        strSQL = strSQL & " LEFT(CONVERT(varchar, YOUK_TRAN.YOUKT_KUDATE,112),8)  " & Chr(13)
    End If
    
    strSQL = strSQL & "  ORDER BY YOUKT_UKTANTO,"
    If opg_対象年月日_個人.VALUE = 1 Then
        '「月単位表示」を選択している場合
        strSQL = strSQL & " YOUKT_KUDATEYM;" & Chr(13)
    Else
        '「日単位表示」を選択している場合
        strSQL = strSQL & " YOUKT_KUDATEYMD;" & Chr(13)
    End If
    
    fncMakeSql_FVS100_A04UKE = strSQL
    
End Function


