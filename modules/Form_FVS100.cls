'==============================================================================*
'
'        MODULE_NAME      :GetTantoData
'        機能             :担当者マスタ情報取得
'        CREATE_DATE      :2009/10/23
'        IN               :strBumonCode = 部門コード
'                         :vTanto = 担当者ｺｰﾄﾞ
'                         :vTanNm = 担当者名
'        OUT              :取得結果
'        MEMO             :(FVS600引用＋改修）
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
'Private Function GetTantoData(ByRef objDb As Database, ByRef vTanto As Variant, Optional ByRef vTanNm As Variant) As Boolean   'DEL 2009/10/30 kihara
Private Function GetTantoData(ByRef strBumonCode As String, ByRef vTanto As Variant, _
                              Optional ByRef vTanNm As Variant) As Boolean  'MOD 2009/10/30 kihara

    Dim strSQL              As String
'    Dim objRs               As Recordset                                   'DEL 2009/10/30 kihara
    Dim objRs               As Object                                       'MOD 2009/10/30 kihara
    Dim strKaseSqlSvr       As String                                       'INS 2009/10/30 kihara

    GetTantoData = False

    '加瀬DB
    strKaseSqlSvr = Nz(DLookup("SETUT_SETUN", "SETU_TABL", "SETUT_SETUB = 'ODBC_DATA_SOURCE_NAME'")) 'INS 2009/10/30 kihara

    strSQL = ""
    strSQL = "SELECT "
    strSQL = strSQL & "TANT_MAST.TANTM_TANTC, "
    strSQL = strSQL & "TANT_MAST.TANTM_TANTN "
'    strSQL = strSQL & "FROM TANT_MAST INNER JOIN "                         'DEL 2009/10/30 kihara
    strSQL = strSQL & "FROM " & strKaseSqlSvr & ".dbo.TANT_MAST "           'MOD 2009/10/30 kihara
'    strSQL = strSQL & "dbo_CONT_MAST ON "                                  'DEL 2009/10/30 kihara
'    strSQL = strSQL & "TANT_MAST.TANTM_BUMOC = dbo_CONT_MAST.CONT_BUMOC "  'DEL 2009/10/30 kihara
    strSQL = strSQL & "WHERE "
    strSQL = strSQL & "TANT_MAST.TANTM_TANTC = " & "'" & Format$(vTanto, "000") & "' "
    strSQL = strSQL & "AND TANTM_BUMOC = " & "'" & strBumonCode & "'"       'MOD 2009/10/30 kihara

'    Set objRs = objDb.OpenRecordset(strSQL, dbOpenDynaset)                 'DEL 2009/10/30 kihara
    Set objRs = MSZZ025.ADODB_Recordset(strSQL, pobjAdoDbConnection)        'MOD 2009/10/30 kihara
    
    If objRs.EOF Then
        objRs.Close
        Set objRs = Nothing
        Exit Function
    Else
        If Nz(objRs("TANTM_TANTN"), "") <> "" Then vTanNm = objRs("TANTM_TANTN")
    End If

GetTantoData_End:
    objRs.Close
    Set objRs = Nothing
    GetTantoData = True
End Function

'==============================================================================*
'
'        MODULE_NAME      :用途データを読込、画面に設定する
'        機能             :fncSetYotoData
'        CREATE_DATE      :2009/10/23
'        IN               :
'        OUT              :取得結果
'        MEMO             :（新規）
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncSetYotoData() As Boolean
On Error GoTo Err_fncSetYotoData

'    Dim dbSqlServer         As Database                                                    'DEL 2009/10/30 kihara
    Dim strBumonCode        As String
    Dim strSQL              As String
'    Dim RST_Yoto            As Recordset                                                   'DEL 2009/10/30 kihara
    Dim RST_Yoto            As Object                                                       'DEL 2009/10/30 kihara
    
    fncSetYotoData = False
    
    '部門コード取得
    strBumonCode = Nz(DLookup("CONT_BUMOC", "dbo_CONT_MAST", "CONT_KEY=1"))
    If strBumonCode = "" Then
        'テーブル[CONT_MAST]の設定不正
        Call MSZZ024_M10("DLookup(""CONT_BUMOC"", ""dbo_CONT_MAST"", ""CONT_KEY=1"")", "テーブル[CONT_MAST]の設定不正。")
    End If
    
    'DB接続
'    Call subConnectServer(dbSqlServer, strBumonCode)                                       'DEL 2009/10/30 kihara
    Set pobjAdoDbConnection = MSZZ025.ADODB_Connection(strBumonCode)                        'MOD 2009/10/30 kihara
       
    'ACCESS接続
    Set pdbAccess = CurrentDb
      
    'ワークテーブルのクリア
    strSQL = ""
    strSQL = "DELETE FROM " & WORK_TABLE_用途 & "; "
    pdbAccess.Execute strSQL, dbFailOnError
    
    '用途一覧を取得
'    Set RST_Yoto = dbSqlServer.OpenRecordset(fncMakeSql_FVS100_S01YOTO, dbOpenSnapshot, dbSQLPassThrough)  'DEL 2009/10/30 kihara
    Set RST_Yoto = MSZZ025.ADODB_Recordset(fncMakeSql_FVS100_S01YOTO, pobjAdoDbConnection)                  'MOD 2009/10/30 kihara
    
    Set pRST_Access = pdbAccess.OpenRecordset(WORK_TABLE_用途, dbOpenDynaset, dbAppendOnly)

    Do Until RST_Yoto.EOF
       With pRST_Access
        .AddNew
        .Fields("FVS100_YOTOCODE") = RST_Yoto.Fields("NAME_CODE")
        .Fields("FVS100_YOTONAME") = RST_Yoto.Fields("NAME_RYAK")
        .UPDATE
       End With
       RST_Yoto.MoveNext
    Loop

    RST_Yoto.Close
    pRST_Access.Close

    Me.FVS100_S01.Requery
    fncSetYotoData = True
    
Exit_fncSetYotoData:
    'DB切断
'    If Not dbSqlServer Is Nothing Then dbSqlServer.Close: Set dbSqlServer = Nothing                         'DEL 2009/10/30 kihara
    If Not pobjAdoDbConnection Is Nothing Then: pobjAdoDbConnection.Close: Set pobjAdoDbConnection = Nothing 'MOD 2009/10/30 kihara
    If Not pdbAccess Is Nothing Then pdbAccess.Close: Set pdbAccess = Nothing
    Exit Function

Err_fncSetYotoData:
    MsgBox Err.Description
    fncSetYotoData = False
End Function

