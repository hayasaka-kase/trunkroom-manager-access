'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub FieldAppend3(tdfNew As TableDef)

    Dim fldNew        As Field
    Dim intMCount     As Integer    ' 月数
    Dim intDCount     As Integer    ' 日数
    Dim i             As Integer
    Dim intCount      As Integer
    Dim strYMTemp     As String
    Dim strYMDTemp    As String

    With tdfNew
        Call .Fields.Append(.CreateField("担当者コード", DataTypeEnum.dbText, 3))
        Call .Fields.Append(.CreateField("名称", DataTypeEnum.dbText, 30))
        Call .Fields.Append(.CreateField("予約状態", DataTypeEnum.dbText, 4))
        
        If opg_対象年月日_個人.VALUE = 1 Then
            '「月単位表示」を選択している場合
            '月数を取得
            intMCount = DateDiff("m", txt_対象年月F_個人, txt_対象年月T_個人)
            If Format(txt_対象年月F_個人, "dd") > Format(txt_対象年月T_個人, "dd") Then
                intMCount = intMCount - 1
            End If
            '年月のワークテーブル列を作成
            For i = 0 To intMCount
                strYMTemp = Format(DateAdd("m", i, DateSerial(CInt(Left([txt_対象年月F_個人], 4)), _
                                CInt(Right([txt_対象年月F_個人], 2)), 1)), "yyyy年m月")
                Call .Fields.Append(.CreateField(strYMTemp, DataTypeEnum.dbLong))
            Next
        Else
            '「日単位表示」を選択している場合
            '日数を取得
            intDCount = DateDiff("d", txt_対象年月日F_個人, txt_対象年月日T_個人)
            '年月日のワークテーブル列を作成
            For i = 0 To intDCount
                strYMDTemp = Format(DateAdd("d", i, DateSerial(CInt(Left([txt_対象年月日F_個人], 4)), _
                                CInt(Mid([txt_対象年月日F_個人], 6, 2)), _
                                CInt(Right([txt_対象年月日F_個人], 2)))), "yyyy年m月d日")
                Call .Fields.Append(.CreateField(strYMDTemp, DataTypeEnum.dbLong))
            Next
        End If

        '合計列作成
        Call .Fields.Append(.CreateField("合計", DataTypeEnum.dbLong))
        
        '空白フィールドの処理
        For intCount = 0 To .Fields.Count - 1
            If .Fields(intCount).Type = dbText Then
                .Fields(intCount).AllowZeroLength = True
            End If
        Next intCount
            
    End With
    
End Sub

'==============================================================================*
'
'        MODULE_NAME      :fncMakeSourceRecordSet
'        機能             :SQLサーバーから元ネタ取得
'        CREATE_DATE      :2009/10/23
'        IN               :dbSqlServer = SQLサーバー接続オブジェクト(ADODB)
'                         :rsSqlServer = レコードセットオブジェクト(ADODB)
'        OUT              :取得結果
'        MEMO             :(LF0008引用＋改修)
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncMakeSourceRecordSet(dbSQLServer As Object, ByRef rsSqlServer As Object) As Boolean
On Error GoTo ExitHandler
    
    fncMakeSourceRecordSet = False
    
    Set rsSqlServer = Nothing
    
    Set rsSqlServer = CreateObject("ADODB.Recordset")
    rsSqlServer.Open fncMakeSql_FVS100_A01(), dbSQLServer, adOpenForwardOnly, adLockReadOnly
    fncMakeSourceRecordSet = True
    
ExitHandler:

    If Not fncMakeSourceRecordSet Then
        Call Err.Raise(Err.Number, "fncMakeSourceRecordSet" & vbRightAllow & Err.Source, Err.Description, Err.HelpFile, Err.HelpContext)
    End If

End Function

'==============================================================================*
'
'        MODULE_NAME      :fncMakeSql_FVS100_A01
'        機能             :SQLサーバーからデータを取得するSQL（予約集計表）
'        CREATE_DATE      :2009/10/23
'        IN               :
'        OUT              :SQL文
'        MEMO             :(LF0008.fncMakeSql引用＋改修)
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncMakeSql_FVS100_A01() As String
    
    Dim strSQL              As String
    Dim strCondYard         As String
    Dim strCondDate         As String
    Dim strFromTemp         As String
    Dim strToTemp           As String
    Dim str予約数日付範囲   As String
        
    'ヤードコードの範囲条件
    strFromTemp = IIf(Nz(cmb_ヤードコードF_予約, "") = "", "000000", cmb_ヤードコードF_予約)
    strToTemp = IIf(Nz(cmb_ヤードコードT_予約, "") = "", "999999", cmb_ヤードコードT_予約)
    strCondYard = fncMakeBetween(strFromTemp, strToTemp)
    
    '日付の範囲条件
    strFromTemp = IIf(Nz(txt_対象年月日F_予約, "") = "", "1900/01/01", txt_対象年月日F_予約)
    strToTemp = IIf(Nz(txt_対象年月日T_予約, "") = "", "9999/12/31", txt_対象年月日T_予約)
    strCondDate = fncMakeBetween(Format(strFromTemp, "yyyy/mm/dd"), Format(strToTemp, "yyyy/mm/dd"))
    str予約数日付範囲 = fncMakeBetween(Format(strFromTemp, "yyyy/mm/dd") & " 00:00:00", Format(strToTemp, "yyyy/mm/dd") & " 23:59:59")
    
    strSQL = ""
    strSQL = strSQL & " SELECT YARD_CODE, " & Chr(13)
    strSQL = strSQL & "        YARD_NAME, " & Chr(13)
    
    strSQL = strSQL & "        CM1.YOTO_NAME AS USAGE_NM, " & Chr(13)
    
    strSQL = strSQL & "        TEMP_REQ.*, " & Chr(13)
    strSQL = strSQL & "        TEMP_UKE.*, " & Chr(13)
    strSQL = strSQL & "        TEMP_KEI.*, " & Chr(13)
    strSQL = strSQL & "        TEMP_KAIYAKU.* " & Chr(13)
    
    strSQL = strSQL & "   FROM YARD_MAST " & Chr(13)
    
    '用途コード、用途名
    strSQL = strSQL & "        INNER JOIN " & Chr(13)
    strSQL = strSQL & "            ( " & Chr(13) & fncMakeYotoSql & "            ) CM1 " & Chr(13)
    strSQL = strSQL & "           ON CM1.CNTA_CODE = YARD_CODE " & Chr(13)
    
    '予約数（部屋割付済）
    strSQL = strSQL & "        LEFT OUTER JOIN " & Chr(13)
    strSQL = strSQL & "            ( " & Chr(13) & fncMakeReqSql(strCondYard, str予約数日付範囲) & "      ) TEMP_REQ " & Chr(13)
    strSQL = strSQL & "          ON TEMP_REQ.YOUKT_REQ_YCODE = YARD_CODE " & Chr(13)
    strSQL = strSQL & "          AND TEMP_REQ.USAGE = CM1.CNTA_USAGE " & Chr(13)
    
    '受付数
    strSQL = strSQL & "        LEFT OUTER JOIN  " & Chr(13)
    strSQL = strSQL & "            ( " & Chr(13) & fncMakeUkeSql(strCondYard, strCondDate) & "            ) TEMP_UKE " & Chr(13)
    strSQL = strSQL & "          ON TEMP_UKE.YOUKT_YCODE = YARD_CODE " & Chr(13)
    strSQL = strSQL & "          AND TEMP_UKE.USAGE = CM1.CNTA_USAGE " & Chr(13)
    
    '契約数
    strSQL = strSQL & "        LEFT OUTER JOIN " & Chr(13)
    strSQL = strSQL & "            (  " & Chr(13) & fncMakeKeiSql(strCondYard, strCondDate) & "           ) TEMP_KEI " & Chr(13)
    strSQL = strSQL & "          ON TEMP_KEI.CARG_YCODE = YARD_CODE " & Chr(13)
    strSQL = strSQL & "          AND TEMP_KEI.USAGE = CM1.CNTA_USAGE " & Chr(13)
    
    '解約数
    strSQL = strSQL & "        LEFT OUTER JOIN " & Chr(13)
    strSQL = strSQL & "            ( " & Chr(13) & fncMakeKaiyakuSql(strCondYard, strCondDate) & "        ) TEMP_KAIYAKU " & Chr(13)
    strSQL = strSQL & "          ON TEMP_KAIYAKU.CARG_YCODE = YARD_CODE " & Chr(13)
    strSQL = strSQL & "          AND TEMP_KAIYAKU.USAGE = CM1.CNTA_USAGE " & Chr(13)
        
    '▼下記条件は必要か確認　解約したヤードは集計しなくて良いのか？
    strSQL = strSQL & "  WHERE ISNULL(YARD_END_DAY,'9999/12/31') > GETDATE() " & Chr(13)
    '▲
    strSQL = strSQL & "    AND YARD_CODE " & strCondYard & Chr(13)
    
    If chk_用途全て.VALUE = 0 Then
    '用途「全て」にチェック無し
        '用途コードを条件にセット
        strSQL = strSQL & fncMakeCondYoto & Chr(13)
    Else
    '用途「全て」にチェック有り
        '予約数（部屋未割付） コンテナが割付られていない予約本数も取得する
        strSQL = strSQL & "  UNION " & Chr(13)
        strSQL = strSQL & fncMakeReqSql2(strCondYard, str予約数日付範囲) & Chr(13)
    End If

    fncMakeSql_FVS100_A01 = strSQL
    
End Function

