'
'        MODULE_NAME      :chk_サイズ全て_契件_Click
'        機能             :chk_サイズ全て_契件_Clickイベント（契約解約件数表タブ）
'        CREATE_DATE      :2009/10/23
'        IN               :
'        OUT              :
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub chk_サイズ全て_契件_Click()

    If chk_サイズ全て_契件 = -1 Then
        '全てにチェックを付けたらコンボボックスとテキストボックスをクリア
        cmb_サイズ_契件 = ""
        txt_サイズ_契件 = ""
        txt_サイズF_契件 = ""
        txt_サイズT_契件 = ""
        'コンボボックス編集不可
        cmb_サイズ_契件.Enabled = False
        txt_サイズ_契件.Enabled = False
        txt_サイズ_契件.Locked = False
    Else
        'コンボボックス編集可
        cmb_サイズ_契件.Enabled = True
        txt_サイズ_契件.Enabled = True
        txt_サイズ_契件.Locked = True
    End If

End Sub

