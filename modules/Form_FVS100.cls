'
'        MODULE_NAME      :fncMakeReport_FVS100_A01
'        機能             :レポート用ワークテーブル作成
'        CREATE_DATE      :2009/10/23
'        IN               :
'        OUT              :取得結果
'        MEMO             :(LF0008.fncMakeReport引用＋改修)
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncMakeReport_FVS100_A01() As Boolean
On Error GoTo ErrorHandler
    
    Dim dbSQLServer         As Object       'ADODB.Connection
    Dim rsSqlServer         As Object       'ADODB.Recordset
    Dim rsAccess            As Recordset
    Dim strBumonCode        As String
    Dim blnError            As Boolean
    Dim strSQL              As String
    
    
    fncMakeReport_FVS100_A01 = False
    blnError = False
    
    doCmd.Hourglass True
    doCmd.SetWarnings False
    
    '部門コード取得
    strBumonCode = Nz(DLookup("CONT_BUMOC", "dbo_CONT_MAST", "CONT_KEY=1"))
    If strBumonCode = "" Then
        'テーブル[CONT_MAST]の設定不正
        Call MSZZ024_M10("DLookup(""CONT_BUMOC"", ""dbo_CONT_MAST"", ""CONT_KEY=1"")", "テーブル[CONT_MAST]の設定不正。")
    End If
    
    'SQL-Server接続
    Set dbSQLServer = CreateObject("ADODB.Connection")
    dbSQLServer.CommandTimeout = 180
    Call dbSQLServer.Open(MSZZ007_M10(strBumonCode))
    
    'ACCESS接続
    Set pdbAccess = CurrentDb
    
    'ワークテーブルクリア
    Call ClearWork(WORK_TABLE_予約)
    
    'レコードセット作成
    Call fncMakeSourceRecordSet(dbSQLServer, rsSqlServer)
    
    'ワークテーブルレコード追加
    Set rsAccess = pdbAccess.OpenRecordset(WORK_TABLE_予約, dbOpenDynaset, dbAppendOnly)
    
    With rsSqlServer
        If .EOF Then
            MsgBox "該当データが存在しません。", vbInformation, Me.NAME
            GoTo ExitHandler
        End If
        
        While Not .EOF
            'ワークのレコードセットをAddNew
            Call subAddWork(rsSqlServer, rsAccess)
            .MoveNext
        Wend
    End With
    
    '項目が全て0の行はEXCEL出力しない
    strSQL = ""
    strSQL = "DELETE FROM " & WORK_TABLE_予約
    strSQL = strSQL & " WHERE 総受付数 = 0 AND 総契約数 = 0 AND 解約数 = 0 AND [自動紹介(電話)予約数] = 0 AND [自動紹介(ｲﾝﾀｰﾈｯﾄ)予約数] = 0; "

    pdbAccess.Execute strSQL, dbFailOnError
   
    fncMakeReport_FVS100_A01 = True
    GoTo ExitHandler
    
ErrorHandler:
    blnError = True
    
ExitHandler:
    If Not rsSqlServer Is Nothing Then dbSQLServer.Close: Set dbSQLServer = Nothing
    If Not rsAccess Is Nothing Then pdbAccess.Close: Set pdbAccess = Nothing
    If Not dbSQLServer Is Nothing Then dbSQLServer.Close: Set dbSQLServer = Nothing
    If Not pdbAccess Is Nothing Then pdbAccess.Close: Set pdbAccess = Nothing

    doCmd.Hourglass False
    doCmd.SetWarnings True

    If blnError Then
        Call Err.Raise(Err.Number, "fncMakeReport_FVS100_A01" & vbRightAllow & Err.Source, Err.Description, Err.HelpFile, Err.HelpContext)
    End If
    
End Function

