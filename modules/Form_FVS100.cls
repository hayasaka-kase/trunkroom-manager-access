    strSQL = strSQL & "                AND YOUKT_KUDATE " & strCondDate & Chr(13)
    strSQL = strSQL & "                AND YOUKT_GENKBN IN(" & P_GENKBN_電話 & "," & P_GENKBN_インターネット & ") " & Chr(13)
    strSQL = strSQL & "                AND YOUKT_ORG_YUKBN IN(" & P_YUKBN_自動紹介 & "," _
                                                                & P_YUKBN_自社理由 & "," _
