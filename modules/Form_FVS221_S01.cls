Private Sub Form_KeyDown(KeyCode As Integer, Shift As Integer)
On Error Resume Next

    Select Case KeyCode
        Case vbKeyF1        'F1=「終了｣
            KeyCode = 0
            Parent.cmd_終了.SetFocus
        Case vbKeyF2 To vbKeyF12
            KeyCode = 0
    End Select

End Sub

