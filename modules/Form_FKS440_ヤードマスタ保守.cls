'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncINSKONT_MAST(ByVal intMode As Integer, ByRef objRsKONT As Recordset, _
                                 Optional ByRef objRsWk As Recordset = Nothing, _
                                 Optional ByRef varKONTDATA As Variant = Null, _
                                 Optional intDataPlace As Integer = 0) As Boolean

    fncINSKONT_MAST = False

    ' コンテナマスタにデータ登録
    With objRsKONT
        Select Case intMode
            Case intModeInsert  ' *** Insert ***
                .AddNew

            Case intModeUpdate  ' *** Update ***
                .Edit
        End Select

        If Not objRsWk Is Nothing Then
            .Fields("CNTA_CODE") = objRsWk.Fields("CNTA_CODE")                                ' ﾔｰﾄﾞｺｰﾄﾞ
            .Fields("CNTA_NO") = objRsWk.Fields("CNTA_NO")                                    ' ｺﾝﾃﾅ番号
