'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncSelectName(strNAME_ID As String, intNAME_CODE As Integer) As String

    Dim strWhere    As String
    Dim strName     As String

    fncSelectName = ""

    ' 名称マスタより名称を取得
    strWhere = ""
    strWhere = strWhere & " NAME_ID = '" & strNAME_ID & "'"
