            Set objRsKONT = pobjKONT_DB.OpenRecordset(strSQL, dbOpenDynaset)

            With objRsWk
                ' ワークのデータ登録
                Do Until .EOF
                    ' コンテナマスタ登録処理(登録)
                    If fncINSKONT_MAST(intModeInsert, objRsKONT, objRsWk) = False Then Exit Function
                    .MoveNext
                Loop
            End With

