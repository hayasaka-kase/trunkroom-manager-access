    Dim objRsWk      As Recordset  ' ワークテーブルレコードセット
    Dim objRsKONT    As Recordset  ' コンテナマスタレコードセット
' 2005/10/24 ADD T.SUZUKI End

' 2005/11/08 ADD T.SUZUKI Start
    Dim intWKCount   As Integer    ' ワークテーブルのデータ数
    Dim strWorkKey   As String     ' ワークテーブル.ヤードコード + ワークテーブル.コンテナ番号
    Dim strKontKey   As String     ' コンテナマスタ.ヤードコード + コンテナマスタ.コンテナ番号
