'==============================================================================*
'
'        MODULE_NAME      :DB更新処理
'        MODULE_ID        :WRI_AKKN_TRAN
'        Parameter        :intMode intModeInsert = 新規
'                                  intModeUpdate = 修正
'                                  intModeDelete = 削除
'        CREATE_DATE      :
'        戻り値           :True,False
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function WRI_AKKN_TRAN(ByVal intMode As Integer) As Boolean

    Dim strSQL          As String
    Dim StrYard         As Variant

    Dim intCount        As Integer      ' カウンター
    Dim objRsWk         As Recordset    ' ワークテーブルレコードセット
    'insert 2021/06/02 EGL Dim objRsAKKN       As Recordset    ' 自動鍵解除番号発番トランレコードセット
    'insert 2021/06/02 EGL Dim objRsDelAKKN    As Recordset    ' 自動鍵解除番号発番トラン削除データレコードセット
    Dim objRsAKKN       As Object       ' 自動鍵解除番号発番トランレコードセット
    Dim objRsDelAKKN    As Object       ' 自動鍵解除番号発番トラン削除データレコードセット

    Dim intWKCount      As Integer      ' ワークテーブルのデータ数
    Dim intDelCount     As Integer      ' 自動鍵解除番号発番トランの削除データ数
    Dim strWorkKey      As String       ' ワークテーブル.ヤードコード + ワークテーブル.コンテナ番号 + ワークテーブル.鍵区分
    Dim strAkknKey      As String       ' 自動鍵解除番号発番トラン.ヤードコード + 自動鍵解除番号発番トラン.コンテナ番号 + 自動鍵解除番号発番トラン.鍵区分
    Dim strAkknKey2     As String       ' 自動鍵解除番号発番トラン.ヤードコード + 自動鍵解除番号発番トラン.コンテナ番号 + 自動鍵解除番号発番トラン.鍵区分
    
    Dim dbSQLServer     As Object 'insert 2021/06/02 EGL

    WRI_AKKN_TRAN = False

    ' 対象ヤードコード設定
    StrYard = Val(Nz(Me.cmb_ヤードコード, ""))

    If StrYard = "" Then Exit Function

    'SQLサーバー接続
    Set dbSQLServer = ADODB_Connection(pstrBumoCD)  '2021/06/02 insert EGL

    intWKCount = 0
    intDelCount = 0

    ' 修正モードまたは削除モードの場合、自動鍵解除番号発番トランの最新データ抽出
    If (intMode = intModeUpdate Or intMode = intModeDelete) Then
        ' 自動鍵解除番号発番トランから最新データ抽出
        strSQL = ""
        strSQL = strSQL & "SELECT      *" & Chr(13)
        strSQL = strSQL & "FROM        AKKN_TRAN" & Chr(13)
        strSQL = strSQL & "WHERE       AKKNT_YARD = " & StrYard & Chr(13)
        strSQL = strSQL & "AND         AKKNT_STYPE = '4'" & Chr(13) 'insert EGL 2021/06/02 ★副種別を指定
        strSQL = strSQL & "ORDER BY    AKKNT_YARD" & Chr(13)
        strSQL = strSQL & ",           AKKNT_CTNO" & Chr(13)
        strSQL = strSQL & ",           AKKNT_KTYPE" & Chr(13)
        strSQL = strSQL & ",           AKKNT_HATUD DESC" & Chr(13)
        'Set objRsAKKN = pobjKONT_DB.OpenRecordset(strSql, dbOpenDynaset)
        Set objRsAKKN = ADODB_Recordset(strSQL, dbSQLServer, adoAppendOnly) '2021/06/02 insert EGL
    End If

    ' 削除モード時以外の場合、ワークテーブルのデータを抽出
    If intMode <> intModeDelete Then
        ' ワークテーブルのデータ抽出(上段・下段)
        strSQL = ""
        strSQL = strSQL & "SELECT      CNTA_CODE" & Chr(13)
        strSQL = strSQL & ",           CNTA_NO" & Chr(13)
        strSQL = strSQL & ",           CNTA_STEP" & Chr(13)
        strSQL = strSQL & ",           CNTA_KBN" & Chr(13)
        strSQL = strSQL & ",           CNTA_KEY_TYPE" & Chr(13)
        strSQL = strSQL & ",           CNTA_KEY_NO" & Chr(13)
        strSQL = strSQL & ",           CNTA_KEY_NUM" & Chr(13)
        strSQL = strSQL & ",           AKKNT_KAINO" & Chr(13)
        strSQL = strSQL & ",           AKKNT_KAINO_CHANGE" & Chr(13)
        strSQL = strSQL & "FROM        ヤード上ＷＫ" & Chr(13)
        strSQL = strSQL & "WHERE       CNTA_CODE = " & StrYard & Chr(13)        ' ヤードコード
        strSQL = strSQL & "AND         CNTA_STEP = " & pcintUpSide & Chr(13)    ' 段区分(0：上段)
        strSQL = strSQL & "AND         CNTA_NO  IS NOT NULL" & Chr(13)
        strSQL = strSQL & "AND         CNTA_SYU IS NOT NULL" & Chr(13)
        strSQL = strSQL & "UNION ALL" & Chr(13)
        strSQL = strSQL & "SELECT      CNTA_CODE" & Chr(13)
        strSQL = strSQL & ",           CNTA_NO" & Chr(13)
        strSQL = strSQL & ",           CNTA_STEP" & Chr(13)
        strSQL = strSQL & ",           CNTA_KBN" & Chr(13)
        strSQL = strSQL & ",           CNTA_KEY_TYPE" & Chr(13)
        strSQL = strSQL & ",           CNTA_KEY_NO" & Chr(13)
        strSQL = strSQL & ",           CNTA_KEY_NUM" & Chr(13)
        strSQL = strSQL & ",           AKKNT_KAINO" & Chr(13)
        strSQL = strSQL & ",           AKKNT_KAINO_CHANGE" & Chr(13)
        strSQL = strSQL & "FROM        ヤード下ＷＫ" & Chr(13)
        strSQL = strSQL & "WHERE       CNTA_CODE = " & StrYard & Chr(13)        ' ヤードコード
        strSQL = strSQL & "AND         CNTA_STEP = " & pcintDownSide & Chr(13)  ' 段区分(1：下段)
        strSQL = strSQL & "AND         CNTA_NO  IS NOT NULL" & Chr(13)
        strSQL = strSQL & "AND         CNTA_SYU IS NOT NULL" & Chr(13)
        strSQL = strSQL & "ORDER BY    1, 2" & Chr(13)
        
        Set objRsWk = WRI_objDb.OpenRecordset(strSQL, dbReadOnly)
    End If

    Select Case intMode
        Case intModeInsert  ' *** 新規 ***
            ' 自動鍵解除番号発番トランよりデータ抽出
            strSQL = ""
            strSQL = "SELECT * FROM AKKN_TRAN "
            Set objRsAKKN = pobjKONT_DB.OpenRecordset(strSQL, dbOpenDynaset)

            With objRsWk
                ' ワークのデータ登録
                Do Until .EOF
                    If Nz(.Fields("AKKNT_KAINO")) <> "" Then
                        ' 自動鍵解除番号発番トラン登録処理(登録)
                        If fncINSAKKN_TRAN(objRsAKKN, objRsWk) = False Then Exit Function
                    End If
                    .MoveNext
                Loop
            End With

        Case intModeUpdate  ' *** 修正 ***
            strAkknKey2 = ""

            Do Until (objRsWk.EOF And objRsAKKN.EOF)
                ' ワークテーブルのキー作成
                If objRsWk.EOF = True Then
'↓ UPDATE 2014/04/08 MIYAMOTO
'                    strWorkKey = pcstrKeyCode & "99"
                    strWorkKey = pcstrKeyCode
'↑ UPDATE 2014/04/08 MIYAMOTO
                Else
'↓ UPDATE 2014/04/08 MIYAMOTO
'                    strWorkKey = Format(objRsWk.Fields("CNTA_CODE"), "000000") _
'                               & Format(objRsWk.Fields("CNTA_NO"), "000000") _
'                               & Format(IIf(Nz(objRsWk.Fields("CNTA_KEY_TYPE")) = "", "0", Nz(objRsWk.Fields("CNTA_KEY_TYPE"))), "00")
                    strWorkKey = Format(objRsWk.Fields("CNTA_CODE"), "000000") _
                               & Format(objRsWk.Fields("CNTA_NO"), "000000")
'↑ UPDATE 2014/04/08 MIYAMOTO
                End If

                ' 自動鍵解除番号発番トランのキー作成
                If objRsAKKN.EOF = True Then
'↓ UPDATE 2014/04/08 MIYAMOTO
'                    strAkknKey = pcstrKeyCode & "99"
                    strAkknKey = pcstrKeyCode
'↑ UPDATE 2014/04/08 MIYAMOTO
                Else
'↓ UPDATE 2014/04/08 MIYAMOTO
'                    strAkknKey = Format(objRsAKKN.Fields("AKKNT_YARD"), "000000") _
'                               & Format(objRsAKKN.Fields("AKKNT_CTNO"), "000000") _
'                               & Format(objRsAKKN.Fields("AKKNT_KTYPE"), "00")
                    strAkknKey = Format(objRsAKKN.Fields("AKKNT_YARD"), "000000") _
                               & Format(objRsAKKN.Fields("AKKNT_CTNO"), "000000")
'↑ UPDATE 2014/04/08 MIYAMOTO
                End If

                If strAkknKey <> pcstrKeyCode & "99" And strAkknKey = strAkknKey2 Then
                    ' 自動鍵解除番号発番トランのキーが同一の場合はブレイクするまで読み飛ばす
                    ' 但し、自動鍵解除番号発番トランのデータがワークテーブルに存在しない場合は自動鍵解除番号発番トランのデータを削除
                    objRsAKKN.MoveNext
                Else
                    ' ワークテーブルと自動鍵解除番号発番トランのデータ比較
                    If strWorkKey = strAkknKey Then
                        ' ワークテーブルのデータと自動鍵解除番号発番トランのデータが一致する場合
                        If Nz(objRsWk.Fields("AKKNT_KAINO")) <> "" And _
                           Nz(objRsWk.Fields("AKKNT_KAINO")) <> Nz(objRsAKKN.Fields("AKKNT_KAINO")) Then
                            'ワークテーブル.解除番号が入力されていて、自動鍵解除番号発番トラン.解除番号と異なる場合
                            ' 自動鍵解除番号発番トラン登録処理(登録)
                            ' 配列にワークテーブルのデータをセット
                            ReDim Preserve pvarAKKNData(4, intWKCount)
                            pvarAKKNData(0, intWKCount) = objRsWk.Fields("CNTA_CODE")                   ' ヤードコード
                            pvarAKKNData(1, intWKCount) = objRsWk.Fields("CNTA_NO")                     ' コンテナ番号
                            pvarAKKNData(2, intWKCount) = objRsWk.Fields("CNTA_STEP")                   ' 段区分
                            pvarAKKNData(3, intWKCount) = Nz(objRsWk.Fields("CNTA_KEY_TYPE"), "")       ' 鍵区分
                            pvarAKKNData(4, intWKCount) = objRsWk.Fields("AKKNT_KAINO")                 ' 解除番号
                            intWKCount = intWKCount + 1  ' 登録用ワークテーブルデータ数カウントアップ
                        End If
    
                        ' → 次レコードの処理を行う
                        objRsWk.MoveNext    ' ワークテーブル
                        objRsAKKN.MoveNext  ' 自動鍵解除番号発番トラン
                        strAkknKey2 = strAkknKey
    
                    ElseIf strWorkKey < strAkknKey Then
                        ' ワークテーブルのデータが自動鍵解除番号発番トランに存在しない場合
                        ' → ワークテーブルのデータを自動鍵解除番号発番トランに登録
                        If Nz(objRsWk.Fields("AKKNT_KAINO")) <> "" Then
                            ' 配列にワークテーブルのデータをセット
                            ReDim Preserve pvarAKKNData(4, intWKCount)
                            pvarAKKNData(0, intWKCount) = objRsWk.Fields("CNTA_CODE")                   ' ヤードコード
                            pvarAKKNData(1, intWKCount) = objRsWk.Fields("CNTA_NO")                     ' コンテナ番号
                            pvarAKKNData(2, intWKCount) = objRsWk.Fields("CNTA_STEP")                   ' 段区分
                            pvarAKKNData(3, intWKCount) = Nz(objRsWk.Fields("CNTA_KEY_TYPE"), "")       ' 鍵区分
                            pvarAKKNData(4, intWKCount) = objRsWk.Fields("AKKNT_KAINO")                 ' 解除番号
                            intWKCount = intWKCount + 1  ' 登録用ワークテーブルデータ数カウントアップ
                        End If
    
                        objRsWk.MoveNext    ' ワークテーブル
    
                    ElseIf strWorkKey > strAkknKey Then
                        ' 自動鍵解除番号発番トランのデータがワークテーブルに存在しない場合
                        ' → 自動鍵解除番号発番トランのデータを削除
                        ' 配列に自動鍵解除番号発番トランのデータをセット
                        ReDim Preserve pvarAKKNDelData(1, intDelCount)
                        pvarAKKNDelData(0, intDelCount) = objRsAKKN.Fields("AKKNT_YARD")               ' ヤードコード
                        pvarAKKNDelData(1, intDelCount) = objRsAKKN.Fields("AKKNT_CTNO")               ' コンテナ番号
                        intDelCount = intDelCount + 1   ' 削除対象の自動鍵解除番号発番トランデータ数カウントアップ

                        objRsAKKN.MoveNext   ' 自動鍵解除番号発番トラン
                        strAkknKey2 = strAkknKey
                    End If
                End If
            Loop

            ' ワークテーブルのデータ作成
            If intWKCount > 0 Then
                For intCount = 0 To intWKCount - 1
                    ' 自動鍵解除番号発番トラン登録処理(登録)
                    If fncINSAKKN_TRAN(objRsAKKN, , pvarAKKNData(), intCount) = False Then Exit Function
                Next intCount
            End If

            ' 配列の解放
            Erase pvarAKKNData

            'ワークテーブルのデータ削除
            If intDelCount > 0 Then
                For intCount = 0 To intDelCount - 1
                    strSQL = ""
                    strSQL = strSQL & "SELECT      *" & Chr(13)
                    strSQL = strSQL & "FROM        AKKN_TRAN" & Chr(13)
                    strSQL = strSQL & "WHERE       AKKNT_YARD = " & pvarAKKNDelData(0, intCount) & Chr(13)
                    strSQL = strSQL & "AND         AKKNT_CTNO = " & pvarAKKNDelData(1, intCount) & Chr(13)
                    
                    strSQL = strSQL & "ORDER BY    AKKNT_YARD" & Chr(13)
                    strSQL = strSQL & ",           AKKNT_CTNO" & Chr(13)

                    'Set objRsDelAKKN = pobjKONT_DB.OpenRecordset(strSql, dbOpenDynaset)
                    Set objRsDelAKKN = ADODB_Recordset(strSQL, dbSQLServer, adoReadWrite) '2021/06/02 insert EGL
                    Do Until objRsDelAKKN.EOF
                        If fncDELAKKN_TRAN(objRsDelAKKN) = False Then Exit Function

                        objRsDelAKKN.MoveNext
                    Loop
                Next intCount
            End If

            '配列の開放
            Erase pvarAKKNDelData

        Case intModeDelete  ' *** 削除 ***
            ' 自動鍵解除番号発番トランのデータ全件削除
            With objRsAKKN
                Do Until .EOF
                    If fncDELAKKN_TRAN(objRsAKKN) = False Then Exit Function

                    .MoveNext
                Loop
            End With
    End Select

    WRI_AKKN_TRAN = True

Exit_WRI_AKKN_TRAN:
    If Not objRsWk Is Nothing Then objRsWk.Close: Set objRsWk = Nothing
    If Not objRsAKKN Is Nothing Then objRsAKKN.Close: Set objRsAKKN = Nothing
    If Not objRsDelAKKN Is Nothing Then objRsDelAKKN.Close: Set objRsDelAKKN = Nothing
    Exit Function

End Function

'==============================================================================*
'
'        MODULE_NAME      :DB更新処理(QRコード対応)
'        MODULE_ID        :WRI_AKKN_TRAN_QR
'        Parameter        :intMode intModeInsert = 新規
'                                  intModeUpdate = 修正
'                                  intModeDelete = 削除
'        CREATE_DATE      :2021/06/02
'        戻り値           :True,False
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function WRI_AKKN_TRAN_QR(ByVal intMode As Integer) As Boolean

    Dim strSQL          As String
    Dim StrYard         As Variant

    Dim intCount        As Integer      ' カウンター
    Dim objRsWk         As Recordset    ' ワークテーブルレコードセット
    Dim objRsAKKN       As Object       ' 自動鍵解除番号発番トランレコードセット
    Dim objRsDelAKKN    As Object       ' 自動鍵解除番号発番トラン削除データレコードセット

    Dim intWKCount      As Integer      ' ワークテーブルのデータ数
    Dim intDelCount     As Integer      ' 自動鍵解除番号発番トランの削除データ数
    Dim strWorkKey      As String       ' ワークテーブル.ヤードコード + ワークテーブル.コンテナ番号 + ワークテーブル.鍵区分
    Dim strAkknKey      As String       ' 自動鍵解除番号発番トラン.ヤードコード + 自動鍵解除番号発番トラン.コンテナ番号 + 自動鍵解除番号発番トラン.鍵区分
    Dim strAkknKey2     As String       ' 自動鍵解除番号発番トラン.ヤードコード + 自動鍵解除番号発番トラン.コンテナ番号 + 自動鍵解除番号発番トラン.鍵区分

    Dim dbSQLServer     As Object

    WRI_AKKN_TRAN_QR = False

    Erase pvarAKKNData: Erase pvarAKKNDelData
    
    ' 対象ヤードコード設定
    StrYard = Val(Nz(Me.cmb_ヤードコード, ""))

    If StrYard = "" Then Exit Function

    'SQLサーバー接続
    Set dbSQLServer = ADODB_Connection(pstrBumoCD)

    intWKCount = 0
    intDelCount = 0

    ' 修正モードまたは削除モードの場合、自動鍵解除番号発番トランの最新データ抽出
    If (intMode = intModeUpdate Or intMode = intModeDelete) Then
        ' 自動鍵解除番号発番トランから最新データ抽出
        strSQL = ""
        strSQL = strSQL & " SELECT      *" & Chr(13)
        strSQL = strSQL & " FROM        AKKN_TRAN" & Chr(13)
        strSQL = strSQL & " WHERE       AKKNT_YARD  = " & StrYard & Chr(13)
        strSQL = strSQL & " AND         AKKNT_STYPE = '6'" & Chr(13)            '★副種別を指定
        strSQL = strSQL & " ORDER BY    AKKNT_YARD" & Chr(13)
        strSQL = strSQL & " ,           AKKNT_CTNO" & Chr(13)
        strSQL = strSQL & " ,           AKKNT_KTYPE" & Chr(13)
        strSQL = strSQL & " ,           AKKNT_HATUD DESC" & Chr(13)
        'Set objRsAKKN = pobjKONT_DB.OpenRecordset(strSql, dbOpenDynaset)
        Set objRsAKKN = ADODB_Recordset(strSQL, dbSQLServer, adoAppendOnly)
    End If

    ' 削除モード時以外の場合、ワークテーブルのデータを抽出
    If intMode <> intModeDelete Then
        ' ワークテーブルのデータ抽出(上段・下段)
        strSQL = ""
        strSQL = strSQL & "SELECT      CNTA_CODE" & Chr(13)
        strSQL = strSQL & ",           CNTA_NO" & Chr(13)
        strSQL = strSQL & ",           CNTA_STEP" & Chr(13)
        strSQL = strSQL & ",           CNTA_KBN" & Chr(13)
        strSQL = strSQL & ",           CNTA_KEY_TYPE" & Chr(13)
        strSQL = strSQL & ",           CNTA_KEY_NO" & Chr(13)
        strSQL = strSQL & ",           CNTA_KAINO_QR" & Chr(13)                'QRコード★
        strSQL = strSQL & ",           CNTA_KEY_NUM" & Chr(13)
        strSQL = strSQL & ",           AKKNT_KAINO" & Chr(13)
        strSQL = strSQL & ",           AKKNT_KAINO_CHANGE" & Chr(13)
        strSQL = strSQL & "FROM        ヤード上ＷＫ" & Chr(13)
        strSQL = strSQL & "WHERE       CNTA_CODE = " & StrYard & Chr(13)        ' ヤードコード
        strSQL = strSQL & "AND         CNTA_STEP = " & pcintUpSide & Chr(13)    ' 段区分(0：上段)
        strSQL = strSQL & "AND         CNTA_NO  IS NOT NULL" & Chr(13)
        strSQL = strSQL & "AND         CNTA_SYU IS NOT NULL" & Chr(13)
        strSQL = strSQL & "AND         CNTA_KEY_TYPE = '16'"                    '★鍵区分を指定
        strSQL = strSQL & "UNION ALL" & Chr(13)
        strSQL = strSQL & "SELECT      CNTA_CODE" & Chr(13)
        strSQL = strSQL & ",           CNTA_NO" & Chr(13)
        strSQL = strSQL & ",           CNTA_STEP" & Chr(13)
        strSQL = strSQL & ",           CNTA_KBN" & Chr(13)
        strSQL = strSQL & ",           CNTA_KEY_TYPE" & Chr(13)
        strSQL = strSQL & ",           CNTA_KEY_NO" & Chr(13)
        strSQL = strSQL & ",           CNTA_KAINO_QR" & Chr(13)                'QRコード insert EGL 2021/06/02
        strSQL = strSQL & ",           CNTA_KEY_NUM" & Chr(13)
        strSQL = strSQL & ",           AKKNT_KAINO" & Chr(13)
        strSQL = strSQL & ",           AKKNT_KAINO_CHANGE" & Chr(13)
        strSQL = strSQL & "FROM        ヤード下ＷＫ" & Chr(13)
        strSQL = strSQL & "WHERE       CNTA_CODE = " & StrYard & Chr(13)        ' ヤードコード
        strSQL = strSQL & "AND         CNTA_STEP = " & pcintDownSide & Chr(13)  ' 段区分(1：下段)
        strSQL = strSQL & "AND         CNTA_NO  IS NOT NULL" & Chr(13)
        strSQL = strSQL & "AND         CNTA_SYU IS NOT NULL" & Chr(13)
        strSQL = strSQL & "ORDER BY    1, 2" & Chr(13)
        
        Set objRsWk = WRI_objDb.OpenRecordset(strSQL, dbReadOnly)
    End If

    Select Case intMode
        Case intModeInsert  ' *** 新規 ***
            ' 自動鍵解除番号発番トランよりデータ抽出
            strSQL = ""
            strSQL = "SELECT * FROM AKKN_TRAN "
            Set objRsAKKN = pobjKONT_DB.OpenRecordset(strSQL, dbOpenDynaset)

            With objRsWk
                ' ワークのデータ登録
                Do Until .EOF
                    If Nz(.Fields("CNTA_KAINO_QR")) <> "" Then
                        ' 自動鍵解除番号発番トラン登録処理(登録)
                        If fncINSAKKN_TRAN_QR(objRsAKKN, objRsWk) = False Then Exit Function
                    End If
                    .MoveNext
                Loop
            End With

        Case intModeUpdate  ' *** 修正 ***
            strAkknKey2 = ""

            Do Until (objRsWk.EOF And objRsAKKN.EOF)
                ' ワークテーブルのキー作成
                If objRsWk.EOF = True Then
                    strWorkKey = pcstrKeyCode
                Else
                    strWorkKey = Format(objRsWk.Fields("CNTA_CODE"), "000000") _
                               & Format(objRsWk.Fields("CNTA_NO"), "000000")
                End If

                ' 自動鍵解除番号発番トランのキー作成
                If objRsAKKN.EOF = True Then
                    strAkknKey = pcstrKeyCode
                Else
                    strAkknKey = Format(objRsAKKN.Fields("AKKNT_YARD"), "000000") _
                               & Format(objRsAKKN.Fields("AKKNT_CTNO"), "000000")
                End If

                If strAkknKey <> pcstrKeyCode & "99" And strAkknKey = strAkknKey2 Then
                    ' 自動鍵解除番号発番トランのキーが同一の場合はブレイクするまで読み飛ばす
                    ' 但し、自動鍵解除番号発番トランのデータがワークテーブルに存在しない場合は自動鍵解除番号発番トランのデータを削除
                    objRsAKKN.MoveNext
                Else
                    ' ワークテーブルと自動鍵解除番号発番トランのデータ比較
                    If strWorkKey = strAkknKey Then
                        ' ワークテーブルのデータと自動鍵解除番号発番トランのデータが一致する場合
                        If Nz(objRsWk.Fields("CNTA_KAINO_QR")) <> "" And _
                           Nz(objRsWk.Fields("CNTA_KAINO_QR")) <> Nz(objRsAKKN.Fields("AKKNT_KAINO")) Then
                            'ワークテーブル.解除番号が入力されていて、自動鍵解除番号発番トラン.解除番号と異なる場合
                            ' 自動鍵解除番号発番トラン登録処理(登録)
                            ' 配列にワークテーブルのデータをセット
                            ReDim Preserve pvarAKKNData(4, intWKCount)
                            pvarAKKNData(0, intWKCount) = objRsWk.Fields("CNTA_CODE")                   ' ヤードコード
                            pvarAKKNData(1, intWKCount) = objRsWk.Fields("CNTA_NO")                     ' コンテナ番号
                            pvarAKKNData(2, intWKCount) = objRsWk.Fields("CNTA_STEP")                   ' 段区分
                            pvarAKKNData(3, intWKCount) = Nz(objRsWk.Fields("CNTA_KEY_TYPE"), "")       ' 鍵区分
                            pvarAKKNData(4, intWKCount) = objRsWk.Fields("CNTA_KAINO_QR")              ' 解除番号
                            intWKCount = intWKCount + 1  ' 登録用ワークテーブルデータ数カウントアップ
                        End If
    
                        ' → 次レコードの処理を行う
                        objRsWk.MoveNext    ' ワークテーブル
                        objRsAKKN.MoveNext  ' 自動鍵解除番号発番トラン
                        strAkknKey2 = strAkknKey
    
                    ElseIf strWorkKey < strAkknKey Then
                        ' ワークテーブルのデータが自動鍵解除番号発番トランに存在しない場合
                        ' → ワークテーブルのデータを自動鍵解除番号発番トランに登録
                        If Nz(objRsWk.Fields("CNTA_KAINO_QR")) <> "" Then
                            ' 配列にワークテーブルのデータをセット
                            ReDim Preserve pvarAKKNData(4, intWKCount)
                            pvarAKKNData(0, intWKCount) = objRsWk.Fields("CNTA_CODE")                   ' ヤードコード
                            pvarAKKNData(1, intWKCount) = objRsWk.Fields("CNTA_NO")                     ' コンテナ番号
                            pvarAKKNData(2, intWKCount) = objRsWk.Fields("CNTA_STEP")                   ' 段区分
                            pvarAKKNData(3, intWKCount) = Nz(objRsWk.Fields("CNTA_KEY_TYPE"), "")       ' 鍵区分
                            pvarAKKNData(4, intWKCount) = objRsWk.Fields("CNTA_KAINO_QR")              ' 解除番号
                            intWKCount = intWKCount + 1  ' 登録用ワークテーブルデータ数カウントアップ
                        End If
    
                        objRsWk.MoveNext    ' ワークテーブル
    
                    ElseIf strWorkKey > strAkknKey Then
                        ' 自動鍵解除番号発番トランのデータがワークテーブルに存在しない場合
                        ' → 自動鍵解除番号発番トランのデータを削除
                        ' 配列に自動鍵解除番号発番トランのデータをセット
                        ReDim Preserve pvarAKKNDelData(1, intDelCount)
                        pvarAKKNDelData(0, intDelCount) = objRsAKKN.Fields("AKKNT_YARD")               ' ヤードコード
                        pvarAKKNDelData(1, intDelCount) = objRsAKKN.Fields("AKKNT_CTNO")               ' コンテナ番号
                        intDelCount = intDelCount + 1   ' 削除対象の自動鍵解除番号発番トランデータ数カウントアップ

                        objRsAKKN.MoveNext   ' 自動鍵解除番号発番トラン
                        strAkknKey2 = strAkknKey
                    End If
                End If
            Loop

            ' ワークテーブルのデータ作成
            If intWKCount > 0 Then
                For intCount = 0 To intWKCount - 1
                    ' 自動鍵解除番号発番トラン登録処理(登録)
                    If fncINSAKKN_TRAN_QR(objRsAKKN, , pvarAKKNData(), intCount) = False Then Exit Function
                Next intCount
            End If

            ' 配列の解放
            Erase pvarAKKNData

            'ワークテーブルのデータ削除
            If intDelCount > 0 Then
                For intCount = 0 To intDelCount - 1
                    strSQL = ""
                    strSQL = strSQL & "SELECT      *" & Chr(13)
                    strSQL = strSQL & "FROM        AKKN_TRAN" & Chr(13)
                    strSQL = strSQL & "WHERE       AKKNT_YARD = " & pvarAKKNDelData(0, intCount) & Chr(13)
                    strSQL = strSQL & "AND         AKKNT_CTNO = " & pvarAKKNDelData(1, intCount) & Chr(13)
                    strSQL = strSQL & "ORDER BY    AKKNT_YARD" & Chr(13)
                    strSQL = strSQL & ",           AKKNT_CTNO" & Chr(13)
                    'Set objRsDelAKKN = pobjKONT_DB.OpenRecordset(strSql, dbOpenDynaset)
                    Set objRsDelAKKN = ADODB_Recordset(strSQL, dbSQLServer, adoReadWrite)
                    Do Until objRsDelAKKN.EOF
                        If fncDELAKKN_TRAN(objRsDelAKKN) = False Then Exit Function

                        objRsDelAKKN.MoveNext
                    Loop
                Next intCount
            End If

            '配列の開放
            Erase pvarAKKNDelData

        Case intModeDelete  ' *** 削除 ***
            ' 自動鍵解除番号発番トランのデータ全件削除
            With objRsAKKN
                Do Until .EOF
                    If fncDELAKKN_TRAN(objRsAKKN) = False Then Exit Function '4桁と同じ
                    .MoveNext
                Loop
            End With
    End Select

    WRI_AKKN_TRAN_QR = True

Exit_WRI_AKKN_TRAN:
    If Not objRsWk Is Nothing Then objRsWk.Close: Set objRsWk = Nothing
    If Not objRsAKKN Is Nothing Then objRsAKKN.Close: Set objRsAKKN = Nothing
    If Not objRsDelAKKN Is Nothing Then objRsDelAKKN.Close: Set objRsDelAKKN = Nothing
    Exit Function

End Function

'==============================================================================*
'
'        MODULE_NAME      :自動鍵解除番号発番トラン登録処理
'        MODULE_ID        :fncINSAKKN_TRAN
'        Parameter        :objRsAKKN    = 自動鍵解除番号発番トランレコードセット
'                          objRsWK      = ワークテーブルレコードセット
'                          varAKKNDATA  = ワークテーブルデータ格納配列
'                          intDataPlace = 配列のカレントデータ位置
'        CREATE_DATE      :2014/03/07
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
'update 2021/06/02 Private Function fncINSAKKN_TRAN(ByRef objRsAKKN As Recordset, _
                                 Optional ByRef objRsWk As Recordset = Nothing, _
                                 Optional ByRef varAKKNDATA As Variant = Null, _
                                 Optional intDataPlace As Integer = 0) As Boolean
Private Function fncINSAKKN_TRAN(ByRef objRsAKKN As Object, _
                                 Optional ByRef objRsWk As Recordset = Nothing, _
                                 Optional ByRef varAKKNDATA As Variant = Null, _
                                 Optional intDataPlace As Integer = 0) As Boolean

    fncINSAKKN_TRAN = False

    ' 自動鍵解除番号発番トランにデータ登録
    With objRsAKKN
        .AddNew

        If Not objRsWk Is Nothing Then
            .Fields("AKKNT_YARD") = objRsWk.Fields("CNTA_CODE")                                 ' ヤードコード
            .Fields("AKKNT_CTNO") = objRsWk.Fields("CNTA_NO")                                   ' コンテナ番号
            .Fields("AKKNT_KTYPE") = objRsWk.Fields("CNTA_KEY_TYPE")                            ' 鍵区分
            .Fields("AKKNT_HATUD") = Format$(DATE, "YYYYMMDD") & Format$(time, "HHMMSS")        ' 解除番号発番日時
            .Fields("AKKNT_KAINO") = Nz(objRsWk.Fields("AKKNT_KAINO"))                          ' 解除番号
            .Fields("AKKNT_STYPE") = "4"                                                        ' 副種別 insert EGL 2021/06/02
            .Fields("AKKNT_INSED") = Format$(DATE, "YYYYMMDD")                                  ' 作成日付
            .Fields("AKKNT_INSEJ") = Format$(time, "HHMMSS")                                    ' 作成時刻
            .Fields("AKKNT_INSPB") = PROG_ID                                                    ' 作成プログラムID
            .Fields("AKKNT_INSUB") = LsGetUserName()                                            ' 作成ユーザーID
        Else
