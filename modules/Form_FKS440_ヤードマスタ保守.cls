            .Fields("CNTA_WIDTH") = objRsWk.Fields("CNTA_WIDTH")                              ' 幅
            .Fields("CNTA_HEIGHT") = objRsWk.Fields("CNTA_HEIGHT")                            ' 高さ
            .Fields("CNTA_AGRE") = 0                                                          ' 契約状態
            .Fields("CNTA_USAGE") = Nz(objRsWk.Fields("CNTA_USAGE"), 0)                       ' 使用用途
            .Fields("CNTA_USE") = objRsWk.Fields("CNTA_USE")                                  ' 利用可否
            .Fields("CNTA_YCODE") = objRsWk.Fields("CNTA_YCODE")                              ' 予約客先ｺｰﾄﾞ
            .Fields("CNTA_YNAME") = objRsWk.Fields("CNTA_YNAME")                              ' 予約客先名
            .Fields("CNTA_YTEL") = objRsWk.Fields("CNTA_YTEL")                                ' 予約客先電話番号
            .Fields("CNTA_DEPOSIT") = objRsWk.Fields("CNTA_DEPOSIT")                          ' 予約金
            .Fields("CNTA_YRENTKG") = Nz(objRsWk.Fields("CNTA_YRENTKG"), 0)                   ' 予約賃料
