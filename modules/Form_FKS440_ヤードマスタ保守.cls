'        strSQL = strSQL & "        CNTA_ZAPPI_CODE2, " & Chr(13)   ' 2005/11/21 DEL S.SHIBAZAKI
'        strSQL = strSQL & "        CNTA_ZAPPI_2, " & Chr(13)       ' 2005/11/21 DEL S.SHIBAZAKI
        strSQL = strSQL & "        CNTA_DEPTH, " & Chr(13)
        strSQL = strSQL & "        CNTA_WIDTH, " & Chr(13)
        strSQL = strSQL & "        CNTA_HEIGHT, " & Chr(13)
        strSQL = strSQL & "        CNTA_USAGE, " & Chr(13)
        strSQL = strSQL & "        CNTA_USE, " & Chr(13)
        strSQL = strSQL & "        CNTA_YCODE, " & Chr(13)
        strSQL = strSQL & "        CNTA_YNAME, " & Chr(13)
        strSQL = strSQL & "        CNTA_YTEL, " & Chr(13)
        strSQL = strSQL & "        CNTA_DEPOSIT, " & Chr(13)
        strSQL = strSQL & "        CNTA_YRENTKG, " & Chr(13)
'        strSQL = strSQL & "        CNTA_SECUKG, " & Chr(13)         ' 2005/11/21 DEL T.SUZUKI
        strSQL = strSQL & "        CNTA_SCODE, " & Chr(13)
        strSQL = strSQL & "        CNTA_UPDATE, " & Chr(13)
        strSQL = strSQL & "        CNTA_PRICE_DIFF, " & Chr(13)          ' 料金差額  ' 2005/11/21 ADD T.SUZUKI
        strSQL = strSQL & "        CNTA_REASON " & Chr(13)               ' 差額理由  ' 2005/11/21 ADD T.SUZUKI
        
        '2006/06/09 SHIBAZAKI 鍵情報追加
        strSQL = strSQL & "," & fncMakeKeySqlSelect(False)
