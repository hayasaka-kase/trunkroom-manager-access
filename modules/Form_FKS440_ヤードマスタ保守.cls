        strSQL = strSQL & ",       IIf(Nz(CNTA_BIKE_OK, 0) = 0, 0, 1) AS BIKE_OK "     'INSERT 2011/03/05 SHIBAZAKI
        strSQL = strSQL & ",       AKKNT_KAINO " & Chr(13)                 ' 解除番号             'INSERT 2014/03/07 MIYAMOTO
        strSQL = strSQL & ",       AKKNT_KAINO_CHANGE " & Chr(13)          ' 解除番号変更チェック 'INSERT 2014/03/07 MIYAMOTO
        strSQL = strSQL & ",       CNTA_KAINO_QR " & Chr(13)              ' 解除番号変更チェック(6桁) 'INSERT 2021/06/02 EGL
