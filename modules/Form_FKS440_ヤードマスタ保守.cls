Private Sub cmd_カードメンテ_Click()

    Dim strYardCode As String
    
    If Nz(Me.cmb_ヤードコード, "") = "" Then
         MsgBox "ヤードコードを入力してください。", vbInformation, strMsg_kaku
         GoTo Exit_rtn
