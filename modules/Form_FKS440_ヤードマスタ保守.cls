'==============================================================================*
'
'        MODULE_NAME      :Check駅
'        機能             :路線コンボにより駅コンボをチェックする、
'        IN               :Nothing
'        OUT              :Nothing
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub Check駅()

    '路線1が空白の場合は、txt路線コード1と、cmb_駅1は空白とする
    If Nz(Me.cmb_路線1, "") = "" Then
        Me.txt_路線コード1 = ""
        Me.cmb_駅1 = ""
    Else
        Me.txt_路線コード1 = Me.cmb_路線1.Column(1)
    End If
    Me.cmb_駅1.Requery
        
    '路線2が空白の場合は、txt路線コード2と、cmb_駅2は空白とする
    If Nz(Me.cmb_路線2, "") = "" Then
        Me.txt_路線コード2 = ""
        Me.cmb_駅2 = ""
    Else
        Me.txt_路線コード2 = Me.cmb_路線2.Column(1)
    End If
    Me.cmb_駅2.Requery
        
    '路線3が空白の場合は、txt路線コード3と、cmb_駅3は空白とする
    If Nz(Me.cmb_路線3, "") = "" Then
        Me.txt_路線コード3 = ""
        Me.cmb_駅3 = ""
    Else
        Me.txt_路線コード3 = Me.cmb_路線3.Column(1)
    End If
    Me.cmb_駅3.Requery

End Sub
