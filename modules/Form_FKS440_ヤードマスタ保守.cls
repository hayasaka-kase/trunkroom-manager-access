'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function GetData_Yard_Excel(xlBook As Object) As Boolean

    Dim objCon              As Object
    Dim objRst              As Object
    Dim xlSheet             As Object
    
    Dim lngRow1             As Long
    Dim lngCol1             As Long
    Dim lngRow2             As Long
    Dim lngCol2             As Long
    Dim lngRow3             As Long
    Dim lngCol3             As Long
    Dim lngRow4             As Long
    Dim lngCol4             As Long
    Dim lngCnt1             As Long
    Dim lngCnt2             As Long
    Dim lngCnt3             As Long
    Const C_COL_CNT1        As Long = 8
    Const C_COL_CNT2        As Long = 6
    Const C_COL_CNT3        As Long = 5
    On Error GoTo ErrorHandler

    'ヤードマスタよりデータの取得
    Set objCon = ADODB_Connection()
    On Error GoTo ErrorHandler1
    
    ' コンテナDB接続
    If fncConnectDB(pcintKONT_DB) = False Then Exit Function

    Set objRst = pobjKONT_DB.OpenRecordset(Select_YARD_MAST(), dbOpenDynaset, dbSQLPassThrough, dbReadOnly)
    
    If Not objRst.EOF Then

        'エクセルファイルにセット
        With xlBook.ActiveSheet
        
            .Range("B3").VALUE = objRst.Fields("YARD_KANOUSYA").VALUE
            .Range("B5").VALUE = objRst.Fields("YARD_ZENMEN").VALUE
            .Range("D3").VALUE = objRst.Fields("YARD_RIYOUJIKAN").VALUE
            .Range("B8").VALUE = objRst.Fields("YARD_SYOUMEI").VALUE
            
            .Range("C8").VALUE = objRst.Fields("YARD_DAISYA1").VALUE
            .Range("C9").VALUE = objRst.Fields("YARD_DAISYA2").VALUE
            .Range("C10").VALUE = objRst.Fields("YARD_DAISYA3").VALUE
            .Range("C11").VALUE = objRst.Fields("YARD_DAISYA4").VALUE
            
            'UPDATE 2018/08/16 N.IMAI Start
            If objRst.Fields("YARD_DAISYA1").VALUE <> "" Then
                If objRst.Fields("YARD_D_DAN1") <> "" Then
                    .Range("D8").VALUE = objRst.Fields("YARD_D_DAN1").VALUE & "段"
                End If
                If objRst.Fields("YARD_D_TESURI1").VALUE <> "" Then
                    If objRst.Fields("YARD_D_TESURI1").VALUE = 1 Then
                        .Range("E8").VALUE = "有"
                    ElseIf objRst.Fields("YARD_D_TESURI1").VALUE = 0 Then
                        .Range("E8").VALUE = "無"
                    End If
                End If
            End If
            
            If objRst.Fields("YARD_DAISYA2").VALUE <> "" Then
                If objRst.Fields("YARD_D_DAN2") <> "" Then
                    .Range("D9").VALUE = objRst.Fields("YARD_D_DAN2").VALUE & "段"
                End If
                If objRst.Fields("YARD_D_TESURI2").VALUE <> "" Then
                    If objRst.Fields("YARD_D_TESURI2").VALUE = 1 Then
                        .Range("E9").VALUE = "有"
                    ElseIf objRst.Fields("YARD_D_TESURI2").VALUE = 0 Then
                        .Range("E9").VALUE = "無"
                    End If
                End If
            End If
            
            If objRst.Fields("YARD_DAISYA3").VALUE <> "" Then
                If objRst.Fields("YARD_D_DAN3") <> "" Then
                    .Range("D10").VALUE = objRst.Fields("YARD_D_DAN3").VALUE & "段"
                End If
                If objRst.Fields("YARD_D_TESURI3").VALUE <> "" Then
                    If objRst.Fields("YARD_D_TESURI3").VALUE = 1 Then
                        .Range("E10").VALUE = "有"
                    ElseIf objRst.Fields("YARD_D_TESURI3").VALUE = 0 Then
                        .Range("E10").VALUE = "無"
                    End If
                End If
            End If
            
            If objRst.Fields("YARD_DAISYA4").VALUE <> "" Then
                If objRst.Fields("YARD_D_DAN4") <> "" Then
                    .Range("D11").VALUE = objRst.Fields("YARD_D_DAN4").VALUE & "段"
                End If
                If objRst.Fields("YARD_D_TESURI4").VALUE <> "" Then
                    If objRst.Fields("YARD_D_TESURI4").VALUE = 1 Then
                        .Range("E11").VALUE = "有"
                    ElseIf objRst.Fields("YARD_D_TESURI4").VALUE = 0 Then
                        .Range("E11").VALUE = "無"
                    End If
                End If
            End If
            'UPDATE 2018/08/16 N.IMAI End
            
            .Range("B14").VALUE = objRst.Fields("YARD_MOYORI_EKI1").VALUE
            .Range("B15").VALUE = objRst.Fields("YARD_MOYORI_EKI2").VALUE
            .Range("B16").VALUE = objRst.Fields("YARD_MOYORI_EKI3").VALUE
            
            .Range("C14").VALUE = objRst.Fields("YARD_MOYORI_BUS1").VALUE
            .Range("C15").VALUE = objRst.Fields("YARD_MOYORI_BUS2").VALUE
            .Range("C16").VALUE = objRst.Fields("YARD_MOYORI_BUS3").VALUE
            
            .Range("D14").VALUE = objRst.Fields("YARD_HOSOU").VALUE
            
            If objRst.Fields("YARD_TOKKI1").VALUE <> "" Then
                .Range("B19").VALUE = "・" & objRst.Fields("YARD_TOKKI1").VALUE
            Else
                .Range("B19").VALUE = ""
            End If
            If objRst.Fields("YARD_TOKKI2").VALUE <> "" Then
                .Range("B20").VALUE = "・" & objRst.Fields("YARD_TOKKI2").VALUE
            Else
                .Range("B20").VALUE = ""
            End If
            If objRst.Fields("YARD_TOKKI3").VALUE <> "" Then
                .Range("B21").VALUE = "・" & objRst.Fields("YARD_TOKKI3").VALUE
            Else
                .Range("B21").VALUE = ""
            End If
            If objRst.Fields("YARD_TOKKI4").VALUE <> "" Then
                .Range("B22").VALUE = "・" & objRst.Fields("YARD_TOKKI4").VALUE
            Else
                .Range("B22").VALUE = ""
            End If
        
        End With
        
        
        GetData_Yard_Excel = True
    Else
        GetData_Yard_Excel = False
    End If
    
    objRst.Close
    On Error GoTo ErrorHandler1
    objCon.Close
    On Error GoTo ErrorHandler
Exit Function

ErrorHandler1:
    objRst.Close
    objCon.Close
ErrorHandler:                   '↓自分の関数名
    Call Err.Raise(Err.Number, "GetData_Yard_Excel" & vbRightAllow & Err.Source, Err.Description, Err.HelpFile, Err.HelpContext)
End Function

