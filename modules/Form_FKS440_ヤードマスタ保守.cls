'        MODULE_NAME      :カードマスタ削除処理
'        MODULE_ID        :deleteSCRD_MAST
'        Parameter        :ヤードコード
'        CREATE_DATE      :2006/06/07
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub deleteSCRD_MAST(ByVal strYcode As String)

    Dim sqlText As String
    Dim rsObject  As Recordset
    Dim isException As Boolean

  On Error GoTo Exception
  
    isException = False
    
    sqlText = "SELECT * FROM SCRD_MAST WHERE SCRDM_YCODE = " & strYcode
    Set rsObject = pobjKONT_DB.OpenRecordset(sqlText, dbOpenDynaset)

    Do Until rsObject.EOF
        rsObject.Edit
        rsObject.Delete
        rsObject.MoveNext
    Loop
    GoTo Finally

Exception:
    isException = True

Finally:
    If Not rsObject Is Nothing Then rsObject.Close: Set rsObject = Nothing
    If isException = True Then
        Call Err.Raise(Err.Number, "deleteSCRD_MAST" & vbRightAllow & Err.Source, Err.Description, Err.HelpFile, Err.HelpContext)
    End If

End Sub

'2006/06/09 SHIBAZAKI 鍵情報追加
'==============================================================================*
'
'        MODULE_NAME      :fncChkComboInput
'        機能             :コンボボックス入力チェック
'        IN               :第一引数：対象コンボボックス
'                         :第二引数：入力可能最大桁数
'                         :第三引数：更新後処理のキャンセル
'        OUT              :True=正常
'                          False=入力値がリストに存在しない
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Public Function fncChkComboInput(cmbCheck As ComboBox, intMaxLength As Integer, ByRef Cancel As Integer) As Boolean

    Dim strCode     As String
    Dim intRet      As Integer
    Dim intCount    As Integer
    Dim strValue    As String
    Dim blnFound    As Boolean
    
    intRet = 0
    
    strCode = Nz(cmbCheck, "")
    
    fncChkComboInput = True
    
    '空白なら入力チェックしない
    If strCode = "" Then
        GoTo ChkComboInput_End
    End If
    
    '入力値がリストに存在しているかチェック
    If cmbCheck.ListCount <> 0 Then
        blnFound = False
        '入力値を０サプレス
        strValue = Format(cmbCheck, Mid("0000000000", 1, intMaxLength))
        'コンボボックス内にコードが存在してる？
        For intCount = 0 To cmbCheck.ListCount - 1
            'コード値比較
            If cmbCheck.Column(0, intCount) = strValue Then
                blnFound = True
                Exit For
            End If
        Next
        
        If Not blnFound Then
            MsgBox "該当するコードがありません。", vbInformation, strMsg_kaku
            SendKeys "{ESC}"
            fncChkComboInput = False
            GoTo ChkComboInput_End
        End If
    End If
    
ChkComboInput_End:
    If Not fncChkComboInput Then
        Cancel = True
    End If

End Function

