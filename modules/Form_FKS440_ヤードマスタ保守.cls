'==============================================================================*
'
'        MODULE_NAME      :txt_ヤード名_BeforeUpdateイベント
'        MODULE_ID        :txt_ヤード名_BeforeUpdate
'        CREATE_DATE      :
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub txt_ヤード名_BeforeUpdate(Cancel As Integer)

    Dim vCode       As Variant

    On Error GoTo err_rtn
      
    If blnFormLoadFlg = False Then Exit Sub

    vCode = Nz(Me.txt_ヤード名, "")

    '何も入力されていない時は、処理をしない
    If vCode = "" Then
        Exit Sub
    End If

    '入力チェック
    Select Case CmBCheck_Char(vCode, 36)
        Case 0
    
        Case 2
            '桁数ｴﾗｰ
            MsgBox "桁数オーバーしています。", vbInformation, strMsg_err
            Cancel = True
            GoTo Exit_rtn
        Case 9
    End Select

Exit_rtn:
    Exit Sub

err_rtn:
    MsgBox "ｴﾗｰ番号" & Err.Number & vbCrLf & Err.Description
    Err.Clear
    GoTo Exit_rtn
End Sub

