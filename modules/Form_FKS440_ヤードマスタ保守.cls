'==============================================================================*
'
'        MODULE_NAME      :cmdNebikiOnOff
'        機能             :価格表からの割引対象外チェックイベントにより
'                         :コンテナに値を反映させる
'        IN               :ヤードﾞコード
'                         :段区分
'                         :使用用途
'                         :実帖
'                         :割引対象外
'        CREATE_DATE      :2008/10/15
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Public Sub setNebikiOnOff(YCODE As Long, STEP As Integer, USAGE As Integer, SIZE As Double, ChkFlg As Boolean)
On Error GoTo err_rtn
    
    Dim objDb                           As Database
    Dim strSQL As String

    'ワークテーブルの更新
    Set objDb = CurrentDb
    objDb.Execute "UPDATE " & IIf(STEP = 0, "ヤード上ＷＫ", "ヤード下ＷＫ") & _
                  " SET CNTA_NEBIKI_DISABLE =  " & ChkFlg & _
                  " WHERE CNTA_CODE = " & YCODE & _
                  "   AND CNTA_STEP = " & STEP & _
                  "   AND CNTA_USAGE = " & USAGE & _
                  "   AND CNTA_SIZE = " & SIZE _
                  , dbFailOnError

    If STEP = 0 Then
        Me.FKS440_ヤードマスタサブ上.Requery
    Else
        Me.FKS440_ヤードマスタサブ下.Requery
    End If

Exit_rtn:
    If Not objDb Is Nothing Then objDb.Close: Set objDb = Nothing
    Exit Sub

err_rtn:
    Call Err.Raise(Err.Number, "setNebikiOnOff" & vbRightAllow & Err.Source, Err.Description, Err.HelpFile, Err.HelpContext)
    Resume Exit_rtn
End Sub
' 2008/10/15 ADD iizuka End

