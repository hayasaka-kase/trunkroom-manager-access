'
'        MODULE_NAME      :
'        MODULE_ID        :txt_定率_BeforeUpdate
'        CREATE_DATE      :
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub txt_定率_BeforeUpdate(Cancel As Integer)

    Dim vNum As Variant

    On Error GoTo err_rtn

    vNum = Nz(Me.txt_定率, "")

    If vNum = "" Then Exit Sub
  
    Select Case CHK_Numeric(vNum, 5)
        Case 0

        Case 1
            MsgBox "定率値は、数値で、入力してください。", vbInformation, strMsg_kaku
            Cancel = True
            SendKeys "{ESC}"  '入力のキャンセル処理
            Exit Sub

        Case 2
            MsgBox "定率値は、3桁以内で、入力してください。", vbInformation, strMsg_kaku
            Cancel = True
            SendKeys "{ESC}"  '入力のキャンセル処理
            Exit Sub

        Case Else
            Cancel = True
            SendKeys "{ESC}"
            Exit Sub
    End Select

    If vNum > 999.9 Then
        MsgBox "定率値は、正しく入力してください。", vbInformation, strMsg_kaku
        Cancel = True
        SendKeys "{ESC}"  '入力のキャンセル処理
        Exit Sub
    End If

Exit_rtn:
    Exit Sub

err_rtn:
    MsgBox "ｴﾗｰ番号" & Err.Number & vbCrLf & Err.Description
    Err.Clear
    GoTo Exit_rtn
End Sub

