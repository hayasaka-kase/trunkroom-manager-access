    If (intMode = intModeUpdate Or intMode = intModeDelete) Then
        ' コンテナマスタからデータ抽出
        ' *** 上段・下段 ***
        strSQL = ""
        strSQL = "SELECT * " & Chr(13)
        strSQL = strSQL & "  FROM CNTA_MAST " & Chr(13)
        strSQL = strSQL & " WHERE (CNTA_STEP = " & pcintUpSide & Chr(13)           ' 段区分(0：上段)
        strSQL = strSQL & "    OR  CNTA_STEP = " & pcintDownSide & ") " & Chr(13)  ' 段区分(1：下段)
        strSQL = strSQL & "   AND CNTA_CODE = " & vCode & Chr(13)                  ' ヤードコード
        strSQL = strSQL & " ORDER BY CNTA_CODE, " & Chr(13)  ' ヤードコード
        strSQL = strSQL & "          CNTA_STEP, " & Chr(13)  ' 段区分
