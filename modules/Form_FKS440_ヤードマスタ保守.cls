'2006/05/25 SHIBAZAKI 営業日タブ追加
'==============================================================================*
'
'        MODULE_NAME      :txt_営業開始日_BeforeUpdate イベント
'        MODULE_ID        :txt_営業開始日_BeforeUpdate
'        CREATE_DATE      :2006/05/25
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub txt_営業開始日_BeforeUpdate(Cancel As Integer)
    Dim errorMsg As String
    
    If fncDateCheck(txt_営業開始日, Cancel) = True Then
        If Nz(VarChangeDate, "") <> "" And Nz(txt_営業終了日, "") <> "" Then
            If CDate(VarChangeDate) > CDate(txt_営業終了日) Then
'del 2006/09/06 tajima                If Nz(txt_EndCalMm, "0") = "0" Then
                    errorMsg = "営業開始日は営業終了日より以前として下さい。"
'del 2006/09/06 tajima                Else
'del 2006/09/06 tajima                    errorMsg = "営業開始日は営業終了日(ヤード解約予定日の" & txt_EndCalMm & "ヶ月前）より以前として下さい。"
'del 2006/09/06 tajima                End If
            
                MsgBox errorMsg, vbInformation, strMsg_err
                Cancel = True
                SendKeys "{ESC}"
            End If
        End If
        
        '' 20110203 M.HONDA START
        If Me.chk_ネット予約可否.VALUE = True And Nz(VarChangeDate, "") <> "" Then
'            If CDate(Me.txt_営業開始日.VALUE) > Now Then 2012/08/10 tajima
            If CDate(VarChangeDate) > Now Then
                Me.lbl_先行予約.ForeColor = 255
                Me.lbl_先行予約.Caption = "『先行予約』"
            Else
                Me.lbl_先行予約.ForeColor = 0
                Me.lbl_先行予約.Caption = ""
            End If
        End If
        '' 20110203 M.HONDA END
    
    End If

End Sub

