'==============================================================================*
'
'        MODULE_NAME      : cmdREGET_Clickイベント
'        MODULE_ID        : cmdREGET_Click
'        CREATE_DATE      : 2006/03/27
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub cmdREGET_Click()
    Dim strSQL              As String
    Dim dbSQLServer         As Object       'ADODB.Connection
    Dim rsSqlServer         As Object       'ADODB.Recordset
    Dim rsWork              As Recordset
    Dim strBUMOC            As String
    Dim dblKiro             As Double
    On Error GoTo ErrorHandler

    '自分の緯度経度が入力されていること
    If (Nz(Me.txt_YARD_ZAHYOKEI, "") = "") Or _
        (Nz(Me.txt_YARD_IDO, "") = "") Or _
        (Nz(Me.txt_YARD_KEIDO, "") = "") Then
        MsgBox "経緯度が設定不足です。"
        Exit Sub
    End If
    
    'コントロールマスタの取得
    strBUMOC = ""
    dblKiro = 0
    strSQL = strSQL & "SELECT "
    strSQL = strSQL & " CONT_BUMOC,"
    strSQL = strSQL & " CONT_MAX_KIRO "
    strSQL = strSQL & "FROM dbo_CONT_MAST "
    strSQL = strSQL & "WHERE CONT_KEY = 1 "
    Set rsWork = CurrentDb().OpenRecordset(strSQL, dbOpenSnapshot)
    On Error GoTo ErrorHandler1
    With rsWork
        If Not .EOF Then
            strBUMOC = Trim(Nz(.Fields("CONT_BUMOC")))
            dblKiro = CDbl(Nz(.Fields("CONT_MAX_KIRO"), 0))
        End If
        .Close
    End With
    On Error GoTo ErrorHandler
    If (strBUMOC = "") Or (dblKiro = 0) Then
        MsgBox "コントロールマスタの設定不足です。"
        Exit Sub
    End If
    
    'SQL-Server接続
    Set dbSQLServer = CreateObject("ADODB.Connection")
    dbSQLServer.CommandTimeout = 180
    Call dbSQLServer.Open(MSZZ007_M10(strBUMOC))
    On Error GoTo ErrorHandler1
    'SQL-Serverの一時テーブル作成
    If MNN020.GetNearPoint(dbSQLServer, Me.cmb_ヤードコード.VALUE, CDbl(Me.txt_YARD_IDO), CDbl(Me.txt_YARD_KEIDO), dblKiro) <= 0 Then
        dbSQLServer.Close
        Exit Sub
    End If
    'SQL-Serverの一時テーブルからアクセス側に反映
    Set rsWork = CurrentDb.OpenRecordset(fncSelectWork("FKS440_W01", "NYAR_NCODE"))
    On Error GoTo ErrorHandler2
    Set rsSqlServer = CreateObject("ADODB.Recordset")
    With rsSqlServer
        .Open fncSelectWork(MNN020.WK_TABLE_NAME, "YARD_CODE"), dbSQLServer, adOpenForwardOnly, adLockReadOnly
        On Error GoTo ErrorHandler3
        While (Not .EOF) Or (Not rsWork.EOF)
            If rsWork.EOF Then
                If .Fields("YARD_CODE") <> CLng(Me.cmb_ヤードコード.VALUE) Then
                    rsWork.AddNew
                    Call subAddnewWork(rsWork, rsSqlServer)
                End If
                .MoveNext
            ElseIf .EOF Then
                With rsWork
                    .Edit
                    If (Nz(.Fields("NYAR_IDO")) > 0) And (Nz(.Fields("NYAR_KEIDO")) > 0) Then
                        .Fields("NYAR_KIRO") = MNN020.KmFromDo( _
                            CInt(Me.txt_YARD_ZAHYOKEI), _
                            CDbl(Me.txt_YARD_IDO), _
                            CDbl(Me.txt_YARD_KEIDO), _
                            CDbl(.Fields("NYAR_IDO")), _
                            CDbl(.Fields("NYAR_KEIDO")))
                        .UPDATE
                    End If
                    .MoveNext
                End With
            ElseIf rsWork("NYAR_NCODE") > .Fields("YARD_CODE") Then
                If .Fields("YARD_CODE") <> CLng(Me.cmb_ヤードコード.VALUE) Then
                    rsWork.AddNew
                    Call subAddnewWork(rsWork, rsSqlServer)
                End If
                .MoveNext
            ElseIf rsWork("NYAR_NCODE") = .Fields("YARD_CODE") Then
                rsWork.Edit
                Call subEditWork(rsWork, rsSqlServer)
                rsWork.MoveNext
                .MoveNext
            ElseIf rsWork("NYAR_NCODE") < .Fields("YARD_CODE") Then
                With rsWork
                    If (Nz(.Fields("NYAR_IDO")) > 0) And (Nz(.Fields("NYAR_KEIDO")) > 0) Then
                        .Edit
                        .Fields("NYAR_KIRO") = MNN020.KmFromDo( _
                            CInt(Me.txt_YARD_ZAHYOKEI), _
                            CDbl(Me.txt_YARD_IDO), _
                            CDbl(Me.txt_YARD_KEIDO), _
                            CDbl(.Fields("NYAR_IDO")), _
                            CDbl(.Fields("NYAR_KEIDO")))
                        .UPDATE
                    End If
                    .MoveNext
                End With
            End If
        Wend
        .Close
    End With
    On Error GoTo ErrorHandler2
    rsWork.Close
    On Error GoTo ErrorHandler1
    dbSQLServer.Close
    On Error GoTo ErrorHandler
    Me.FKS440_近隣ヤードマスタ.Requery
Exit Sub

ErrorHandler3:
    rsSqlServer.Close
ErrorHandler2:
    rsWork.Close
ErrorHandler1:
    dbSQLServer.Close
ErrorHandler:
    Call MSZZ024_M00("cmdREGET", True)
End Sub

'==============================================================================*
'
'        MODULE_NAME      : 一時テーブル取得SQL作成
'        MODULE_ID        : fncSelectWork
'        CREATE_DATE      : 2006/03/27
'        RETURN           : SQL文
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncSelectWork(ByVal strTable As String, ByVal strOrder As String) As String
    fncSelectWork = "SELECT * FROM " & strTable & " WHERE " & strOrder & " > 0 ORDER BY " & strOrder
End Function

'==============================================================================*
'
'        MODULE_NAME      : 一時テーブル追加時項目設定
'        MODULE_ID        : subAddnewWork
'        CREATE_DATE      : 2006/03/27
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub subAddnewWork(rsWork As Recordset, rsSqlServer As Object)
    On Error GoTo ErrorHandler
    With rsSqlServer
        rsWork("NYAR_YCODE") = CLng(Me.cmb_ヤードコード.VALUE)
        rsWork("NYAR_NCODE") = .Fields("YARD_CODE")
        rsWork("YARD_NAME") = .Fields("YARD_NAME")
        rsWork("YARD_ADDR") = Nz(.Fields("YARD_ADDR_1")) & Nz(.Fields("YARD_ADDR_2")) & Nz(.Fields("YARD_ADDR_3"))
    End With
    Call subEditWork(rsWork, rsSqlServer)
Exit Sub
    
ErrorHandler:                   '↓自分の関数名
    Call Err.Raise(Err.Number, "subAddnewWork" & vbRightAllow & Err.Source, Err.Description, Err.HelpFile, Err.HelpContext)
End Sub

'==============================================================================*
'
'        MODULE_NAME      : 一時テーブル追加・編集時項目設定
'        MODULE_ID        : subEditWork
'        CREATE_DATE      : 2006/03/27
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub subEditWork(rsWork As Recordset, rsSqlServer As Object)
    On Error GoTo ErrorHandler
    
    With rsSqlServer
        rsWork("NYAR_ZAHYOKEI") = .Fields("YARD_ZAHYOKEI")
        rsWork("NYAR_IDO") = .Fields("YARD_IDO")
        rsWork("NYAR_KEIDO") = .Fields("YARD_KEIDO")
        If (Nz(Me.txt_YARD_ZAHYOKEI, "") <> "") And (Nz(Me.txt_YARD_IDO, "") <> "") And (Nz(Me.txt_YARD_KEIDO, "") <> "") And _
            (Nz(.Fields("YARD_IDO")) > 0) And (Nz(.Fields("YARD_KEIDO")) > 0) And (IsNull(.Fields("YARD_KIRO"))) Then
            rsWork("NYAR_KIRO") = MNN020.KmFromDo( _
                CInt(Me.txt_YARD_ZAHYOKEI), _
                CDbl(Me.txt_YARD_IDO), _
                CDbl(Me.txt_YARD_KEIDO), _
                CDbl(.Fields("YARD_IDO")), _
                CDbl(.Fields("YARD_KEIDO")))
        Else
            rsWork("NYAR_KIRO") = .Fields("YARD_KIRO")
        End If
        rsWork.UPDATE
    End With
Exit Sub
    
ErrorHandler:                   '↓自分の関数名
    Call Err.Raise(Err.Number, "subEditWork" & vbRightAllow & Err.Source, Err.Description, Err.HelpFile, Err.HelpContext)
End Sub

