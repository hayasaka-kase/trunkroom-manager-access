'
'        MODULE_NAME      :cmd_保存_KeyDownイベント
'        MODULE_ID        :cmd_保存_KeyDown
'        CREATE_DATE      :
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub cmd_保存_KeyDown(KeyCode As Integer, Shift As Integer)

    Select Case KeyCode
        Case vbKeyReturn
            cmd_保存_Click

        Case vbKeyTab
            If Shift > 0 Then
                Me.cmb_ヤードコード.SetFocus
                Call cmd_Top_Click  ' 2005/11/21 ADD T.SUZUKI
            Else
                If intModeflg <> intModeDelete Then
                    Me.cmd_取消.SetFocus
                Else
                    Me.cmd_削除.SetFocus
                End If
            End If

        Case vbKeyUp, vbKeyRight
            If intModeflg <> intModeDelete Then
                Me.cmd_取消.SetFocus
            Else
                Me.cmd_削除.SetFocus
            End If

        Case vbKeyLeft, vbKeyDown
            Me.cmd_終了.SetFocus
    End Select

    KeyCode = 0
End Sub

