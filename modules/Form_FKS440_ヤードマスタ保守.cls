        strSQL = strSQL & "        CNTA_REASON " & Chr(13)               ' 差額理由  ' 2005/11/21 ADD T.SUZUKI
        
        '2006/06/09 SHIBAZAKI 鍵情報追加
        strSQL = strSQL & "," & fncMakeKeySqlSelect(False)
        strSQL = strSQL & ",        IS_NEW "  '2007/04/16 add tajima
        strSQL = strSQL & ",        CNTA_UKNO "  '2007/04/16 add tajima
