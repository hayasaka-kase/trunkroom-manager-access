'==============================================================================*
'
'        MODULE_NAME      :GetBoxSize
'        機能             :サイズ毎の部屋を取得
'        IN               :
'        OUT              :
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function GetBoxSize() As Boolean

    Dim strSQL    As String
    Dim objRs     As Recordset
    Dim i         As Integer

    GetBoxSize = False

    i = 0
    
    '▼ 2019/04/09 add tajima
    '部門"H"以外はサイズ設定をしない
    If (pstrBumoCD <> "H") Then
        ReDim Preserve strSize(i)
        ReDim Preserve strBox(i)
        GetBoxSize = True
        Exit Function
    End If
    '▲ 2019/04/09 add tajima

    ' 加瀬DB接続
    If fncConnectDB(pcintKASE_DB) = False Then Exit Function
    
    strSQL = " select * "
    strSQL = strSQL & " from dbo.PGPA_TABL "
    strSQL = strSQL & " where  PGPAT_PGP1B = 'FKS440' "
    strSQL = strSQL & " order by PGPAT_PGP2B "
    
    Set objRs = pobjKASE_DB.OpenRecordset(strSQL, dbOpenDynaset, dbSQLPassThrough, dbReadOnly)

    Do Until objRs.EOF
                
        ReDim Preserve strSize(i)
        ReDim Preserve strBox(i)
        
        strSize(i) = objRs.Fields("PGPAT_PGP2B")
        strBox(i) = objRs.Fields("PGPAT_PARAN")
        i = i + 1
        objRs.MoveNext
    Loop
        
    
    objRs.Close
    Set objRs = Nothing

    If fncDisConnectDB(pcintKASE_DB) = False Then Exit Function

    GetBoxSize = True
Exit Function

GetBoxSize_Exit:
    If Not objRs Is Nothing Then objRs.Close: Set objRs = Nothing
    If Not pobjKASE_DB Is Nothing Then pobjKASE_DB.Close: Set pobjKASE_DB = Nothing
End Function

