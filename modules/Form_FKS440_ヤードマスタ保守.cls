'update 2021/06/02 Private Sub subSetAKKN_DEL_Data(ByRef strDelData As String, ByVal objRsAKKN As Recordset)
Private Sub subSetAKKN_DEL_Data(ByRef strDelData As String, ByVal objRsAKKN As Object)

    Dim strWK As String

    ' 削除データを文字列に格納(最終的にログ出力)
    ' (ヤードコード・コンテナ番号)
    strWK = ""
    strWK = objRsAKKN.Fields("AKKNT_YARD") & " , " & objRsAKKN.Fields("AKKNT_CTNO") & " , " & objRsAKKN.Fields("AKKNT_KTYPE")

    ' 削除データを文字列に格納(最終的にログ出力)
    If Nz(strDelData, "") <> "" Then
        strDelData = strDelData & vbCrLf & strWK
    Else
        strDelData = pcstrAKKN_DEL & strWK
    End If
End Sub
