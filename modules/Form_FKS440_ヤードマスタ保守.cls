            If intWKCount > 0 Then
                For intCount = 0 To intWKCount - 1
                    ' コンテナマスタ登録処理(登録)
                    If fncINSKONT_MAST(intModeInsert, objRsKONT, , pvarKONTData(), intCount) = False Then Exit Function
                Next intCount
            End If

            ' 配列の解放
            Erase pvarKONTData

        Case intModeDelete  ' *** 削除 ***
            ' コンテナマスタのデータ全件削除
            With objRsKONT
                Do Until .EOF
                    If fncDELKONT_MAST(objRsKONT) = False Then Exit Function

                    .MoveNext
                Loop
            End With
    End Select
