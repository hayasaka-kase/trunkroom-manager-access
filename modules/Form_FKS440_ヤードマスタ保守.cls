'
'        MODULE_NAME      :営業日変更のヤード修繕登録
'        MODULE_ID        :insertYard修繕
'
'==============================================================================*
Private Sub insertYard修繕(aYARD_CODE As Long)
    Dim sql As String
    Dim dbKaseConect        As Object 'KASE-DBへのコネクト
    Dim KPCNumber           As String
    

    On Error GoTo Exception
    
    KPCNumber = MSZZ000.LsGetUserName
    
    sql = sql & "INSERT INTO REPR_TRAN ( "
    sql = sql & "    REPRT_UNIQEC"
    sql = sql & "   ,REPRT_BUMOC"
    sql = sql & "   ,REPRT_YARDC"
    sql = sql & "   ,REPRT_ROOMC"
    sql = sql & "   ,REPRT_INPTI"
    sql = sql & "   ,REPRT_TANTC"
    sql = sql & "   ,REPRT_GENTD"
    sql = sql & "   ,REPRT_LIMTD"
    sql = sql & "   ,REPRT_COMPD"
    sql = sql & "   ,REPRT_TYPEC"
    sql = sql & "   ,REPRT_REPRC"
    sql = sql & "   ,REPRT_CNT1N"
    sql = sql & "   ,REPRT_CNT1N1"
    sql = sql & "   ,REPRT_CNT1N2"
    sql = sql & "   ,REPRT_CNT2N"
    sql = sql & "   ,REPRT_CNT2N1"
    sql = sql & "   ,REPRT_CNT2N2"
    sql = sql & "   ,REPRT_KINGA"
    sql = sql & "   ,REPRT_WORKC"
    sql = sql & "   ,REPRT_GYOUN"
    sql = sql & "   ,REPRT_ACPTB"
    sql = sql & "   ,REPRT_INSED"
    sql = sql & "   ,REPRT_INSEJ"
    sql = sql & "   ,REPRT_INSPB"
    sql = sql & "   ,REPRT_INSUB"
    sql = sql & " ) VALUES ("
    sql = sql & "    NEWID()"                               '--REPRT_UNIQEC
    sql = sql & "   ,'" & pstrBumoCD & "'"                  '--REPRT_BUMOC
    sql = sql & "   ,'" & Format$(aYARD_CODE, "000000") & "'" '--REPRT_YARDC
    sql = sql & "   ,null"                                  '--REPRT_ROOMC 固定
    sql = sql & "   ,'01'"                                  '--REPRT_INPTI 01ヤード固定
    sql = sql & "   ,'999'"                                 '--REPRT_TANTC 固定 todo:コード確認
    sql = sql & "   ,'" & Format$(DATE, "yyyymmdd") & "'"   '--REPRT_GENTD
    sql = sql & "   ,null"                                  '--REPRT_LIMTD 固定
    sql = sql & "   ,null"                                  '--REPRT_COMPD 固定
    sql = sql & "   ,'03'"                                  '--REPRT_TYPEC 03コメント固定
    sql = sql & "   ,null"                                  '--REPRT_REPRC 固定
    sql = sql & "   ,'" & pstr営業開始日変更 & "'"          '--REPRT_CNT1N 固定
    sql = sql & "   ,'by " & KPCNumber & "'"                '--REPRT_CNT1N1"
    sql = sql & "   ,null"                                  '--REPRT_CNT1N2固定
    sql = sql & "   ,null"                                  '--REPRT_CNT2N 固定
    sql = sql & "   ,null"                                  '--REPRT_CNT2N1固定
    sql = sql & "   ,null"                                  '--REPRT_CNT2N2固定
    sql = sql & "   ,null"                                  '--REPRT_KINGA 固定
    sql = sql & "   ,null"                                  '--REPRT_WORKC 固定
    sql = sql & "   ,null"                                  '--REPRT_GYOUN 固定
    sql = sql & "   ,null"                                  '--REPRT_ACPTB 固定
    sql = sql & "   ,'" & Format$(DATE, "yyyymmdd") & "'"   '--REPRT_INSED
    sql = sql & "   ,'" & Format$(time, "hhmmss") & "'"     '--REPRT_INSEJ
    sql = sql & "   ,'" & PROG_ID & "'"                     '--REPRT_INSPB
    sql = sql & "   ,'" & KPCNumber & "'"                   '--REPRT_INSUB
    sql = sql & " )"
    
    Set dbKaseConect = ADODB_Connection()
    Call ADODB_Execute(sql, dbKaseConect)
    If Not dbKaseConect Is Nothing Then dbKaseConect.Close
Exit Sub

Exception:
    If Not dbKaseConect Is Nothing Then dbKaseConect.Close
    Call Err.Raise(Err.Number, "insertYard修繕" & vbRightAllow & Err.Source, Err.Description, Err.HelpFile, Err.HelpContext)
End Sub
