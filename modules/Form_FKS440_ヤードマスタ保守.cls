Private Sub txt_時間1_AfterUpdate()
   ' 入力がある場合のみチェック
    If Nz(Me.txt_時間1, "") <> "" Then

        ' 数字以外が含まれている場合
        If Not IsNumeric(Me.txt_時間1) Then
            MsgBox "数字のみ入力してください。", vbExclamation
            Me.txt_時間1 = ""
            Me.txt_時間1.SetFocus
        End If

        ' 1未満の場合
        If Me.txt_時間1 < 1 Then
            MsgBox "1以上を入力してください。", vbExclamation
            Me.txt_時間1 = ""
            Me.txt_時間1.SetFocus   'INSERT 2025/11/20 T.KAWABATA
        End If
    End If
End Sub

