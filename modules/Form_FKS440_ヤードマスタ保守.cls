            .Fields("CNTA_UPDATE") = objRsWk.Fields("CNTA_UPDATE")                            ' 更新日
            .Fields("CNTA_PRICE_DIFF") = Nz(objRsWk.Fields("CNTA_PRICE_DIFF"), 0)             ' 料金差額          ' 2005/11/21 ADD T.SUZUKI
