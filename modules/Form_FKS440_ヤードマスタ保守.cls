    Me.FKS440_ヤードマスタサブ価格表上.Form.RecordSource = MakePriceRecordSource(pcintUpSide)

    '段区分の固定値を上段に設定
    Me.FKS440_ヤードマスタサブ価格表上.Form.txt_段区分.DefaultValue = pcintUpSide

    'レコードソースをワークテーブルから下段データを検索するSQLに設定
    Me.FKS440_ヤードマスタサブ価格表下.Form.RecordSource = MakePriceRecordSource(pcintDownSide)

    '段区分の固定値を下段に設定
    Me.FKS440_ヤードマスタサブ価格表下.Form.txt_段区分.DefaultValue = pcintDownSide
End Sub

'==============================================================================*
