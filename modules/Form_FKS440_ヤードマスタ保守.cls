Private Function UpdateCntaReprDownside_RTN(pobjKASE_DB As Database) As Boolean

    Dim strSQL          As String
    Dim ojDyn           As Recordset
    Dim vCode(0 To 1)   As Variant

    UpdateCntaReprDownside_RTN = False

    strSQL = ""
    strSQL = "SELECT ヤード下ＷＫ.* "
    strSQL = strSQL & "FROM ヤード下ＷＫ "
    strSQL = strSQL & "ORDER BY CNTA_CODE,CNTA_NO;"
    Set ojDyn = objDb.OpenRecordset(strSQL, dbOpenDynaset)

    If ojDyn.EOF Then

    Else
        ojDyn.MoveFirst
        Do Until ojDyn.EOF

            ojDyn.Edit  'カレントレコードを編集できるように編集バッファにコピー

            vCode(0) = Format(Nz(ojDyn!CNTA_CODE), "000000") ' ヤードコード
            vCode(1) = Format(Nz(ojDyn!CNTA_NO), "000000")   ' コンテナ番号

            '修繕状態の判断
            ' 修繕トランよりユニークコードを取得
            strSQL = " SELECT REPRT_UNIQEC " & Chr(13)
            strSQL = strSQL & "  FROM REPR_TRAN " & Chr(13)
            strSQL = strSQL & " WHERE REPRT_YARDC = '" & (vCode(0)) & "'" & Chr(13)
            strSQL = strSQL & "   AND REPRT_ROOMC = '" & (vCode(1)) & "'" & Chr(13)
            strSQL = strSQL & "   AND REPRT_BUMOC = '" & pstrBumoCD & "'"       'INSERT 2018/10/19 N.IMAI
            Set objRs = pobjKASE_DB.OpenRecordset(strSQL, dbOpenDynaset, dbSQLPassThrough, dbReadOnly)

            If objRs.EOF Then
                ' 修繕トランに存在しないとき
                ojDyn.Fields("REPR_NAME") = Null    ' 修繕状態(名称)
            Else
                ' 修繕トランに存在するとき
                ojDyn.Fields("REPR_NAME") = "修繕"  ' 修繕状態(名称)
            End If
            
            '修繕状態レコードをクローズ
            objRs.Close
            Set objRs = Nothing

            'カレントレコードの編集
            ojDyn.UPDATE
            ojDyn.MoveNext
        Loop
    End If

    If Not ojDyn Is Nothing Then ojDyn.Close: Set ojDyn = Nothing
    If Not objRs Is Nothing Then objRs.Close: Set objRs = Nothing

     UpdateCntaReprDownside_RTN = True
End Function

