'==============================================================================*
'
'        MODULE_NAME      :コンテナデータ削除チェック
'        MODULE_ID        :fncDelCheck
'        CREATE_DATE      :2005/10/24
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncDelCheck() As Boolean

    Dim intCount    As Integer
    Dim intCheckKbn As Integer
    Dim strYcode    As String
    Dim strSQL      As String
    Dim objRs       As Recordset

    On Error GoTo fncDelCheck_Err

    fncDelCheck = False

    intCheckKbn = 0

    ' ヤードコード取得
    strYcode = Me.cmb_ヤードコード

    ' ヤードコードが未選択の場合処理を抜ける
    If Nz(Trim(strYcode), "") = "" Then Exit Function
    
' INSERT 2009/04/01 KIHARA Start
    '==============================================================
    ' 加瀬DB接続
    If fncConnectDB(pcintKASE_DB) = False Then Exit Function
    ' 修繕トラン
    intCheckKbn = 4
    intCount = 0

    strSQL = "SELECT COUNT(*) " & Chr(13)
    strSQL = strSQL & " FROM REPR_TRAN " & Chr(13)
    strSQL = strSQL & " WHERE REPRT_YARDC = '" & strYcode & "'" & Chr(13)
    strSQL = strSQL & "   AND REPRT_BUMOC = '" & pstrBumoCD & "'"               'INSERT 2018/10/19 N.IMAI
    Set objRs = pobjKASE_DB.OpenRecordset(strSQL, dbOpenDynaset, dbSQLPassThrough, dbReadOnly)

    intCount = Nz(objRs.Fields(0), 0)

    objRs.Close
    Set objRs = Nothing

    If intCount > 0 Then
        GoTo fncDelCheck_Err_Exit
    End If
    ' 加瀬DB切断
    If fncDisConnectDB(pcintKASE_DB) = False Then Exit Function
    '==============================================================
' INSERT 2009/04/01 KIHARA End

' 2005/11/08 ADD T.SUZUKI Start
    ' コンテナDB接続
    If fncConnectDB(pcintKONT_DB) = False Then Exit Function
' 2005/11/08 ADD T.SUZUKI End

    ' 予約受付トラン
    intCheckKbn = 3
    intCount = 0

    strSQL = "SELECT COUNT(*) " & Chr(13)
    strSQL = strSQL & " FROM YOUK_TRAN " & Chr(13)                                              ' 2005/11/08 ADD T.SUZUKI
'    strSQL = strSQL & " FROM dbo_YOUK_TRAN " & Chr(13)                                         ' 2005/11/08 DEL T.SUZUKI
    strSQL = strSQL & " WHERE YOUKT_YCODE = " & strYcode
    Set objRs = pobjKONT_DB.OpenRecordset(strSQL, dbOpenDynaset, dbSQLPassThrough, dbReadOnly)  ' 2005/11/08 ADD T.SUZUKI
'    Set objRs = objDb.OpenRecordset(strSQL, dbOpenDynaset)                                     ' 2005/11/08 DEL T.SUZUKI

    intCount = Nz(objRs.Fields(0), 0)

    objRs.Close
    Set objRs = Nothing

    If intCount > 0 Then
        GoTo fncDelCheck_Err_Exit
    End If
    ' -------------------------------------------------------------

    ' コンテナ契約ファイル
    intCheckKbn = 2
    intCount = 0

    strSQL = "SELECT COUNT(*) " & Chr(13)
    strSQL = strSQL & " FROM CARG_FILE " & Chr(13)                                              ' 2005/11/08 ADD T.SUZUKI
'    strSQL = strSQL & " FROM dbo_CARG_FILE " & Chr(13)                                         ' 2005/11/08 DEL T.SUZUKI
    strSQL = strSQL & " WHERE CARG_YCODE = " & strYcode
    Set objRs = pobjKONT_DB.OpenRecordset(strSQL, dbOpenDynaset, dbSQLPassThrough, dbReadOnly)  ' 2005/11/08 ADD T.SUZUKI
'    Set objRs = objDb.OpenRecordset(strSQL, dbOpenDynaset)                                     ' 2005/11/08 DEL T.SUZUKI

    intCount = Nz(objRs.Fields(0), 0)

    objRs.Close
    Set objRs = Nothing

    If intCount > 0 Then
        GoTo fncDelCheck_Err_Exit
    End If
    ' -------------------------------------------------------------

    ' 地主契約トラン
    intCheckKbn = 1
    intCount = 0

    strSQL = "SELECT COUNT(*) " & Chr(13)
    strSQL = strSQL & " FROM JARG_FILE " & Chr(13)                                              ' 2005/11/08 ADD T.SUZUKI
'    strSQL = strSQL & " FROM dbo_JARG_FILE " & Chr(13)                                         ' 2005/11/08 DEL T.SUZUKI
    strSQL = strSQL & " WHERE JARG_YCODE = " & strYcode
    Set objRs = pobjKONT_DB.OpenRecordset(strSQL, dbOpenDynaset, dbSQLPassThrough, dbReadOnly)  ' 2005/11/08 ADD T.SUZUKI
'    Set objRs = objDb.OpenRecordset(strSQL, dbOpenDynaset)                                     ' 2005/11/08 DEL T.SUZUKI

    intCount = Nz(objRs.Fields(0), 0)

    objRs.Close
    Set objRs = Nothing

    If intCount > 0 Then
        GoTo fncDelCheck_Err_Exit
    End If
    ' -------------------------------------------------------------

' 2005/11/08 ADD T.SUZUKI Start
    ' コンテナDB切断
    If fncDisConnectDB(pcintKONT_DB) = False Then Exit Function
' 2005/11/08 ADD T.SUZUKI End

    fncDelCheck = True

    Exit Function

fncDelCheck_Err_Exit:
    Select Case intCheckKbn
        Case 4  ' *** 修繕トランチェックエラー ***
            MsgBox pstrCstREPRErrMsg, vbInformation, strMsg_err     'INSERT 2009/04/01 KIHARA
    
        Case 3  ' *** 予約受付トランチェックエラー ***
            MsgBox pstrCstYOUKErrMsg, vbInformation, strMsg_err

        Case 2  ' *** コンテナ契約ファイルチェックエラー ***
            MsgBox pstrCstCARGErrMsg, vbInformation, strMsg_err

        Case 1  ' *** 地主契約トランチェックエラー ***
            MsgBox pstrCstJARGErrMsg, vbInformation, strMsg_err
    End Select

    If Not objRs Is Nothing Then objRs.Close: Set objRs = Nothing
    If Not pobjKONT_DB Is Nothing Then pobjKONT_DB.Close: Set pobjKONT_DB = Nothing  ' 2005/11/08 ADD T.SUZUKI
    If Not pobjKASE_DB Is Nothing Then pobjKASE_DB.Close: Set pobjKASE_DB = Nothing  ' 2009/04/01 INS KIHARA
    Exit Function

fncDelCheck_Err:
    MsgBox "ｴﾗｰ番号" & Err.Number & vbCrLf & Err.Description
    Err.Clear
End Function

