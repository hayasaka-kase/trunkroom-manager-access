'
'        MODULE_NAME      :Form_KeyDownイベント
'        MODULE_ID        :Form_KeyDown
'        CREATE_DATE      :
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub Form_KeyDown(KeyCode As Integer, Shift As Integer)
    
    
    Call CmReprMod.OpenFVS90n(KeyCode, Me.cmb_ヤードコード)  ' 2006/06/24 Add tajima
    
    On Error Resume Next
              
    Select Case KeyCode
        Case vbKeyF1
            KeyCode = 0
            Me.cmd_終了.SetFocus

        Case vbKeyF2
            KeyCode = 0
            If Me.opg_処理選択.VALUE = 3 Then
                Me.cmd_削除.SetFocus
            Else
                Me.cmd_保存.SetFocus
            End If

' 2005/11/08 DEL T.SUZUKI Start
'        Case vbKeyF5
'            KeyCode = 0
'            Me.FKS440_ヤードマスタサブ上.SetFocus
'            doCmd.GoToRecord , , acFirst
'            Forms![FKS440_ヤードマスタサブ上]![txt_コンテナ番号].SetFocus
' 2005/11/08 DEL T.SUZUKI End

        Case vbKeyF3, vbKeyF6 To vbKeyF12, vbKeyF5  ' 2005/11/08 ADD T.SUZUKI
'        Case vbKeyF3, vbKeyF6 To vbKeyF12          ' 2005/11/08 DEL T.SUZUKI
            KeyCode = 0

' 2005/11/21 ADD T.SUZUKI Start
        Case vbKeyPageUp
            ' ページアップキー
            KeyCode = 0
            Call cmd_Top_Click

        Case vbKeyPageDown
            ' ページダウンキー
            KeyCode = 0
            Call cmd_Bottom_Click
        
        Case Else
            Exit Sub
    End Select
' 2005/11/21 ADD T.SUZUKI End
End Sub

