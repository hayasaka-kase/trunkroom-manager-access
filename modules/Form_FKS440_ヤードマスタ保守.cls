'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub txt_営業終了日_BeforeUpdate(Cancel As Integer)
    Dim errorMsg As String
    
    errorMsg = ""
    
    If fncDateCheck(txt_営業終了日, Cancel) = True Then
        If Nz(VarChangeDate, "") <> "" Then
            If Nz(txt_営業開始日, "") <> "" Then
                If CDate(VarChangeDate) <= CDate(txt_営業開始日) Then
                    errorMsg = "営業終了日は営業開始日の翌日以降として下さい。"
                End If
            End If
                
            If errorMsg = "" And Nz(txt_ヤード解約予定日, "") <> "" Then
                If CDate(VarChangeDate) > CDate(txt_ヤード解約予定日) Then
                    errorMsg = "営業終了日はヤード解約予定日以前として下さい。"
                End If
            End If
                
            If errorMsg <> "" Then
                MsgBox errorMsg, vbInformation, strMsg_err
                Cancel = True
                SendKeys "{ESC}"
            End If
        End If
    End If

End Sub

