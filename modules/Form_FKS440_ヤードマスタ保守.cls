Private Sub cmd_保存_Click()

    Dim intAns      As Integer
    Dim intRtn      As Integer  ' 2005/10/24 ADD T.SUZUKI

' 2005/10/24 ADD T.SUZUKI Start
    ' 入力中のレコードを確定する。
    On Error Resume Next
    doCmd.RunCommand acCmdSaveRecord
' 2005/10/24 ADD T.SUZUKI End

    On Error GoTo err_rtn

    'INSERT 2025/11/20 T.KAWABATA Start
    If CHK_MOYORIEKI = False Then Exit Sub
    'INSERT 2025/11/20 T.KAWABATA End

    ' ヤードマスタ入力項目の必須入力チェック
    If CHK_INPUTDATA = False Then Exit Sub

' INSERT START 2018/08/20 K.WADA
    ' 価格表入力チェック
    ' *** 上段 ***
    intRtn = fncInputCheckKakaku(0)
    If intRtn <> 0 Then Exit Sub

    ' *** 下段 ***
    intRtn = fncInputCheckKakaku(1)
    If intRtn <> 0 Then Exit Sub

' INSERT END 2018/08/20 K.WADA

' 2005/10/24 ADD T.SUZUKI Start
    ' コンテナマスタ入力項目の必須入力チェック
    ' *** 上段 ***
    intRtn = fncInputCheck(0)
    If intRtn <> 0 Then Exit Sub

    ' *** 下段 ***
    intRtn = fncInputCheck(1)
    If intRtn <> 0 Then Exit Sub
' 2005/10/24 ADD T.SUZUKI End

    
'2018/11/14 EGL 貸止期間追加↓
    intRtn = fncInputStopDate()
    If intRtn <> 0 Then Exit Sub
'2018/11/14 EGL 貸止期間追加↑

    '確認メッセージ
    intAns = MsgBox(strmsg保存確認, vbQuestion + vbYesNo, strMsg_kaku)

    If intAns = vbNo Then GoTo Exit_rtn

    If WRI_RTN = True Then
        doCmd.Echo False     'Add 01-11-2000 Araki
        Call CLR_RTN  ' 画面の初期化
        Call DEL_RTN  ' ワーク削除 & 作成
        blnDataUpdate = False
        Me.cmb_ヤードコード.Requery
        Me.FKS440_ヤードマスタサブ上.Requery
        Me.FKS440_ヤードマスタサブ下.Requery
        Me.FKS440_近隣ヤードマスタ.Requery  ' 2005/10/24 ADD T.SUZUKI
        Me.FKS440_ヤードマスタサブ価格表上.Requery  ' 2005/11/21 ADD S.SHIBAZAKI
        Me.FKS440_ヤードマスタサブ価格表下.Requery  ' 2005/11/21 ADD S.SHIBAZAKI
        doCmd.Echo True     'Add 01-11-2000 Araki

        Call cmd_Necessary_Click           ' 2005/10/24 ADD T.SUZUKI
        Call Etc_Lock_Rtn                  ' 2005/10/24 ADD T.SUZUKI
        Call cmd_NecessaryLow_Click        ' 2005/11/21 ADD S.SHIBAZAKI
    
        Call Check駅                       'INSERT 2025/11/20 T.KAWABATA
    
    End If

Exit_rtn:
    Me.cmb_ヤードコード.SetFocus
    Call cmd_Top_Click  ' 2005/11/21 ADD T.SUZUKI
    Exit Sub

err_rtn:
    MsgBox "ｴﾗｰ番号" & Err.Number & vbCrLf & Err.Description
    Err.Clear
    GoTo Exit_rtn
End Sub

