    strYardCode = Format$(Me.cmb_ヤードコード, "000000")
    
    ' 修正があったか、または新規モードのとき
    If blnDataUpdate = True Or intModeflg = intModeInsert Then
    
        ' 入力中のレコードを確定する。
        On Error Resume Next
        doCmd.RunCommand acCmdSaveRecord
    
        On Error GoTo Exception
    
        ' ヤードマスタ入力項目の必須入力チェック
        If CHK_INPUTDATA = False Then Exit Sub
    
        ' コンテナマスタ入力項目の必須入力チェック
