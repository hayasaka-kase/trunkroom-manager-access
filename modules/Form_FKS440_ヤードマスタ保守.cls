            '2006/06/09 SHIBAZAKI 鍵情報追加
            Call subSetKeyInfoToWork(objRsWk, objRsKONT, False)

            '▼2007/04/16 tajima 新規コンテナは【紹介待ち】とする
            If objRsWk.Fields("IS_NEW") = True Then
                .Fields("CNTA_USE") = 0
