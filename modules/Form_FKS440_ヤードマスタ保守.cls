Private Sub txt_ネット保証会社2適用賃料_BeforeUpdate(Cancel As Integer)

    On Error GoTo err_rtn

    If blnFormLoadFlg = False Then Exit Sub

    If fncTxtInputCheck(Me.txt_ネット保証会社2適用賃料, pcsglMoneyMaxValue, 9) = False Then
        MsgBox strMSG桁数オーバー, vbInformation, strMsg_err
        Cancel = True
        SendKeys "{ESC}"
    End If

