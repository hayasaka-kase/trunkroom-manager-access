Private Function WRI_CNTA_MAST(ByVal intMode As Integer) As Boolean
'Private Function WRI_CNTA_MAST() As Boolean
' 2005/10/24 REP T.SUZUKI End

    Dim strSQL       As String
    Dim vCode        As Variant

' 2005/10/24 ADD T.SUZUKI Start
