'==============================================================================*
'
'        MODULE_NAME      :数値項目のチェックを一括でする。
'        MODULE_ID        :CHK_Numeric
'        CREATE_DATE      :
'       返り値
'                      １：数値と判断できない時
'                      ２：桁数が溢れている時
'                      ９：それ以外のエラー
'                      ０：すべてのチェックがＯＫの時
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function CHK_Numeric(ByVal oText As Variant, ByVal ilen As Integer) As Integer

    On Error GoTo err_rtn

    CHK_Numeric = 9
  
    If Nz(CmNumeric(oText), "") = "" Then
        CHK_Numeric = 1
        GoTo Exit_rtn
    End If

    If CmLenb(Replace(oText, "-", "")) > ilen Then  ' 2005/11/30 ADD T.SUZUKI
'    If CmLenb(oText) > iLen Then                   ' 2005/11/30 DEL T.SUZUKI
        CHK_Numeric = 2
        GoTo Exit_rtn
    End If

    CHK_Numeric = 0

Exit_rtn:
    Exit Function

err_rtn:
    MsgBox "ｴﾗｰ番号" & Err.Number & vbCrLf & Err.Description
    CHK_Numeric = 9
    GoTo Exit_rtn
End Function

