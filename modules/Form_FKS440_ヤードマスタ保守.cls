    fncSelectName = strName
End Function

'==============================================================================*
'
'        MODULE_NAME      :貸止期間チェック
'        MODULE_ID        :fncInputStopDate
'        CREATE_DATE      :2018/11/14
'==============================================================================*
Private Function fncInputStopDate() As Integer
    
    fncInputStopDate = -1
    
    '■未入力
    If Trim(Me.txt_貸止FROM_D) = "" And Trim(Me.txt_貸止FROM_T) = "" _
    And Trim(Me.txt_貸止TO_D) = "" And Trim(Me.txt_貸止TO_T) = "" Then
        '未入力
        fncInputStopDate = 0
        Exit Function
    End If
    
    '■一部入力は不可
    If Trim(Nz(Me.txt_貸止FROM_D)) = "" Then
        MsgBox "貸止期間は開始終了日時を入力して下さい", vbInformation, strMsg_err
        Me.txt_貸止FROM_D.SetFocus
        Exit Function
    End If
    If Trim(Nz(Me.txt_貸止FROM_T)) = "" Then
        MsgBox "貸止期間は開始終了日時を入力して下さい", vbInformation, strMsg_err
        Me.txt_貸止FROM_T.SetFocus
        Exit Function
    End If
    If Trim(Nz(Me.txt_貸止TO_D)) = "" Then
        MsgBox "貸止期間は開始終了日時を入力して下さい", vbInformation, strMsg_err
        Me.txt_貸止TO_D.SetFocus
        Exit Function
    End If
    If Trim(Nz(Me.txt_貸止TO_T)) = "" Then
        MsgBox "貸止期間は開始終了日時を入力して下さい", vbInformation, strMsg_err
        Me.txt_貸止TO_T.SetFocus
        Exit Function
    End If
    
    '■形のチェック
    If Not IsDate(Me.txt_貸止FROM_D) Then
        MsgBox "貸止期間は開始日はYYYY/MM/DD形式で入力して下さい", vbInformation, strMsg_err
        Me.txt_貸止FROM_D.SetFocus
        Exit Function
    End If
    If Not IsDate("2018/01/01 " & Me.txt_貸止FROM_T) Then
        MsgBox "貸止期間は開始時間はHH:MM形式で入力して下さい", vbInformation, strMsg_err
        Me.txt_貸止FROM_T.SetFocus
        Exit Function
    End If
    If Not IsDate(Me.txt_貸止TO_D) Then
        MsgBox "貸止期間は終了日はYYYY/MM/DD形式で入力して下さい", vbInformation, strMsg_err
        Me.txt_貸止TO_D.SetFocus
        Exit Function
    End If
    If Not IsDate("2018/01/01 " & Me.txt_貸止TO_T) Then
        MsgBox "貸止期間は終了時間はHH:MM形式で入力して下さい", vbInformation, strMsg_err
        Me.txt_貸止TO_T.SetFocus
        Exit Function
    End If
    
    '■開始日時＜終了日時は不可
    If CDate(Me.txt_貸止FROM_D & Space(1) & Me.txt_貸止FROM_T) >= CDate(Me.txt_貸止TO_D & Space(1) & Me.txt_貸止TO_T) Then
        MsgBox "貸止期間を入力するならば、開始日時＜終了日時で入力して下さい", vbInformation, strMsg_err
        Me.txt_貸止FROM_D.SetFocus
        Exit Function
    End If

    fncInputStopDate = 0
End Function

'==============================================================================*
'
'        MODULE_NAME      :上段・下段入力チェック
'        MODULE_ID        :fncInputCheck
'        Parameter        :intKbn(0:上段 / 1:下段)
'        CREATE_DATE      :2005/10/24
'==============================================================================*
'        UPDATE_DATE      :2017/05/06 K.SATO
'                          種別の必須チェックを廃止
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncInputCheck(intKbn As Integer) As Integer

    Dim intCheckKbn  As Integer
    Dim objRs        As Recordset
    Dim objSubForm   As SubForm
    Dim objControl   As Control

'    Dim strSQL As String

    On Error GoTo fncInputCheck_Err

    fncInputCheck = -1

    Select Case intKbn
        Case 0  ' *** 上段 ***
'            strSQL = "SELECT * FROM ヤード上ＷＫ "
            Set objSubForm = Me.FKS440_ヤードマスタサブ上

        Case 1  ' *** 下段 ***
'            strSQL = "SELECT * FROM ヤード下ＷＫ "
            Set objSubForm = Me.FKS440_ヤードマスタサブ下
    End Select

    doCmd.GoToRecord , , acFirst
    objSubForm.Requery

'    Set objRs = objDb.OpenRecordset(strSQL, dbReadOnly)
    ' 上段 OR 下段のレコードセットのクローン作成
    Set objRs = objSubForm.Form.RecordsetClone

' 2005/11/08 ADD T.SUZUKI Start
    On Error Resume Next
    objRs.MoveLast
    objRs.MoveFirst
' 2005/11/08 ADD T.SUZUKI End
' 2005/11/08 DEL T.SUZUKI Start
'    If objRs.EOF = False Then
'        objRs.MoveLast
'        objRs.MoveFirst
'    End If
' 2005/11/08 DEL T.SUZUKI End

    Do Until objRs.EOF
        ' 入力チェック

        ' *** 共通項目 ***
        intCheckKbn = 0

        ' コンテナ番号
        If Nz(objRs.Fields("CNTA_NO"), "") = "" Then
            MsgBox "コンテナ番号" & pcstrMSGInputError, vbInformation, strMsg_err

            objSubForm.SetFocus
            objSubForm.Form.Bookmark = objRs.Bookmark
            Set objControl = objSubForm!txt_コンテナ番号
            GoTo fncInputCheckErr_Exit
        End If

        ' コンテナ種別
        'DEL 2017/05/06 K.SATO Start
        'If Nz(objRs.Fields("CNTA_SYU"), "") = "" Then
        '    MsgBox "種別" & pcstrMSGInputError, vbInformation, strMsg_err
        '
        '    objSubForm.SetFocus
        '    objSubForm.Form.Bookmark = objRs.Bookmark
        '    Set objControl = objSubForm!cmb_種別
        '    GoTo fncInputCheckErr_Exit
        'End If
        'DEL 2017/05/06 K.SATO End

        ' 使用用途
        If Nz(objRs.Fields("CNTA_USAGE"), "") = "" Then
            MsgBox "用途" & pcstrMSGInputError, vbInformation, strMsg_err

            objSubForm.SetFocus
            objSubForm.Form.Bookmark = objRs.Bookmark
            Set objControl = objSubForm!CNTA_USAGE
            GoTo fncInputCheckErr_Exit
        End If

        ' 利用
        If Nz(objRs.Fields("CNTA_USE"), "") = "" Then
            MsgBox "利用" & pcstrMSGInputError, vbInformation, strMsg_err

            objSubForm.SetFocus
            objSubForm.Form.Bookmark = objRs.Bookmark
            Set objControl = objSubForm!CNTA_USE
            GoTo fncInputCheckErr_Exit
        End If

        ' *** 必須 ***
        intCheckKbn = 1

        ' 実帖
        If Nz(objRs.Fields("CNTA_SIZE"), "") = "" Then
            MsgBox "実帖" & pcstrMSGInputError, vbInformation, strMsg_err

            objSubForm.SetFocus
            objSubForm.Form.Bookmark = objRs.Bookmark
            Set objControl = objSubForm!CNTA_SIZE
            GoTo fncInputCheckErr_Exit
        End If
        
        ' INSERT START 2018/08/20 K.WADA
        If Nz(objRs.Fields("CNTA_FLOOR"), "") = "" Then
            MsgBox "階数" & pcstrMSGInputError, vbInformation, strMsg_err

            objSubForm.SetFocus
            objSubForm.Form.Bookmark = objRs.Bookmark
            Set objControl = objSubForm!CNTA_FLOOR
            GoTo fncInputCheckErr_Exit
        End If
        ' INSERT END 2018/08/20 K.WADA

' 2005/11/21 DEL T.SUZUKI Start
'        ' 月額料金
'        If Nz(objRs.Fields("CNTA_KEI_RENTKG"), "") = "" Then
'            MsgBox "月額料金" & pcstrMSGInputError, vbInformation, strMsg_err
'
'            objSubForm.SetFocus
'            objSubForm.Form.Bookmark = objRs.Bookmark
'            Set ObjControl = objSubForm!CNTA_KEI_RENTKG
'            GoTo fncInputCheckErr_Exit
'        End If
'
'        ' 予約保証金
'        If Nz(objRs.Fields("CNTA_SECUKG"), "") = "" Then
'            MsgBox "予約保証金" & pcstrMSGInputError, vbInformation, strMsg_err
'
'            objSubForm.SetFocus
'            objSubForm.Form.Bookmark = objRs.Bookmark
'            Set ObjControl = objSubForm!CNTA_SECUKG
'            GoTo fncInputCheckErr_Exit
'        End If
