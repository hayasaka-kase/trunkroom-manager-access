'==============================================================================*
'
'        MODULE_NAME      :文字項目のチェックを一括でする。
'        MODULE_ID        :CmBCheck_Char
'        CREATE_DATE      :
'返り値は、
'２：桁数が溢れている時
'９：それ以外のエラー
'０：すべてのチェックがＯＫの時
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Public Function CmBCheck_Char(ByVal oText As Variant, ByVal ilen As Integer) As Integer
'Private Function CmBCheck_Char(ByVal oText As Variant, ByVal iLen As Integer) As Integer

    On Error GoTo err_rtn

    CmBCheck_Char = 9

    If CmLenb(oText) > ilen Then
      CmBCheck_Char = 2
      GoTo Exit_rtn
    End If

    CmBCheck_Char = 0

Exit_rtn:
    Exit Function

err_rtn:
    MsgBox "ｴﾗｰ番号" & Err.Number & vbCrLf & Err.Description
    CmBCheck_Char = 9
    GoTo Exit_rtn
End Function

'==============================================================================*
'
'        MODULE_NAME      :
'        MODULE_ID        :CmBCheck_Num
'        CREATE_DATE      :
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
'**********************************************
'数値項目のチェックを一括でする。
'**********************************************
Private Function CmbCheck_Num(ByVal oText As Variant, ByVal ilen As Integer, Optional ByVal isLEN As Variant) As Integer
  '返り値は、
  '１：数値と判断できない時
  '２：桁数が溢れている時
  '９：それ以外のエラー
  '０：すべてのチェックがＯＫの時

  '引数 oText ←判定する値
  '     iLen  ←整数桁
  '     isLen ←小数桁(省略された時は、小数点桁数無し)

    Dim vINT    As Variant
    Dim vsINT   As Variant
    Dim i       As Integer

    Dim dTEXT   As Double
    Dim dFROM   As Double
    Dim dTO     As Double
    Dim vRet    As Variant

    On Error GoTo err_rtn

    CmbCheck_Num = 9

    If Nz(CmNumeric(oText), "") = "" Then       '数値と判断できないのでエラー
        CmbCheck_Num = 1
        GoTo Exit_rtn
    End If

    If CmChkCher(CStr(Nz(oText)), "A") = False Then '全角文字が入力されているのでエラー
        CmbCheck_Num = 1
        GoTo Exit_rtn
    End If

    '小数点の値が設定されている時のチェック
    vRet = Nz(InStr(Abs(oText), "."), 0)

    If IsMissing(isLEN) = False Then
        If vRet <> 0 Then
            If isLEN < CmLenb(Abs(oText)) - vRet Then    '小数点桁数が設定桁数を超えているエラー
                CmbCheck_Num = 2
                GoTo Exit_rtn
            End If
        End If
    Else
        If CmLenb(Abs(CmNumeric(oText))) > ilen Then           '文字数超過のためエラー
            CmbCheck_Num = 2
            GoTo Exit_rtn
        End If

        If vRet <> 0 Then                         '小数点の入力があるのでエラー
            CmbCheck_Num = 2
            GoTo Exit_rtn
        End If
    End If

    '桁チェック
    i = 0
    For i = 1 To ilen
        vINT = vINT & "9"
    Next

    If IsMissing(isLEN) = False Then
        vsINT = "."
        i = 0
        For i = 1 To isLEN
            vsINT = vsINT & "9"
        Next
    End If

    vINT = vINT & vsINT
    vINT = CmNumeric(vINT)

    dTEXT = CmNumeric(oText)
    dFROM = vINT * -1
    dTO = vINT

    If dFROM > dTEXT Or dTO < dTEXT Then        '論理範囲超過のためエラー
        CmbCheck_Num = 2
        GoTo Exit_rtn
    End If

    CmbCheck_Num = 0

Exit_rtn:
    Exit Function

err_rtn:
    MsgBox "ｴﾗｰ番号" & Err.Number & vbCrLf & Err.Description
    CmbCheck_Num = 9
    GoTo Exit_rtn
End Function

'==============================================================================*
'
'        MODULE_NAME      :
'        MODULE_ID        :CmFormatConma
'        CREATE_DATE      :
'        引数          ０：カンマ表示
'                      １：カンマ無し
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub CmFormatConma(ByVal oText As TextBox, ByVal iMode As Integer)

    Dim objCONT As TextBox

    Set objCONT = oText

    If iMode = 0 Then
        objCONT.VALUE = Format(Nz(CmNumeric(objCONT), ""), "#,##0")
    Else
        objCONT.VALUE = Format(Nz(CmNumeric(objCONT), ""), "0")
    End If
End Sub

'==============================================================================*
'
'        MODULE_NAME      :コントロールの入力切替設定
'        MODULE_ID        :CmLockControl
'        CREATE_DATE      :
'        引数             :０  使用可
'                          １  使用不可
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub CmLockControl(ByVal ContNM As Object, ByVal iMode As Integer)

    Dim objControl As Object

    Set objControl = ContNM

    If iMode = 0 Then
        objControl.Enabled = True
        If TypeName(objControl) <> "CommandButton" Then                         'INSERT 2006/03/27 K.ISHIZAKA
            objControl.Locked = False
        End If                                                                  'INSERT 2006/03/27 K.ISHIZAKA
    Else
        objControl.Enabled = False
        If TypeName(objControl) <> "CommandButton" Then                         'INSERT 2006/03/27 K.ISHIZAKA
            objControl.Locked = True
        End If                                                                  'INSERT 2006/03/27 K.ISHIZAKA
    End If
End Sub

