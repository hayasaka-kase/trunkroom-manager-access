'==============================================================================*
'
'        MODULE_NAME      :必須チェック(コンテナ上段・下段)
'        MODULE_ID        :RequireCheck
'        Parameter        :intKbn
'                                0 = 上段
'                                1 = 下段
'        CREATE_DATE      :2005/11/26
'==============================================================================*
'        UPDATE_DATE      :2017/05/06 K.SATO
'                          種別の必須チェックを廃止
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Public Function RequireCheck(ByVal intKbn As Integer) As Boolean

    Dim objSubForm   As SubForm

    RequireCheck = False

    Select Case intKbn
        Case 0  ' *** 上段 ***
            Set objSubForm = Me.FKS440_ヤードマスタサブ上

        Case 1  ' *** 下段 ***
            Set objSubForm = Me.FKS440_ヤードマスタサブ下
    End Select

    ' コンテナ番号
    If Nz(objSubForm!txt_コンテナ番号) = "" Then
        MsgBox strMSG必須入力エラー, vbInformation, strMsg_err
        objSubForm!txt_コンテナ番号.SetFocus
        Exit Function
    End If

    'del 2017/05/06 K.SATO Start
    ' 種別
    'If Nz(objSubForm!cmb_種別) = "" Then
    '    MsgBox strMSG必須入力エラー, vbInformation, strMsg_err
    '    objSubForm!cmb_種別.SetFocus
    '    Exit Function
    'End If
    'del 2017/05/06 K.SATO End

    ' 用途
    If Nz(objSubForm!CNTA_USAGE) = "" Then
        MsgBox strMSG必須入力エラー, vbInformation, strMsg_err
        objSubForm!CNTA_USAGE.SetFocus
        Exit Function
    End If

    ' 実帖
    If Nz(objSubForm!CNTA_SIZE) = "" Then
        MsgBox strMSG必須入力エラー, vbInformation, strMsg_err
        objSubForm!CNTA_SIZE.SetFocus
' INSERT START 2018/09/05 K.WADA
        objSubForm!lbl_階数.Visible = True
        objSubForm!CNTA_FLOOR.Visible = True
' INSERT END 2018/09/05 K.WADA
        Exit Function
    End If

    RequireCheck = True
End Function

