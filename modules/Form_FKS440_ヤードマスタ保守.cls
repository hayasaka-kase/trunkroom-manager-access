'==============================================================================*
'
'       MODULE_NAME     : 書類プレビュー
'       MODULE_ID       : xlPrintPreview
'       CREATE_DATE     : 2018/07/10            K.MITSUNO
'       PARAM           : [strTanto]            担当コード(I)省略可能
'       RETURN          : 正常(True)／異常(False)
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function xlPreview() As Boolean

    Const pstrCstKAKUNIN             As String = "確認"

    Dim strYardCode         As String
    Dim strPath             As String
    Dim strExcel            As String
    Dim strFileDir          As String
    Dim strFile             As String
    Dim xlApp               As Object
    Dim xlBook              As Object
    On Error GoTo ErrorHandler
    
    
    If Nz(CmNumeric(Me.cmb_ヤードコード), "") = "" Then
        xlPreview = False
        Exit Function
    End If

    strYardCode = Me.cmb_ヤードコード.VALUE
    
    If (MsgBox("Excel出力を実行しますか？", vbYesNo + vbQuestion, pstrCstKAKUNIN) = vbNo) Then
        Exit Function
    End If
    
    strExcel = Nz(DLookup("CONT_EXCEL_PATH", "dbo_CONT_MAST", ""), "")

    'バックアップ
    FileCopy strExcel & "\" & strYardCode & ".xls", strExcel & "\bk\" & strYardCode & "_" & Format(Now, "yyyyMMddhhnnss") & ".xls"

    strExcel = Nz(DLookup("CONT_EXCEL_PATH", "dbo_CONT_MAST", ""), "") & "\" & strYardCode & ".xls"
    'エクセル起動
    Set xlApp = CreateObject("Excel.Application")
    On Error GoTo ErrorHandler1
    xlApp.ScreenUpdating = False
    xlApp.DisplayAlerts = False
    Set xlBook = xlApp.Workbooks.Open(strExcel, 0)
    On Error GoTo ErrorHandler2
    
    'データ取得
    If GetData_Yard_Excel(xlBook) Then
    
        xlApp.DisplayAlerts = False
        xlBook.SaveAs strExcel
        
        '表示する
        xlApp.ScreenUpdating = True
        xlApp.Visible = True
        On Error GoTo ErrorHandler
        xlPreview = True
    Else
        xlBook.Close False
