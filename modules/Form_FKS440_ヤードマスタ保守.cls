'==============================================================================*
'
'        MODULE_NAME      :cmb_巡回担当コード_AfterUpdate()
'        機能             :cmb_巡回担当コード AfterUpdateｲﾍﾞﾝﾄ処理
'        IN               :
'        OUT              :
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub cmb_巡回担当者コード_AfterUpdate()
    Dim vCode   As Variant
    Dim vTanto  As Variant

    On Error GoTo cmb_巡回担当者コード_AfterUpdate_Err

    vCode = Nz(Trim(Me.cmb_巡回担当者コード), "")
    If vCode = "" Then
        Me.txt_巡回担当者コード = ""
        GoTo cmb_巡回担当者コード_AfterUpdate_End
    End If

    'ファイルへの存在チェック
    If GetTantoData(vCode, vTanto) = False Then GoTo cmb_巡回担当者コード_AfterUpdate_End

    Me.txt_巡回担当者コード = vTanto
    Me.cmb_巡回担当者コード = Format$(Me.cmb_巡回担当者コード, "000")

    GoTo cmb_巡回担当者コード_AfterUpdate_End

cmb_巡回担当者コード_AfterUpdate_Err:
    MsgBox "ｴﾗｰ番号" & Err.Number & vbCrLf & Err.Description
    Err.Clear

cmb_巡回担当者コード_AfterUpdate_End:
    Exit Sub

End Sub

'==============================================================================*
'
'        MODULE_NAME      :cmb_巡回担当コード_BeforeUpdate
'        機能             :巡回担当コード BeforeUpdateｲﾍﾞﾝﾄ処理
'        IN               :
'        OUT              :
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub cmb_巡回担当者コード_BeforeUpdate(Cancel As Integer)
    'ｺｰﾄﾞが空の場合担当者名欄も空欄表示
    If ControlCrear(Me.cmb_巡回担当者コード, Me.txt_巡回担当者コード) = False Then Exit Sub

    '選択された担当者データの存在チェック
    If GetTantoData(Nz(Me.cmb_巡回担当者コード, "")) = False Then
       MsgBox "登録されていません。", vbInformation, strMsg_err
       Cancel = True
       SendKeys "{ESC}"
    End If

End Sub

