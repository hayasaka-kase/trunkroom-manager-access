'==============================================================================*
'
'        MODULE_NAME      :コンテナマスタ削除処理
'        MODULE_ID        :fncDELKONT_MAST
'        Parameter        :objRsNYAR = コンテナマスタレコードセット
'        CREATE_DATE      :2005/11/08
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncDELKONT_MAST(ByRef objRsKONT As Recordset) As Boolean

    fncDELKONT_MAST = False

' 2005/12/06 ADD T.SUZUKI Start
    pstrKONT_DelData = ""  ' 初期化

    ' コンテナ削除データ文字列に格納
    Call subSetKONT_DEL_Data(pstrKONT_DelData, objRsKONT)

    ' コンテナマスタ削除データログ出力処理
    Call MSZZ003_M00(PROG_ID, 0, pstrKONT_DelData)
' 2005/12/06 ADD T.SUZUKI End

    ' コンテナマスタのデータ削除
    With objRsKONT
        .Edit
        .Delete
    End With

    fncDELKONT_MAST = True

fncDELKONT_MAST_Exit:
    Exit Function
End Function

'==============================================================================*
'
'        MODULE_NAME      :コンテナマスタ削除データ格納処理
'        MODULE_ID        :subSetKONT_DEL_Data
'        Parameter        :strDelData = コンテナマスタ削除データ格納文字列
'                          objRsKONT  = コンテナマスタレコードセット
'        CREATE_DATE      :2005/11/08
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub subSetKONT_DEL_Data(ByRef strDelData As String, ByVal objRsKONT As Recordset)

    Dim strWK As String

    ' 削除データを文字列に格納(最終的にログ出力)
    ' (ヤードコード・コンテナ番号)
    strWK = ""
    strWK = objRsKONT.Fields("CNTA_CODE") & " , " & objRsKONT.Fields("CNTA_NO")

    ' 削除データを文字列に格納(最終的にログ出力)
    If Nz(strDelData, "") <> "" Then
        strDelData = strDelData & vbCrLf & strWK
    Else
        strDelData = pcstrKONT_DEL & strWK
    End If
End Sub

