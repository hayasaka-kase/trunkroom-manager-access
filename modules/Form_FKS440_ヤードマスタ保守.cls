    Loop
    objRs.Close
    Set objRs = Nothing

    Set objSubForm = Nothing  ' 2005/10/24 ADD T.SUZUKI

    fncInputCheck = 0

    GoTo fncInputCheck_Exit

fncInputCheckErr_Exit:
    Select Case intCheckKbn
        Case 1  ' *** 必須 ***
            If intKbn = 0 Then                      ' 2005/11/21 ADD S.SHIBAZAKI
                Call cmd_Necessary_Click
            Else                                    ' 2005/11/21 ADD S.SHIBAZAKI
                Call cmd_NecessaryLow_Click         ' 2005/11/21 ADD S.SHIBAZAKI
            End If                                  ' 2005/11/21 ADD S.SHIBAZAKI
