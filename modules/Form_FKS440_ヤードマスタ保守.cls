'==============================================================================*
'
'        MODULE_NAME      :近隣ヤードマスタ更新
'        MODULE_ID        :WRI_NYAR_MAST
'        Parameter        :intMode intModeInsert = 新規
'                                  intModeUpdate = 修正
'                                  intModeDelete = 削除
'                          strYCODE              = ヤードコード
'                          pstrWORKData_NYAR_CODE= 近隣ヤードコード格納配列           'INSERT 2009/01/30 KIHARA
'                          intNYARCnt            = 近隣ヤードコード格納配列のデータ数 'INSERT 2009/01/30 KIHARA
'        CREATE_DATE      :2005/11/08
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
'2009/01/30 MOD START KIHARA 近隣更新ヤード、件数パラメータ追加
'Private Function WRI_NYAR_MAST(ByVal intMode As Integer, ByVal strYcode As String) As Boolean
Private Function WRI_NYAR_MAST(ByVal intMode As Integer, ByVal strYcode As String, pstrWORKData_NYAR_CODE As Variant, intNYARCnt As Integer) As Boolean
'2009/01/30 MOD END KIHARA

    Dim strSQL         As String
    Dim objRsWk        As Recordset  ' ワークテーブルレコードセット
    Dim objRsNYAR      As Recordset  ' 近隣ヤードマスタレコードセット

    Dim strWorkKey     As String     ' ワークテーブル.ヤードコード   + ワークテーブル.近隣ヤードコード
    Dim strNyarKey     As String     ' 近隣ヤードマスタ.ヤードコード + 近隣ヤードマスタ.近隣ヤードコード
    Dim intWKCount     As Integer    ' ワークテーブルのデータ数
    Dim intCount       As Integer    ' カウンター
    Dim blnWKInsFlg    As Boolean    ' 近隣ヤードマスタ登録フラグ                  '2009/01/30 ADD KIHARA
    Dim intWKCount2    As Integer    ' ワークテーブルのデータ数                    '2009/01/30 ADD KIHARA

    WRI_NYAR_MAST = False

    intWKCount = 0  ' 2005/11/30 ADD T.SUZUKI
    intWKCount2 = 0 ' 2009/01/30 ADD KIHARA
    intNYARCnt = 0  ' 2009/01/30 ADD KIHARA

    ' 修正モードまたは削除モードの場合、近隣ヤードマスタのデータを抽出
    If (intMode = intModeUpdate Or intMode = intModeDelete) Then
        ' 近隣ヤードマスタよりデータ抽出
        strSQL = ""
        strSQL = strSQL & " SELECT NYAR_YCODE, " & Chr(13)  ' ヤードコード
        strSQL = strSQL & "        NYAR_NCODE, " & Chr(13)  ' 近隣ヤードコード
        strSQL = strSQL & "        NYAR_INSED, " & Chr(13)  ' 作成日付
        strSQL = strSQL & "        NYAR_INSEJ, " & Chr(13)  ' 作成時刻
        strSQL = strSQL & "        NYAR_INSPB, " & Chr(13)  ' 作成プログラムＩＤ
        strSQL = strSQL & "        NYAR_INSUB, " & Chr(13)  ' 作成ユーザーＩＤ
        
        strSQL = strSQL & "        NYAR_UPDAD, " & Chr(13)  ' 更新日付          'INSERT 2006/03/27 K.ISHIZAKA
        strSQL = strSQL & "        NYAR_UPDAJ, " & Chr(13)  ' 更新時刻          'INSERT 2006/03/27 K.ISHIZAKA
        strSQL = strSQL & "        NYAR_UPDPB, " & Chr(13)  ' 更新プログラムＩＤ'INSERT 2006/03/27 K.ISHIZAKA
        strSQL = strSQL & "        NYAR_UPDUB, " & Chr(13)  ' 更新ユーザーＩＤ  'INSERT 2006/03/27 K.ISHIZAKA
        strSQL = strSQL & "        NYAR_KIRO   " & Chr(13)  ' 距離              'INSERT 2006/03/27 K.ISHIZAKA
        
        strSQL = strSQL & "   FROM NYAR_MAST " & Chr(13)
        strSQL = strSQL & "  WHERE (NYAR_YCODE = " & strYcode & Chr(13)
        strSQL = strSQL & "     OR  NYAR_NCODE = " & strYcode & ") " & Chr(13)
    
        If intMode <> intModeDelete Then
            ' 新規または更新時は自ヤード以外を対象とする
            strSQL = strSQL & "    AND (NYAR_YCODE <> NYAR_NCODE) " & Chr(13)  ' → 自ヤード以外
        End If
    
        strSQL = strSQL & "  ORDER BY NYAR_YCODE, " & Chr(13)
        strSQL = strSQL & "           NYAR_NCODE "
        Set objRsNYAR = pobjKONT_DB.OpenRecordset(strSQL, dbOpenDynaset)
    End If

    ' 削除モード時以外の場合、ワークテーブルのデータを抽出
    If intMode <> intModeDelete Then
        ' ワークテーブルのデータ抽出
        ' (※画面上で削除された近隣ヤードデータの近隣ヤードコードは｢0｣で残る)
        strSQL = ""
        strSQL = strSQL & " SELECT NYAR_YCODE, " & Chr(13)  ' ヤードコード
        strSQL = strSQL & "        NYAR_NCODE, " & Chr(13)  ' 近隣ヤードコード
        strSQL = strSQL & "        NYAR_KIRO " & Chr(13)    ' 距離              'INSERT 2006/03/27 K.ISHIZAKA
        strSQL = strSQL & "   FROM FKS440_W01 " & Chr(13)
        strSQL = strSQL & "  WHERE NYAR_NCODE <> 0 " & Chr(13)
        strSQL = strSQL & "    AND (NYAR_YCODE <> NYAR_NCODE) " & Chr(13)  ' → 自ヤード以外
        strSQL = strSQL & " UNION ALL " & Chr(13)
        strSQL = strSQL & " SELECT NYAR_NCODE, " & Chr(13)  ' 近隣ヤードコード
        strSQL = strSQL & "        NYAR_YCODE, " & Chr(13)  ' ヤードコード
        strSQL = strSQL & "        NYAR_KIRO " & Chr(13)    ' 距離              'INSERT 2006/03/27 K.ISHIZAKA
        strSQL = strSQL & "   FROM FKS440_W01 " & Chr(13)
        strSQL = strSQL & "  WHERE NYAR_NCODE <> 0 " & Chr(13)  ' 削除データ以外
        strSQL = strSQL & "    AND (NYAR_YCODE <> NYAR_NCODE) " & Chr(13)  ' → 自ヤード以外
        strSQL = strSQL & " ORDER BY 1, 2 "
        Set objRsWk = WRI_objDb.OpenRecordset(strSQL, dbReadOnly)
    End If
    '▼▼2009/01/30 Start hirano 近隣情報初期化
    Erase pstrWORKData_NYAR_CODE  ' 配列の解放
    blnNyarDateUpdFlg = False     ' 近隣ヤード日付登録フラグ
    blnWKInsFlg = False           ' ワークテーブルの近隣ヤードマスタ登録フラグ
    '▲▲2009/01/30 End hirano

    Select Case intMode
        Case intModeInsert  ' *** 新規 ****
            ' 近隣ヤードマスタよりデータ抽出
            strSQL = ""
            strSQL = "SELECT * FROM NYAR_MAST "
            Set objRsNYAR = pobjKONT_DB.OpenRecordset(strSQL, dbOpenDynaset)

            If intMode = intModeInsert Then
                ' 新規登録時、自ヤードの登録
'                If fncINSNYAR_MAST(objRsNYAR, strYCODE, strYCODE) = False Then Exit Function       'DELETE 2006/03/27 K.ISHIZAKA
                If fncINSNYAR_MAST(objRsNYAR, strYcode, strYcode, "0") = False Then Exit Function   'INSERT 2006/03/27 K.ISHIZAKA
            End If

            With objRsWk
                ' ワークのデータ登録
                Do Until .EOF
'                    If fncINSNYAR_MAST(objRsNYAR, objRsWk.Fields("NYAR_YCODE"), objRsWk.Fields("NYAR_NCODE")) = False Then Exit Function   'DELETE 2006/03/27 K.ISHIZAKA
                    If fncINSNYAR_MAST(objRsNYAR, objRsWk.Fields("NYAR_YCODE"), objRsWk.Fields("NYAR_NCODE"), Nz(objRsWk.Fields("NYAR_KIRO"))) = False Then Exit Function   'INSERT 2006/03/27 K.ISHIZAKA
                    '▼▼2009/01/30 ADD Start hirano INSERT後,近隣配列格納
                    If Val(strYcode) <> objRsWk.Fields("NYAR_NCODE") Then
                        ReDim Preserve pstrWORKData_NYAR_CODE(intWKCount2)
                        pstrWORKData_NYAR_CODE(intWKCount2) = Format$(CLng(objRsWk.Fields("NYAR_NCODE")), "######") ' 近隣ヤードコード
                        intWKCount2 = intWKCount2 + 1
                    End If
                    '▲▲2009/01/30 ADD End hirano
                    .MoveNext
                Loop
            End With

            '▼▼2009/01/30 ADD Start hirano 件数をパラメータへセット
            intNYARCnt = intWKCount2
            '▲▲2009/01/30 ADD End hirano
        Case intModeUpdate  ' *** 修正 ***
            ' 対象データ数分処理を行う
            strWorkKey = ""
            strNyarKey = ""
            Do Until (objRsWk.EOF And objRsNYAR.EOF)
                ' ワークテーブルのキー作成
                If objRsWk.EOF = True Then
                    strWorkKey = pcstrKeyCode
                Else
                    strWorkKey = Format(objRsWk.Fields("NYAR_YCODE"), "000000") & Format(objRsWk.Fields("NYAR_NCODE"), "000000")
                End If

                ' 近隣ヤードマスタのキー作成
                If objRsNYAR.EOF = True Then
                    strNyarKey = pcstrKeyCode
                Else
                    strNyarKey = Format(objRsNYAR.Fields("NYAR_YCODE"), "000000") & Format(objRsNYAR.Fields("NYAR_NCODE"), "000000")
                End If

                ' ワークテーブルと近隣ヤードマスタのデータ比較
                If strWorkKey = strNyarKey Then
                    ' ワークテーブルのデータと近隣ヤードマスタのデータが一致する場合
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
                    With objRsNYAR                                              'INSERT 2006/03/27 K.ISHIZAKA
                        .Edit                                                   'INSERT 2006/03/27 K.ISHIZAKA
                        .Fields("NYAR_UPDAD") = Format$(DATE, "yyyymmdd")       ' 更新日付          'INSERT 2006/03/27 K.ISHIZAKA
                        .Fields("NYAR_UPDAJ") = Format$(time, "hhmmss")         ' 更新時刻          'INSERT 2006/03/27 K.ISHIZAKA
                        .Fields("NYAR_UPDPB") = PROG_ID                         ' 更新プログラムＩＤ'INSERT 2006/03/27 K.ISHIZAKA
                        .Fields("NYAR_UPDUB") = MSZZ000.LsGetUserName()         ' 更新ユーザーＩＤ  'INSERT 2006/03/27 K.ISHIZAKA
                        .Fields("NYAR_KIRO") = objRsWk.Fields("NYAR_KIRO")      ' 距離              'INSERT 2006/03/27 K.ISHIZAKA
                        objRsNYAR.UPDATE                                        'INSERT 2006/03/27 K.ISHIZAKA
                    End With                                                    'INSERT 2006/03/27 K.ISHIZAKA
                    ' → 次レコードの処理を行う
                    objRsWk.MoveNext    ' ワークテーブル
                    objRsNYAR.MoveNext  ' 近隣ヤードマスタ

                ElseIf strWorkKey < strNyarKey Then
                    ' ワークテーブルのデータが近隣ヤードマスタに存在しない場合
                    ' → ワークテーブルのデータを近隣ヤードマスタに登録

                    ' 配列にワークテーブルのデータをセット
'                    ReDim Preserve pstrWORKData(1, intWKCount)                 'DELETE 2006/03/27 K.ISHIZAKA
                    ReDim Preserve pstrWORKData(2, intWKCount)                  'INSERT 2006/03/27 K.ISHIZAKA
                    pstrWORKData(0, intWKCount) = objRsWk.Fields("NYAR_YCODE")  ' ヤードコード
                    pstrWORKData(1, intWKCount) = objRsWk.Fields("NYAR_NCODE")  ' 近隣ヤードコード
                    pstrWORKData(2, intWKCount) = Nz(objRsWk.Fields("NYAR_KIRO")) 'INSERT 2006/03/27 K.ISHIZAKA
                    
                    ' 2009/01/30 INSERT START KIHARA
                    If Val(strYcode) <> objRsWk.Fields("NYAR_NCODE") Then
                        blnWKInsFlg = True
                        ReDim Preserve pstrWORKData_NYAR_CODE(intWKCount2)
                        pstrWORKData_NYAR_CODE(intWKCount2) = Format$(CLng(objRsWk.Fields("NYAR_NCODE")), "######") ' 近隣ヤードコード
                        intWKCount2 = intWKCount2 + 1
                    End If
                    ' 2009/01/30 INSERT END   KIHARA

                    intWKCount = intWKCount + 1  ' 登録用ワークテーブルデータ数カウントアップ

                    objRsWk.MoveNext    ' ワークテーブル

                ElseIf strWorkKey > strNyarKey Then
                    ' 近隣ヤードマスタのデータがワークテーブルに存在しない場合
                    '▼▼ 2009/01/30 ADD Start hirano
                    If strWorkKey = pcstrKeyCode Then 'ワークテーブルがレコードが無い場合
                        If Val(strYcode) <> objRsNYAR.Fields("NYAR_NCODE") Then
                            ReDim Preserve pstrWORKData_NYAR_CODE(intWKCount2)
                            pstrWORKData_NYAR_CODE(intWKCount2) = Format$(CLng(objRsNYAR.Fields("NYAR_NCODE")), "######") ' 近隣ヤードコード
                            intWKCount2 = intWKCount2 + 1
                        End If
                    Else
                        ' INSERT START 2009/01/30 KIHARA
                        If Val(strYcode) <> objRsWk.Fields("NYAR_NCODE") Then
                            ReDim Preserve pstrWORKData_NYAR_CODE(intWKCount2)
                            pstrWORKData_NYAR_CODE(intWKCount2) = Format$(CLng(objRsNYAR.Fields("NYAR_NCODE")), "######") ' 近隣ヤードコード
                            intWKCount2 = intWKCount2 + 1
                        End If
                        ' INSERT END   2009/01/30 KIHARA
                    End If
                    '▲▲ 2009/01/30 ADD End hirano
                    ' → 近隣ヤードマスタのデータを削除
                    If fncDELNYAR_MAST(objRsNYAR) = False Then Exit Function

                    objRsNYAR.MoveNext   ' 近隣ヤードマスタ
                End If
            Loop

            ' ワークテーブルのデータ作成
'            If intWKCount > 0 Then                             'DELETE 2009/01/30 KIHARA
             If intWKCount > 0 And blnWKInsFlg = True Then      'INSERT 2009/01/30 KIHARA
                For intCount = 0 To intWKCount - 1
                    ' ワークデーブルのデータを近隣ヤードマスタに登録
'                    If fncINSNYAR_MAST(objRsNYAR, pstrWORKData(0, intCount), pstrWORKData(1, intCount)) = False Then GoTo WRI_NYAR_MAST_Exit                           'DELETE 2006/03/27 K.ISHIZAKA
                    If fncINSNYAR_MAST(objRsNYAR, pstrWORKData(0, intCount), pstrWORKData(1, intCount), pstrWORKData(2, intCount)) = False Then GoTo WRI_NYAR_MAST_Exit 'INSERT 2006/03/27 K.ISHIZAKA
                Next intCount
            End If
            intNYARCnt = intWKCount2  'INSERT 2009/01/30 KIHARA
            
            ' 配列の解放
            Erase pstrWORKData
            blnNyarDateUpdFlg = True  'INSERT 2009/01/30 KIHARA
        Case intModeDelete  ' *** 削除 ***
            With objRsNYAR
                Do Until .EOF
                    ' INSERT START 2009/01/30 KIHARA
                    If Val(strYcode) <> objRsNYAR.Fields("NYAR_NCODE") Then
                        ReDim Preserve pstrWORKData_NYAR_CODE(intWKCount2)
                        pstrWORKData_NYAR_CODE(intWKCount2) = Format$(CLng(objRsNYAR.Fields("NYAR_NCODE")), "######") ' 近隣ヤードコード
                        intWKCount2 = intWKCount2 + 1
                    End If
                    ' INSERT END   2009/01/30 KIHARA
                    ' 近隣ヤードマスタのデータ全件削除
                    If fncDELNYAR_MAST(objRsNYAR) = False Then GoTo WRI_NYAR_MAST_Exit
                    .MoveNext
                Loop
                intNYARCnt = intWKCount2  'INSERT 2009/01/30 KIHARA
                blnNyarDateUpdFlg = True  'INSERT 2009/01/30 KIHARA
            End With
        
'            With objRsNYAR
'                Do Until .EOF
'                    ' 近隣ヤードマスタのデータ全件削除
'                    If fncDELNYAR_MAST(objRsNYAR) = False Then GoTo WRI_NYAR_MAST_Exit
'                    .MoveNext
'                Loop
'            End With
    End Select

    WRI_NYAR_MAST = True

WRI_NYAR_MAST_Exit:
    If Not objRsNYAR Is Nothing Then objRsNYAR.Close: Set objRsNYAR = Nothing
    If Not objRsWk Is Nothing Then objRsWk.Close: Set objRsWk = Nothing
    Exit Function
End Function

'==============================================================================*
'
'        MODULE_NAME      :近隣ヤードマスタ登録処理
'        MODULE_ID        :fncINSNYAR_MAST
'        Parameter        :objRsNYAR = 近隣ヤードマスタレコードセット
'                         :strYCODE  = ヤードコード
'                         :strNCODE  = 近隣ヤードコード
'                         :strKIRO   = 距離
'        CREATE_DATE      :2005/11/08
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
'Private Function fncINSNYAR_MAST(ByRef objRsNYAR As Recordset, ByVal strYCODE As String, ByVal strNCODE As String) As Boolean
Private Function fncINSNYAR_MAST(ByRef objRsNYAR As Recordset, ByVal strYcode As String, ByVal strNcode As String, ByVal strKIRO As String) As Boolean

    fncINSNYAR_MAST = False

    ' 近隣ヤードマスタにデータ登録
    With objRsNYAR
        .AddNew

        .Fields("NYAR_YCODE") = strYcode                    ' ヤードコード
        .Fields("NYAR_NCODE") = strNcode                    ' 近隣ヤードコード
        .Fields("NYAR_INSED") = Format$(DATE, "yyyymmdd")   ' 作成日付
        .Fields("NYAR_INSEJ") = Format$(time, "hhmmss")     ' 作成時刻
        .Fields("NYAR_INSPB") = PROG_ID                     ' 作成プログラムＩＤ
        .Fields("NYAR_INSUB") = MSZZ000.LsGetUserName       ' 作成ユーザーＩＤ
        If strKIRO <> "" Then
            .Fields("NYAR_KIRO") = CDbl(strKIRO)            ' 距離              'INSERT 2006/03/27 K.ISHIZAKA
        End If

        .UPDATE
    End With

    fncINSNYAR_MAST = True

fncINSNYAR_MAST_Exit:
    Exit Function
End Function

'==============================================================================*
'
'        MODULE_NAME      :近隣ヤードマスタ削除処理
'        MODULE_ID        :fncDELNYAR_MAST
'        Parameter        :objRsNYAR = 近隣ヤードマスタレコードセット
'        CREATE_DATE      :2005/11/08
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncDELNYAR_MAST(ByRef objRsNYAR As Recordset) As Boolean

    fncDELNYAR_MAST = False

    ' 近隣ヤードマスタのデータ削除
    With objRsNYAR
        .Edit
        .Delete
    End With

    fncDELNYAR_MAST = True

fncDELNYAR_MAST_Exit:
    Exit Function
End Function

'==============================================================================*
'
'        MODULE_NAME      :価格表テーブル更新
'        MODULE_ID        :WRI_PRIC_TABL
'        Parameter        :intMode intModeInsert = 新規
'                                  intModeUpdate = 修正
'                                  intModeDelete = 削除
'                          strYCODE              = ヤードコード
'        CREATE_DATE      :2005/11/21
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function WRI_PRIC_TABL(ByVal intMode As Integer, ByVal strYcode As String) As Boolean

    Dim strSQL      As String
    Dim objRsPRICE  As Recordset
    Dim objRsWk     As Recordset

    Dim strWorkKey  As String
    Dim strPriceKey As String

    Dim intCount    As Integer
    Dim intWKCount  As Integer

    WRI_PRIC_TABL = False

    intWKCount = 0         ' 2005/11/30 ADD T.SUZUKI

    ' 修正モードまたは削除モードの場合、価格表テーブルのデータを抽出
    If (intMode = intModeUpdate Or intMode = intModeDelete) Then
        ' 価格表テーブルよりデータ抽出
        strSQL = ""
        strSQL = " SELECT PRIC_YCODE, " & Chr(13)
        strSQL = strSQL & " PRIC_USAGE, " & Chr(13)
        strSQL = strSQL & " PRIC_SIZE, " & Chr(13)
        strSQL = strSQL & " PRIC_STEP, " & Chr(13)
        strSQL = strSQL & " PRIC_PRICE, " & Chr(13)
        strSQL = strSQL & " PRIC_FZAPPI_CODE, " & Chr(13)
        strSQL = strSQL & " PRIC_FZAPPI, " & Chr(13)
        ' INSERT START 2018/08/20 K.WADA
        strSQL = strSQL & " PRIC_FZAPPI_CODE2, " & Chr(13)
        strSQL = strSQL & " PRIC_FZAPPI2, " & Chr(13)
        ' INSERT END 2018/08/20 K.WADA
        strSQL = strSQL & " PRIC_EZAPPI_CODE, " & Chr(13)
        strSQL = strSQL & " PRIC_EZAPPI, " & Chr(13)
        strSQL = strSQL & " PRIC_INSED, " & Chr(13)
        strSQL = strSQL & " PRIC_INSEJ, " & Chr(13)
        strSQL = strSQL & " PRIC_INSPB, " & Chr(13)
        strSQL = strSQL & " PRIC_INSUB, " & Chr(13)
        strSQL = strSQL & " PRIC_UPDAD, " & Chr(13)
        strSQL = strSQL & " PRIC_UPDAT, " & Chr(13)
        strSQL = strSQL & " PRIC_UPDPB, " & Chr(13)
        strSQL = strSQL & " PRIC_NEBIKI_DISABLE, " & Chr(13)    ' 2008/10/15 ADD iizuka
        strSQL = strSQL & " PRIC_UPDUB " & Chr(13)
        strSQL = strSQL & "   FROM PRIC_TABL " & Chr(13)  ' *** 価格表テーブル ***
        strSQL = strSQL & "  WHERE PRIC_YCODE = " & strYcode & Chr(13)  ' ヤードコード
        strSQL = strSQL & "  ORDER BY PRIC_STEP, " & Chr(13)
        strSQL = strSQL & "           PRIC_USAGE, " & Chr(13)
        strSQL = strSQL & "           PRIC_SIZE "
        Set objRsPRICE = pobjKONT_DB.OpenRecordset(strSQL, dbOpenDynaset)
    End If

    ' 削除モード時以外の場合、ワークテーブルのデータを抽出
    If intMode <> intModeDelete Then
        ' ワークテーブルのデータ抽出
        strSQL = ""
        strSQL = strSQL & " SELECT PRIC_YCODE, " & Chr(13)        ' ヤードコード
        strSQL = strSQL & "        PRIC_USAGE, " & Chr(13)        ' 使用用途
        strSQL = strSQL & "        PRIC_SIZE, " & Chr(13)         ' 実帖
        strSQL = strSQL & "        PRIC_STEP, " & Chr(13)         ' 段区分
        strSQL = strSQL & "        PRIC_PRICE, " & Chr(13)        ' プライス
        strSQL = strSQL & "        PRIC_NEBIKI_DISABLE, " & Chr(13) ' 割引対象外  ' 2008/10/15 ADD iizuka
        strSQL = strSQL & "        PRIC_FZAPPI_CODE, " & Chr(13)  ' 初回雑費コード
        strSQL = strSQL & "        PRIC_FZAPPI, " & Chr(13)       ' 初回雑費
        ' INSERT START 2018/08/20 K.WADA
        strSQL = strSQL & "        PRIC_FZAPPI_CODE2, " & Chr(13)  ' 初回雑費コード2
        strSQL = strSQL & "        PRIC_FZAPPI2, " & Chr(13)       ' 初回雑費2
        ' INSERT END 2018/08/20 K.WADA
        strSQL = strSQL & "        PRIC_EZAPPI_CODE, " & Chr(13)  ' 毎月雑費コード
        strSQL = strSQL & "        PRIC_EZAPPI " & Chr(13)        ' 毎月雑費
        strSQL = strSQL & "   FROM FKS440_W02 " & Chr(13)
        strSQL = strSQL & "  WHERE PRIC_YCODE = " & strYcode & Chr(13)
        strSQL = strSQL & "  ORDER BY PRIC_STEP, " & Chr(13)
        strSQL = strSQL & "           PRIC_USAGE, " & Chr(13)
        strSQL = strSQL & "           PRIC_SIZE "
        Set objRsWk = WRI_objDb.OpenRecordset(strSQL, dbReadOnly)
    End If

    Select Case intMode
        Case intModeInsert  ' *** 新規 ****
            ' 価格表テーブルよりデータ抽出
            strSQL = ""
            strSQL = "SELECT * FROM PRIC_TABL "
            Set objRsPRICE = pobjKONT_DB.OpenRecordset(strSQL, dbOpenDynaset)

            Do Until objRsWk.EOF
                ' 価格表テーブル登録
                If fncINSPRICE_TABL(intModeInsert, objRsPRICE, objRsWk) = False Then GoTo WRI_PRIC_TABL_Exit

                objRsWk.MoveNext
            Loop

        Case intModeUpdate  ' *** 修正 ****
            ' 対象データ数分処理を行う
            strWorkKey = ""
            strPriceKey = ""
            Do Until (objRsWk.EOF And objRsPRICE.EOF)
                ' ワークテーブルのキー作成
                If objRsWk.EOF = True Then
                    strWorkKey = pcstrKeyCodePC
                Else
                    strWorkKey = Format(objRsWk.Fields("PRIC_YCODE"), "000000") & Format(objRsWk.Fields("PRIC_STEP"), "0") & _
                                 Format(objRsWk.Fields("PRIC_USAGE"), "00") & Format(objRsWk.Fields("PRIC_SIZE"), "000.00")
                End If

                ' 価格表テーブルのキー作成
                If objRsPRICE.EOF = True Then
                    strPriceKey = pcstrKeyCodePC
                Else
                    strPriceKey = Format(objRsPRICE.Fields("PRIC_YCODE"), "000000") & Format(objRsPRICE.Fields("PRIC_STEP"), "0") & _
                                  Format(objRsPRICE.Fields("PRIC_USAGE"), "00") & Format(objRsPRICE.Fields("PRIC_SIZE"), "000.00")
                End If

                ' ワークテーブルと価格表テーブルのデータ比較
                If strWorkKey = strPriceKey Then
                    ' ワークテーブルのデータと価格表テーブルのデータが一致する場合
                    ' コンテナマスタ登録処理(更新)
                    If fncINSPRICE_TABL(intModeUpdate, objRsPRICE, objRsWk) = False Then GoTo WRI_PRIC_TABL_Exit

                    ' → 次レコードの処理を行う
                    objRsWk.MoveNext     ' ワークテーブル
                    objRsPRICE.MoveNext  ' 価格表テーブル

                ElseIf strWorkKey < strPriceKey Then
                    ' ワークテーブルのデータが価格表テーブルに存在しない場合
                    ' → ワークテーブルのデータを価格表テーブルに登録

                    ' 配列にワークテーブルのデータをセット
                    'ReDim Preserve pvarKONTData(8, intWKCount)     ' 2008/10/15 DEL iizuka
                    'ReDim Preserve pvarKONTData(9, intWKCount)     ' 2008/10/15 chg iizuka →ReDim Preserve pvarKONTData(8, intWKCount) ' 2018/08/20 DEL K.WADA
                    ReDim Preserve pvarKONTData(11, intWKCount)     ' 2018/08/20 ADD K.WADA
                    pvarKONTData(0, intWKCount) = objRsWk.Fields("PRIC_YCODE")        ' ヤードコード
                    pvarKONTData(1, intWKCount) = objRsWk.Fields("PRIC_USAGE")        ' 使用用途
                    pvarKONTData(2, intWKCount) = objRsWk.Fields("PRIC_SIZE")         ' 実帖
                    pvarKONTData(3, intWKCount) = objRsWk.Fields("PRIC_STEP")         ' 段区分
                    pvarKONTData(4, intWKCount) = objRsWk.Fields("PRIC_PRICE")        ' プライス
                    pvarKONTData(5, intWKCount) = objRsWk.Fields("PRIC_FZAPPI_CODE")  ' 初回雑費コード
                    pvarKONTData(6, intWKCount) = objRsWk.Fields("PRIC_FZAPPI")       ' 初回雑費
                    ' INSERT START 2018/08/20 K.WADA
                    pvarKONTData(7, intWKCount) = objRsWk.Fields("PRIC_FZAPPI_CODE2")  ' 初回雑費コード2
                    pvarKONTData(8, intWKCount) = objRsWk.Fields("PRIC_FZAPPI2")       ' 初回雑費2
                    pvarKONTData(9, intWKCount) = objRsWk.Fields("PRIC_EZAPPI_CODE")  ' 毎月雑費コード
                    pvarKONTData(10, intWKCount) = objRsWk.Fields("PRIC_EZAPPI")       ' 毎月雑費
                    pvarKONTData(11, intWKCount) = IIf(objRsWk.Fields("PRIC_NEBIKI_DISABLE"), 1, 0)  ' 割引対象ﾌﾗｸﾞ
                    ' INSERT END 2018/08/20 K.WADA
                    ' DELETE START 2018/08/20 K.WADA
                    'pvarKONTData(7, intWKCount) = objRsWk.Fields("PRIC_EZAPPI_CODE")  ' 毎月雑費コード
                    'pvarKONTData(8, intWKCount) = objRsWk.Fields("PRIC_EZAPPI")       ' 毎月雑費
                    'pvarKONTData(9, intWKCount) = IIf(objRsWk.Fields("PRIC_NEBIKI_DISABLE"), 1, 0)  ' 割引対象ﾌﾗｸﾞ  '2008/10/15 add iizuka
                    ' DELETE END 2018/08/20 K.WADA

                    intWKCount = intWKCount + 1  ' 登録用ワークテーブルデータ数カウントアップ

                    objRsWk.MoveNext    ' ワークテーブル

                ElseIf strWorkKey > strPriceKey Then
                    ' 価格表テーブルのデータがワークテーブルに存在しない場合
                    ' → 価格表テーブルのデータを削除
                    If fncDELPRICE_TABL(objRsPRICE) = False Then Exit Function

                    objRsPRICE.MoveNext   ' 価格表テーブル
                End If
            Loop

            ' ワークテーブルのデータ作成
            If intWKCount > 0 Then
                For intCount = 0 To intWKCount - 1
                    ' ワークデーブルのデータを近隣ヤードマスタに登録
                    If fncINSPRICE_TABL(intModeInsert, objRsPRICE, , pvarKONTData(), intCount) = False Then GoTo WRI_PRIC_TABL_Exit
                Next intCount
            End If

            ' 配列の解放
            Erase pvarKONTData   ' 2005/11/30 ADD T.SUZUKI
'            Erase pstrWORKData  ' 2005/11/30 DEL T.SUZUKI

        Case intModeDelete  ' *** 削除 ****
            Do Until objRsPRICE.EOF
                ' 価格表テーブル削除
                ' → 価格表テーブルのデータを削除
                If fncDELPRICE_TABL(objRsPRICE) = False Then Exit Function

                objRsPRICE.MoveNext
            Loop
    End Select

' とりあえずコメント
'' 2005/12/06 ADD T.SUZUKI Start
'    If Nz(pstrPRIC_DelData, "") <> "" Then
'        ' 価格表テーブル削除データログ出力処理
'        Call MSZZ003_M00(PROG_ID, 0, pstrPRIC_DelData)
'        pstrPRIC_DelData = ""
'    End If
'' 2005/12/06 ADD T.SUZUKI End
' とりあえずコメント

    WRI_PRIC_TABL = True

WRI_PRIC_TABL_Exit:
    If Not objRsPRICE Is Nothing Then objRsPRICE.Close: Set objRsPRICE = Nothing
    If Not objRsWk Is Nothing Then objRsWk.Close: Set objRsWk = Nothing
    Exit Function
End Function

'==============================================================================*
'
'        MODULE_NAME      :価格表テーブル登録処理
'        MODULE_ID        :fncINSPRICE_TABL
'        Parameter        :intMode intModeInsert = 新規
'                                  intModeUpdate = 修正
'                                  intModeDelete = 削除
'                          objRsPRICE   = 価格表テーブルレコードセット
'                          objRsWK      = ワークテーブルレコードセット
'                          varPRICEDATA = ワークテーブルデータ格納配列
'                          intDataPlace = 配列のカレントデータ位置
'        CREATE_DATE      :2005/11/21
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncINSPRICE_TABL(ByVal intMode As Integer, ByRef objRsPRICE As Recordset, _
                                  Optional ByRef objRsWk As Recordset = Nothing, _
                                  Optional ByRef varPRICEDATA As Variant = Null, _
                                  Optional intDataPlace As Integer = 0) As Boolean

    fncINSPRICE_TABL = False

    ' 価格表テーブルにデータ登録
    With objRsPRICE
        Select Case intMode
            Case intModeInsert  ' *** Insert ***
                .AddNew

            Case intModeUpdate  ' *** Update ***
                .Edit
        End Select

        If Not objRsWk Is Nothing Then
            .Fields("PRIC_YCODE") = objRsWk.Fields("PRIC_YCODE")                              ' ﾔｰﾄﾞｺｰﾄﾞ
            .Fields("PRIC_USAGE") = objRsWk.Fields("PRIC_USAGE")                              ' 使用用途
            .Fields("PRIC_SIZE") = objRsWk.Fields("PRIC_SIZE")                                ' 実帖
            .Fields("PRIC_STEP") = Nz(objRsWk.Fields("PRIC_STEP"), 0)                         ' 段区分
            .Fields("PRIC_PRICE") = Nz(objRsWk.Fields("PRIC_PRICE"), 0)                       ' プライス
            .Fields("PRIC_FZAPPI_CODE") = objRsWk.Fields("PRIC_FZAPPI_CODE")                  ' 初回雑費コード
            .Fields("PRIC_FZAPPI") = objRsWk.Fields("PRIC_FZAPPI")                            ' 初回雑費
            ' INSERT START 2018/08/20 K.WADA
            .Fields("PRIC_FZAPPI_CODE2") = objRsWk.Fields("PRIC_FZAPPI_CODE2")                ' 初回雑費コード2
            .Fields("PRIC_FZAPPI2") = objRsWk.Fields("PRIC_FZAPPI2")                          ' 初回雑費2
            ' INSERT END 2018/08/20 K.WADA
            .Fields("PRIC_EZAPPI_CODE") = objRsWk.Fields("PRIC_EZAPPI_CODE")                  ' 毎月雑費コード
            .Fields("PRIC_EZAPPI") = objRsWk.Fields("PRIC_EZAPPI")                            ' 毎月雑費
            .Fields("PRIC_NEBIKI_DISABLE") = IIf(objRsWk.Fields("PRIC_NEBIKI_DISABLE"), 1, 0) ' 割引対象ﾌﾗｸﾞ  '2008/10/15 add iizuka

        Else
            .Fields("PRIC_YCODE") = varPRICEDATA(0, intDataPlace)                             ' ﾔｰﾄﾞｺｰﾄﾞ
            .Fields("PRIC_USAGE") = varPRICEDATA(1, intDataPlace)                             ' 使用用途
            .Fields("PRIC_SIZE") = varPRICEDATA(2, intDataPlace)                              ' 実帖
            .Fields("PRIC_STEP") = varPRICEDATA(3, intDataPlace)                              ' 段区分
            .Fields("PRIC_PRICE") = varPRICEDATA(4, intDataPlace)                             ' プライス
            .Fields("PRIC_FZAPPI_CODE") = varPRICEDATA(5, intDataPlace)                       ' 初回雑費コード
            .Fields("PRIC_FZAPPI") = varPRICEDATA(6, intDataPlace)                            ' 初回雑費
            ' INSERT START 2018/08/20 K.WADA
            .Fields("PRIC_FZAPPI_CODE2") = varPRICEDATA(7, intDataPlace)                      ' 初回雑費コード2
            .Fields("PRIC_FZAPPI2") = varPRICEDATA(8, intDataPlace)                           ' 初回雑費2
            .Fields("PRIC_EZAPPI_CODE") = varPRICEDATA(9, intDataPlace)                       ' 毎月雑費コード
            .Fields("PRIC_EZAPPI") = varPRICEDATA(10, intDataPlace)                           ' 毎月雑費
            .Fields("PRIC_NEBIKI_DISABLE") = varPRICEDATA(11, intDataPlace)                   ' 割引対象ﾌﾗｸﾞ
            ' INSERT END 2018/08/20 K.WADA
            ' DELETE START 2018/08/20 K.WADA
            '.Fields("PRIC_EZAPPI_CODE") = varPRICEDATA(7, intDataPlace)                       ' 毎月雑費コード
            '.Fields("PRIC_EZAPPI") = varPRICEDATA(8, intDataPlace)                            ' 毎月雑費
            '.Fields("PRIC_NEBIKI_DISABLE") = varPRICEDATA(9, intDataPlace)                    ' 割引対象ﾌﾗｸﾞ  '2008/10/15 add iizuka
            ' DELETE END 2018/08/20 K.WADA
        End If

        Select Case intMode
            Case intModeInsert  ' *** 新規 ***
                .Fields("PRIC_INSED") = Format$(DATE, "yyyymmdd")                             ' 作成日付
                .Fields("PRIC_INSEJ") = Format$(time, "hhmmss")                               ' 作成時刻
                .Fields("PRIC_INSPB") = PROG_ID                                               ' 作成プログラムID
                .Fields("PRIC_INSUB") = MSZZ000.LsGetUserName                                 ' 作成ユーザーID

            Case intModeUpdate  ' *** 更新時 ***
                .Fields("PRIC_UPDAD") = Format$(DATE, "yyyymmdd")                             ' 更新日付
                .Fields("PRIC_UPDAT") = Format$(time, "hhmmss")                               ' 更新時刻
                .Fields("PRIC_UPDPB") = PROG_ID                                               ' 更新プログラムID
                .Fields("PRIC_UPDUB") = MSZZ000.LsGetUserName                                 ' 更新ユーザーID
        End Select
        
        .UPDATE
    End With

    fncINSPRICE_TABL = True

fncINSPRICE_TABL_Exit:
    Exit Function
End Function

'==============================================================================*
'
'        MODULE_NAME      :価格表テーブル削除処理
'        MODULE_ID        :fncDELPRICE_TABL
'        Parameter        :objRsPRICE = 価格表テーブルレコードセット
'        CREATE_DATE      :2005/11/08
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncDELPRICE_TABL(ByRef objRsPRICE As Recordset) As Boolean

    fncDELPRICE_TABL = False

' 2005/12/06 ADD T.SUZUKI Start
    pstrPRIC_DelData = ""

    ' コンテナ削除データ文字列に格納
    Call subSetPRIC_DEL_Data(pstrPRIC_DelData, objRsPRICE)

    ' 価格表テーブル削除データログ出力処理
    Call MSZZ003_M00(PROG_ID, 0, pstrPRIC_DelData)
' 2005/12/06 ADD T.SUZUKI End

    ' コンテナマスタのデータ削除
    With objRsPRICE
        .Edit
        .Delete
    End With

    fncDELPRICE_TABL = True

fncDELPRICE_TABL_Exit:
    Exit Function
End Function

'==============================================================================*
'
'        MODULE_NAME      :価格表テーブル削除データ格納処理
'        MODULE_ID        :subSetPRIC_DEL_Data
'        Parameter        :strDelData = 価格表テーブル削除データ格納文字列
'                          objRsPRIC  = 価格表テーブルレコードセット
'        CREATE_DATE      :2005/12/06
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub subSetPRIC_DEL_Data(ByRef strDelData As String, ByVal objRsPRIC As Recordset)

    Dim strWK As String  ' ワーク文字列格納変数

    ' 削除データを文字列に格納(最終的にログ出力)
    ' (ヤードコード・使用用途・実帖・段区分)
    strWK = ""
    strWK = objRsPRIC.Fields("PRIC_YCODE") & " , " & _
            objRsPRIC.Fields("PRIC_USAGE") & " , " & _
            objRsPRIC.Fields("PRIC_SIZE") & " , " & _
            objRsPRIC.Fields("PRIC_STEP")

    If Nz(strDelData, "") <> "" Then
        strDelData = strDelData & vbCrLf & strWK
    Else
        strDelData = pcstrPRIC_DEL & strWK
    End If
End Sub

'==============================================================================*
'
'        MODULE_NAME      :ボタンの切り替え
'        MODULE_ID        :s_bottunset
'        CREATE_DATE      :
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function s_bottunset(intMode As Integer)

    If intMode <> intModeDelete Then
        Me.cmd_保存.Enabled = True
        Me.cmd_削除.Enabled = False
    Else
        Me.cmd_保存.Enabled = False
        Me.cmd_削除.Enabled = True
    End If
    
    If intMode = intModeUpdate Then
        Me.cmd_Excel.Enabled = True
    Else
        Me.cmd_Excel.Enabled = False
    End If
    
    If pcIsFKS441Authority Then Me.cmd_保存.Enabled = False '2008/06/06 add tajima
    
    '↓2018/11/14 EGL.t
    'If txt_解除番号権限.VALUE <> "1" Then                                      'DELETE 2019/01/16 N.IMAI
    If txt_解除番号権限.VALUE <> "1" And txt_解除番号権限.VALUE <> "4" Then     'INSERT 2019/01/16 N.IMAI
        Me.cmd_保存.Enabled = False
        Me.cmd_削除.Enabled = False
        Me.cmd_Excel.Enabled = False
    End If
    '↑2018/11/14 EGL.t
    
End Function

