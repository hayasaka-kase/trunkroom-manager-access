'☆関数追加ここから↓
'==============================================================================*
'
'        MODULE_NAME      :価格表ワークテーブル作成
'        MODULE_ID        :MakePriceWork
'        CREATE_DATE      :
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function MakePriceWork(dbAccess As Database) As Boolean
On Error GoTo err_rtn

    Dim rsPrice     As Recordset    '価格表テーブルRS
    Dim rsWork      As Recordset    'ワークテーブルRS
    
    MakePriceWork = False
    
    '価格表テーブル既存データ読み込み（条件：ヤードコード）
    Set rsPrice = pobjKONT_DB.OpenRecordset(MakePriceSql(), dbOpenSnapshot, dbSQLPassThrough)

    '追加する先となるワークテーブル
    Set rsWork = objDb.OpenRecordset("SELECT * FROM FKS440_W02 ")

    '価格表テーブルのデータをワークテーブルに追加
    Do Until rsPrice.EOF
        Call InsertPriceWork(rsPrice, rsWork)
        rsPrice.MoveNext
    Loop

    MakePriceWork = True
    GoTo Exit_rtn

err_rtn:
    MsgBox "ｴﾗｰ番号" & Err.Number & vbCrLf & Err.Description
    Err.Clear

Exit_rtn:
    If Not rsPrice Is Nothing Then rsPrice.Close: Set rsPrice = Nothing
    If Not rsWork Is Nothing Then rsWork.Close: Set rsWork = Nothing
End Function

'==============================================================================*
'
'        MODULE_NAME      :価格表テーブル検索SQL作成
'        MODULE_ID        :MakePriceSql
'        CREATE_DATE      :
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function MakePriceSql() As String

    Dim strSQL      As String

    strSQL = strSQL & " SELECT PRIC_YCODE, "
    strSQL = strSQL & "        PRIC_USAGE, "
    strSQL = strSQL & "        PRIC_SIZE, "
    strSQL = strSQL & "        PRIC_STEP, "
    strSQL = strSQL & "        PRIC_PRICE, "
    strSQL = strSQL & "        PRIC_FZAPPI_CODE, "
    strSQL = strSQL & "        PRIC_FZAPPI, "
    ' INSERT START 2018/08/20 K.WADA
    strSQL = strSQL & "        PRIC_FZAPPI_CODE2, "
    strSQL = strSQL & "        PRIC_FZAPPI2, "
    ' INSERT END 2018/08/20 K.WADA
    strSQL = strSQL & "        PRIC_EZAPPI_CODE, "
    strSQL = strSQL & "        PRIC_NEBIKI_DISABLE, "           '2008/10/15 add iizuka
    strSQL = strSQL & "        PRIC_EZAPPI "
    strSQL = strSQL & "   FROM PRIC_TABL "
    strSQL = strSQL & "  WHERE PRIC_YCODE = '" & Me.cmb_ヤードコード & "' "
' 2005/11/21 ADD T.SUZUKI Start
    strSQL = strSQL & "  ORDER BY PRIC_STEP, "
    strSQL = strSQL & "           PRIC_USAGE, "
    strSQL = strSQL & "           PRIC_SIZE "
' 2005/11/21 ADD T.SUZUKI End

    MakePriceSql = strSQL
End Function

'==============================================================================*
'
'        MODULE_NAME      :価格表ワークテーブルデータ追加
'        MODULE_ID        :MakePriceSql
'        CREATE_DATE      :
'
'        PARMS            :第一引数　価格表テーブルレコードセット
'                         :第二引数　ワークテーブルレコードセット
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Sub InsertPriceWork(rsPriceTbl As Recordset, rsWorkTbl As Recordset)

    With rsWorkTbl
        .AddNew

        .Fields("PRIC_YCODE") = rsPriceTbl.Fields("PRIC_YCODE")
        .Fields("PRIC_USAGE") = rsPriceTbl.Fields("PRIC_USAGE")
        .Fields("PRIC_SIZE") = rsPriceTbl.Fields("PRIC_SIZE")
        .Fields("PRIC_STEP") = rsPriceTbl.Fields("PRIC_STEP")
        .Fields("PRIC_PRICE") = rsPriceTbl.Fields("PRIC_PRICE")
        .Fields("PRIC_FZAPPI_CODE") = rsPriceTbl.Fields("PRIC_FZAPPI_CODE")
        .Fields("PRIC_FZAPPI") = rsPriceTbl.Fields("PRIC_FZAPPI")
        ' INSERT START 2018/08/20 K.WADA
        .Fields("PRIC_FZAPPI_CODE2") = rsPriceTbl.Fields("PRIC_FZAPPI_CODE2")
        .Fields("PRIC_FZAPPI2") = rsPriceTbl.Fields("PRIC_FZAPPI2")
        ' INSERT END 2018/08/20 K.WADA
        .Fields("PRIC_EZAPPI_CODE") = rsPriceTbl.Fields("PRIC_EZAPPI_CODE")
        .Fields("PRIC_EZAPPI") = rsPriceTbl.Fields("PRIC_EZAPPI")
        .Fields("PRIC_NEBIKI_DISABLE") = (rsPriceTbl.Fields("PRIC_NEBIKI_DISABLE") = 1)         '2008/10/15 add iizuka

        .UPDATE
    End With
End Sub

