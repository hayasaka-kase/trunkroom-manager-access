Private Sub cmd_削除_KeyDown(KeyCode As Integer, Shift As Integer)

    Select Case KeyCode
        Case vbKeyReturn
            cmd_削除_Click

        Case vbKeyTab
            If Shift > 0 Then
                Me.cmb_ヤードコード.SetFocus
                Call cmd_Top_Click  ' 2005/11/21 ADD T.SUZUKI
            Else
                Me.cmd_取消.SetFocus
            End If

        Case vbKeyUp, vbKeyRight
            Me.cmd_取消.SetFocus

        Case vbKeyDown, vbKeyLeft
            If intModeflg <> intModeDelete Then
                Me.cmd_保存.SetFocus
            Else
                Me.cmd_終了.SetFocus
            End If
    End Select

    KeyCode = 0
End Sub

