Private Sub txt_ヤード名称かな_AfterUpdate()
    If Nz(Me.txt_ヤード名称かな, "") <> "" Then
        If Not CheckHiraganaOnly(Me.txt_ヤード名称かな) Then
            MsgBox "ひらがな以外の文字が含まれています。", vbExclamation
            Me.txt_ヤード名称かな = ""
        End If
    End If
End Sub

Private Sub txt_ヤード名称かな_BeforeUpdate(Cancel As Integer)
    Dim vCode       As Variant

    On Error GoTo err_rtn
      
    If blnFormLoadFlg = False Then Exit Sub

    vCode = Nz(Me.txt_ヤード名称かな, "")

    '何も入力されていない時は、処理をしない
    If vCode = "" Then
        Exit Sub
    End If

    '入力チェック
    Select Case CmBCheck_Char(vCode, 50)
        Case 0
    
        Case 2
            '桁数ｴﾗｰ
            MsgBox "25文字まで入力可能です。", vbInformation, strMsg_err
            Cancel = True
            GoTo Exit_rtn
        Case 9
    End Select

Exit_rtn:
    Exit Sub

err_rtn:
    MsgBox "ｴﾗｰ番号" & Err.Number & vbCrLf & Err.Description
    Err.Clear
    GoTo Exit_rtn
End Sub

Function CheckHiraganaOnly(ByVal txt As String) As Boolean
    Dim reg As Object
    Set reg = CreateObject("VBScript.RegExp")

    ' ひらがなの全範囲（ぁ?ん・ーなど含む）
    reg.Pattern = "^[\u3040-\u309Fー]+$"
    reg.Global = True
    reg.IgnoreCase = False

    CheckHiraganaOnly = reg.test(txt)
End Function

