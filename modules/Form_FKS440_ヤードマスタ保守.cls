'        MODULE_ID        :fncUpdCNTA_USE
'        Parameter        :intKbn
'                                0 = 上段
'                                1 = 下段
'                          intValue
'                                0 = 否
'                                1 = 可
'        CREATE_DATE      :2005/12/05
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncUpdCNTA_USE(ByVal intKbn As Integer, ByVal intValue As Integer) As Boolean

    Dim objRsWk  As Recordset
    Dim strSQL   As String

    On Error GoTo fncUpdCNTA_USE_Err

    fncUpdCNTA_USE = False

    ' コンテナ上段 OR 下段データ取得
    strSQL = "SELECT CNTA_USE "

    Select Case intKbn
        Case 0  ' *** 上段 ***
            strSQL = strSQL & " FROM ヤード上ＷＫ " & Chr(13)
        Case 1  ' *** 下段 ***
            strSQL = strSQL & " FROM ヤード下ＷＫ " & Chr(13)
    End Select

    Set objRsWk = objDb.OpenRecordset(strSQL, dbOpenDynaset)

    Do Until objRsWk.EOF
        objRsWk.Edit

        objRsWk.Fields("CNTA_USE") = intValue

        objRsWk.UPDATE

        objRsWk.MoveNext
    Loop
    objRsWk.Close
    Set objRsWk = Nothing

    fncUpdCNTA_USE = True

fncUpdCNTA_USE_Exit:
    If Not objRsWk Is Nothing Then objRsWk.Close: Set objRsWk = Nothing
    Exit Function

fncUpdCNTA_USE_Err:
    MsgBox "ｴﾗｰ番号" & Err.Number & vbCrLf & Err.Description
    Err.Clear
    GoTo fncUpdCNTA_USE_Exit
End Function

'==============================================================================*
'
'        MODULE_NAME      :小数入力項目の入力チェック
'        MODULE_ID        :fncTxtInputCheck
'        Parameter        :ctlTxt      = 対象となるテキストボックス
'                          varMaxValue = 最大値
'                          intLength   = 長さ
'        CREATE_DATE      :2005/12/15
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Public Function fncTxtInputCheck(ByRef ctlTxt As TextBox, _
                                 ByVal varMaxValue As Variant, ByVal intLength As Integer, _
                                 Optional ByVal intKbn As Integer = 0) As Boolean

    fncTxtInputCheck = False

    If IsNull(ctlTxt) = True Then
        fncTxtInputCheck = True: Exit Function
    End If

    Select Case intKbn
        Case 0
            If (ctlTxt > varMaxValue Or _
                Len(Replace(Replace(ctlTxt, ".", ""), "-", "")) > intLength) Then
                Exit Function
            End If

        Case 1
            ' *** フォームのエラーイベントでのエラートラップのとき
            If (ctlTxt > varMaxValue Or _
                Len(Replace(Replace(ctlTxt.Text, ".", ""), "-", "")) > intLength) Then
                Exit Function
            End If
    End Select
    fncTxtInputCheck = True
End Function

'==============================================================================*
'
'        MODULE_NAME      :コンテナの削除チェック
'        MODULE_ID        :fncKONT_DelCheck
'        Parameter        :lngYardCode = ヤードコード
'                          lngCntaCode = コンテナ番号
'        CREATE_DATE      :2005/12/27
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Public Function fncKONT_DelCheck(ByVal lngYardCode As Long, _
                                 ByVal lngCntaCode As Long) As Integer

    Dim intRtn    As Integer
    Dim strErrMsg As String

    On Error GoTo fncKONT_DelCheck_Err

    ' 初期化
    fncKONT_DelCheck = -1

    ' コンテナDB接続
    If fncConnectDB(pcintKONT_DB) = False Then Exit Function

    ' 物件チェックを行う
    intRtn = CmKomsMod.CheckLending(pobjKONT_DB, CmKomsMod.pcintYOYAKU_UNITCHECK, _
                                    lngYardCode, lngCntaCode, strErrMsg)

    If intRtn <> 0 Then
        MsgBox strErrMsg, vbInformation, strMsg_err
        GoTo fncKONT_DelCheck_Exit
    End If

    ' コンテナDB切断
    If fncDisConnectDB(pcintKONT_DB) = False Then Exit Function

    ' コンテナ削除可能
    fncKONT_DelCheck = 0

fncKONT_DelCheck_Exit:
    Exit Function

fncKONT_DelCheck_Err:
    MsgBox "ｴﾗｰ番号" & Err.Number & vbCrLf & Err.Description
    Err.Clear
End Function

'==============================================================================*
'
'        MODULE_NAME      : テキストボックスの入力値の範囲チェック
'        MODULE_ID        : fncTxtBetweenCheck
'        CREATE_DATE      : 2006/03/27
'
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncTxtBetweenCheck(ctlText As TextBox, ByVal dblMin As Double, ByVal dblMax As Double) As Boolean
    Dim dblVal              As Double
    
    If Nz(ctlText, "") <> "" Then
        dblVal = CDbl(ctlText)
        If (dblVal < dblMin) Or (dblMax < dblVal) Then
            MsgBox "指定値が適正でありません", vbInformation, strMsg_err
            fncTxtBetweenCheck = False
            Exit Function
        End If
    End If
    fncTxtBetweenCheck = True
End Function

