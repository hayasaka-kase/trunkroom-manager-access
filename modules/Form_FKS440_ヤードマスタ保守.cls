    strSQL = strSQL & vbCrLf & " YARD_DAISYA2,"
    strSQL = strSQL & vbCrLf & " YARD_DAISYA3,"
    strSQL = strSQL & vbCrLf & " YARD_DAISYA4,"
    
    strSQL = strSQL & vbCrLf & " YARD_D_DAN1,"
    strSQL = strSQL & vbCrLf & " YARD_D_DAN2,"
    strSQL = strSQL & vbCrLf & " YARD_D_DAN3,"
    strSQL = strSQL & vbCrLf & " YARD_D_DAN4,"
    
    strSQL = strSQL & vbCrLf & " YARD_D_TESURI1,"
    strSQL = strSQL & vbCrLf & " YARD_D_TESURI2,"
    strSQL = strSQL & vbCrLf & " YARD_D_TESURI3,"
    strSQL = strSQL & vbCrLf & " YARD_D_TESURI4,"
    
    strSQL = strSQL & vbCrLf & " YARD_MOYORI_EKI1,"
    strSQL = strSQL & vbCrLf & " YARD_MOYORI_EKI2,"
    strSQL = strSQL & vbCrLf & " YARD_MOYORI_EKI3,"
    
    strSQL = strSQL & vbCrLf & " YARD_MOYORI_BUS1,"
    strSQL = strSQL & vbCrLf & " YARD_MOYORI_BUS2,"
    strSQL = strSQL & vbCrLf & " YARD_MOYORI_BUS3,"
    
