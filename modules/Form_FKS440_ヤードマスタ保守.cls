'==============================================================================*
'
'        MODULE_NAME      :価格表上段・下段入力チェック
'        MODULE_ID        :fncInputCheckKakaku
'        Parameter        :intKbn(0:上段 / 1:下段)
'        CREATE_DATE      :2018/08/20
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncInputCheckKakaku(intKbn As Integer) As Integer

    Dim objRs        As Recordset
    Dim objSubForm   As SubForm
    Dim objControl   As Control

    On Error GoTo fncInputCheckKakaku_Err

    fncInputCheckKakaku = -1

    Select Case intKbn
        Case 0  ' *** 上段 ***
            Set objSubForm = Me.FKS440_ヤードマスタサブ価格表上

        Case 1  ' *** 下段 ***
            Set objSubForm = Me.FKS440_ヤードマスタサブ価格表下
    End Select

    doCmd.GoToRecord , , acFirst
    objSubForm.Requery

    ' 上段 OR 下段のレコードセットのクローン作成
    Set objRs = objSubForm.Form.RecordsetClone

    On Error Resume Next
    objRs.MoveLast
    objRs.MoveFirst

    Do Until objRs.EOF
        ' 入力チェック
        ' 初回雑費区分１
        If Nz(objRs.Fields("PRIC_FZAPPI_CODE"), "") = "63" Then
            MsgBox "事務手数料は「初回雑費２」に設定して下さい", vbInformation, strMsg_err
            objSubForm.SetFocus
            objSubForm.Form.Bookmark = objRs.Bookmark
            Set objControl = objSubForm!cmb_初回雑費区分
            GoTo fncInputCheckKakakuErr_Exit
        End If
        ' 毎回雑費区分１
        If Nz(objRs.Fields("PRIC_EZAPPI_CODE"), "") = "63" Then
            MsgBox "事務手数料は「初回雑費２」に設定して下さい", vbInformation, strMsg_err
            objSubForm.SetFocus
            objSubForm.Form.Bookmark = objRs.Bookmark
            Set objControl = objSubForm!cmb_毎月雑費区分
            GoTo fncInputCheckKakakuErr_Exit
        End If
        ' 初回雑費区分２
        If Nz(objRs.Fields("PRIC_FZAPPI_CODE2"), "") <> "63" Then
            MsgBox "「初回雑費２」は事務手数料を設定して下さい", vbInformation, strMsg_err
            objSubForm.SetFocus
            objSubForm.Form.Bookmark = objRs.Bookmark
            Set objControl = objSubForm!cmb_初回雑費区分2
            GoTo fncInputCheckKakakuErr_Exit
        End If
        ' 重複
' DELETE 2018/08/28 K.WADA
'        If Nz(objRs.Fields("PRIC_FZAPPI_CODE"), "") = Nz(objRs.Fields("PRIC_EZAPPI_CODE"), "") _
'            And Nz(objRs.Fields("PRIC_FZAPPI_CODE"), "") = Nz(objRs.Fields("PRIC_FZAPPI_CODE2"), "") _
'            And Nz(objRs.Fields("PRIC_FZAPPI_CODE"), "") <> "0" Then
' INSERT 2018/08/28 K.WADA
        If Nz(objRs.Fields("PRIC_FZAPPI_CODE"), "") = Nz(objRs.Fields("PRIC_EZAPPI_CODE"), "") _
            And Nz(objRs.Fields("PRIC_FZAPPI_CODE"), "") <> "0" Then
            MsgBox "１つの価格内で同じ雑費区分は指定できません", vbInformation, strMsg_err
            objSubForm.SetFocus
            objSubForm.Form.Bookmark = objRs.Bookmark
            Set objControl = objSubForm!cmb_初回雑費区分
            GoTo fncInputCheckKakakuErr_Exit
        End If

        objRs.MoveNext
    Loop
    objRs.Close
    Set objRs = Nothing

    Set objSubForm = Nothing

    fncInputCheckKakaku = 0

    GoTo fncInputCheckKakaku_Exit

fncInputCheckKakakuErr_Exit:
    ' 該当する項目にフォーカス移動
    objControl.SetFocus
    Set objControl = Nothing

fncInputCheckKakaku_Exit:
    If Not objRs Is Nothing Then objRs.Close: Set objRs = Nothing
    If Not objSubForm Is Nothing Then Set objSubForm = Nothing
    Exit Function

fncInputCheckKakaku_Err:
    MsgBox "ｴﾗｰ番号" & Err.Number & vbCrLf & Err.Description
    Err.Clear

    GoTo fncInputCheckKakaku_Exit
End Function

'==============================================================================*
'
'        MODULE_NAME      :近隣データ作成
'        MODULE_ID        :fncCreateNyar
'        Parameter        :
'        CREATE_DATE      :2005/10/24
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncCreateNyar(ByVal strYcode As String) As Boolean

    Dim strSQL   As String
    Dim objRs    As Recordset
    Dim objRsWk  As Recordset

    Dim intCount As Integer

    On Error GoTo fncCreateNyar_Err

    fncCreateNyar = False

    If Nz(strYcode, "") = "" Then Exit Function

    ' 近隣ヤードの件数チェック
    intCount = Nz(DCount("NYAR_YCODE", "FKS440_W01"), 0)
    If intCount > 0 Then Exit Function

' 2005/11/08 ADD T.SUZUKI Start
    ' コンテナDB接続
    If fncConnectDB(pcintKONT_DB) = False Then Exit Function
' 2005/11/08 ADD T.SUZUKI End

    ' 新規モードのときに近隣のヤードを作成
    strSQL = "  SELECT  YARD_CODE, " & Chr(13)    ' ヤードコード
    strSQL = strSQL & " YARD_NAME, " & Chr(13)    ' ヤード名
    strSQL = strSQL & " YARD_ADDR_1, " & Chr(13)  ' 住所１
'>>> INSERT START 2006/03/27 K.ISHIZAKA >>>
    strSQL = strSQL & " YARD_ADDR_3, " & Chr(13)    ' 住所３
    strSQL = strSQL & " YARD_ZAHYOKEI, " & Chr(13)  ' 座標系番号
    strSQL = strSQL & " YARD_IDO, " & Chr(13)       ' 緯度
    strSQL = strSQL & " YARD_KEIDO, " & Chr(13)     ' 経度
    strSQL = strSQL & " NULL AS YARD_KIRO, " & Chr(13)
'<<< INSERT END   2006/03/27 K.ISHIZAKA <<<
    strSQL = strSQL & " YARD_ADDR_2 " & Chr(13)   ' 住所２
    strSQL = strSQL & " FROM YARD_MAST " & Chr(13)       ' 2005/11/08 ADD T.SUZUKI
'    strSQL = strSQL & " FROM dbo_YARD_MAST " & Chr(13)  ' 2005/11/08 DEL T.SUZUKI
    strSQL = strSQL & " WHERE YARD_YUBINO = '" & Me.txt_郵便番号 & "' " & Chr(13)  ' 郵便番号
    strSQL = strSQL & "   AND YARD_CODE <> " & strYcode                            ' ヤードコード(自分以外)
    strSQL = strSQL & " ORDER BY YARD_CODE "
    Set objRs = pobjKONT_DB.OpenRecordset(strSQL, dbOpenDynaset, dbSQLPassThrough, dbReadOnly)  ' 2005/11/08 ADD T.SUZUKI
'    Set objRs = objDb.OpenRecordset(strSQL, dbReadOnly)                                        ' 2005/11/08 DEL T.SUZUKI

    If objRs.EOF = False Then
        strSQL = "SELECT * FROM FKS440_W01 "
        Set objRsWk = objDb.OpenRecordset(strSQL)

        With objRsWk
            Do Until objRs.EOF
                .AddNew
'>>> DELETE START 2006/03/27 K.ISHIZAKA >>>
'                .Fields("NYAR_YCODE") = Me.cmb_ヤードコード                                                        ' ヤードコード
'                .Fields("NYAR_NCODE") = objRs.Fields("YARD_CODE")                                                 ' 近隣ヤードコード
'                .Fields("YARD_NAME") = objRs.Fields("YARD_NAME")                                                  ' ヤード名
'                .Fields("YARD_ADDR") = Nz(objRs.Fields("YARD_ADDR_1"), "") & Nz(objRs.Fields("YARD_ADDR_2"), "")  ' ヤード住所
'                .UPDATE
'<<< DELETE END   2006/03/27 K.ISHIZAKA <<<
                Call subAddnewWork(objRsWk, objRs)

                objRs.MoveNext
            Loop
        End With
    End If
    objRs.Close
    Set objRs = Nothing

' 2005/11/08 ADD T.SUZUKI Start
    ' コンテナDB切断
    If fncDisConnectDB(pcintKONT_DB) = False Then Exit Function
' 2005/11/08 ADD T.SUZUKI End

    fncCreateNyar = True

fncCreateNyar_Exit:
    If Not objRs Is Nothing Then objRs.Close: Set objRs = Nothing
    If Not objRsWk Is Nothing Then objRsWk.Close: Set objRsWk = Nothing
    If Not pobjKONT_DB Is Nothing Then pobjKONT_DB.Close: Set pobjKONT_DB = Nothing  ' 2005/11/08 ADD T.SUZUKI
    Exit Function

fncCreateNyar_Err:
    MsgBox "ｴﾗｰ番号" & Err.Number & vbCrLf & Err.Description
    Err.Clear
    GoTo fncCreateNyar_Exit
End Function

'==============================================================================*
'
'        MODULE_NAME      :DB接続
'        MODULE_ID        :fncConnectDB
'        Parameter        :intDBKbn
'                                   pcintKONT_DB：コンテナDB
'                                   pcintKASE_DB：加瀬DB
'        CREATE_DATE      :2005/11/08
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncConnectDB(ByVal intDBKbn As Integer) As Boolean

'    Dim strBumoCD     As String  ' 2005/11/08 DEL T.SUZUKI

    Dim strConnect    As String
    Dim strDataSource As String

    On Error GoTo fncConnectDB_Err

    fncConnectDB = False

    Select Case intDBKbn
        Case pcintKONT_DB ' *** コンテナDB ***
            ' -----------------------------------------------------------------------------------------------------------
            ' コンテナDB接続
            strDataSource = Nz(DLookup("SETUT_SETUN", "SETU_TABL", "SETUT_SETUB = 'ODBC_DATA_SOURCE_NAME_" & pstrBumoCD & "'"), "")
 
            If strDataSource = "" Then
                MsgBox "SETU_TABLの設定が不正です。", vbExclamation, PROG_ID
                Set pobjKONT_DB = Nothing
                Exit Function
            Else
                Set pobjKONT_DB = Workspaces(0).OpenDatabase(strDataSource, dbDriverNoPrompt, False, MSZZ007_M00(pstrBumoCD))
            End If
            ' -----------------------------------------------------------------------------------------------------------
        Case pcintKASE_DB  ' *** 加瀬DB ***
            ' -----------------------------------------------------------------------------------------------------------
            ' 加瀬DB接続
            strDataSource = Nz(DLookup("SETUT_SETUN", "SETU_TABL", "SETUT_SETUB = 'ODBC_DATA_SOURCE_NAME'"))

            If strDataSource = "" Then
                MsgBox "SETU_TABLの設定が不正です。", vbExclamation, PROG_ID
                Set pobjKASE_DB = Nothing
                Exit Function
            End If
        
            Set pobjKASE_DB = Workspaces(0).OpenDatabase(strDataSource, dbDriverNoPrompt, False, MSZZ007_M00())
            ' -----------------------------------------------------------------------------------------------------------
    End Select

    fncConnectDB = True

    Exit Function

fncConnectDB_Err:
    MsgBox "ｴﾗｰｺｰﾄﾞ" & Err.Number & Space(1) & "ｴﾗｰﾒｯｾｰｼﾞ" & Err.Description
    Err.Clear
End Function

'==============================================================================*
'
'        MODULE_NAME      :DB切断
'        MODULE_ID        :fncDisConnectDB
'        Parameter        :intDBKbn
'                                   0：コンテナDB
'                                   1：加瀬DB
'        CREATE_DATE      :2005/11/08
'==============================================================================*
'---+----1----+----2----+----3----+----4----+----5----+----6----+----7----+----8
Private Function fncDisConnectDB(ByVal intDBKbn As Integer) As Boolean

    On Error GoTo fncDisConnectDB_Err

    fncDisConnectDB = False

    Select Case intDBKbn
        Case 0  ' *** コンテナDB ***
            pobjKONT_DB.Close
            Set pobjKONT_DB = Nothing
        Case 1  ' *** 加瀬DB ***
            pobjKASE_DB.Close
            Set pobjKASE_DB = Nothing
    End Select

    fncDisConnectDB = True

    Exit Function

fncDisConnectDB_Err:
    MsgBox "ｴﾗｰｺｰﾄﾞ" & Err.Number & Space(1) & "ｴﾗｰﾒｯｾｰｼﾞ" & Err.Description
    Err.Clear
End Function

