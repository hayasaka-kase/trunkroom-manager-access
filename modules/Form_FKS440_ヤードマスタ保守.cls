    strSQL = strSQL & " SELECT * "
    strSQL = strSQL & "   FROM FKS440_W02 "
    strSQL = strSQL & "  WHERE PRIC_STEP = " & intStep
' 200511/21 DEL T.SUZUKI Start
'    strSQL = strSQL & "  ORDER BY PRIC_STEP, "
'    strSQL = strSQL & "           PRIC_USAGE, "
'    strSQL = strSQL & "           PRIC_SIZE "
' 200511/21 DEL T.SUZUKI End

    MakePriceRecordSource = strSQL
End Function


